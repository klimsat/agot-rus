	### holdings

	type item_ledger_province = widget_ledger_item {
		datacontext = "[LedgerProvinceItem.GetProvince]"
		datacontext = "[Province.GetHolding]"
		size = { @widget 70 }
		blockoverride "ledger_decoration" {}

		proportional_icon = {
			# position = { 0 5 }
			size = { 600 46 }
			alwaystransparent = yes
			parentanchor = right|bottom
			texture = "[Province.GetTerrain.GetIllustration]"
			alpha = 0.3
			modify_texture = { 
				texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
				blend_mode = alphaMultiply
			}
			using = Mask_Rough_Edges
		}
			
		vbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			blockoverride "char_header_margins" {}

			bottomtotop = yes # so coa in the header stay on top

			hbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding

				hbox_province_stats = {
					visible = "[Not(Holding.IsEmpty)]" # should never happen
				}

				expand = {}

				hbox = {
					alwaystransparent = yes
					spacing = 5
					# right now we can fit 3 special buildings and 5 normal ones
					# if it's possible to get more, it'll show +1 in the top left corner
					
					hbox = {
						visible = "[Not(Holding.GetType.HasParameter('no_buildings'))]"
						righttoleft = yes
						alwaystransparent = no # to avoid the button blinking when the cursor moves between buildings

						hbox = {
							spacing = 2
							datamodel = "[DataModelFirst(LedgerProvinceItem.GetBuildings, Min_int32(GetDataModelSize(LedgerProvinceItem.GetBuildings), '(int32)5'))]"
							righttoleft = yes
							
							item = {
								widget_building_item_ledger = {}
							}
						}

						widget = {
							size = { 0 0 }
							
							text_single = {
								position = { -5 -10 }
								visible = "[GreaterThan_int32(GetDataModelSize(LedgerProvinceItem.GetBuildings), '(int32)5')]"
								background = {
									using = Background_Area_ExtraDark
									margin = { 5 0 }
								}
								raw_text = "+[Subtract_int32(GetDataModelSize(LedgerProvinceItem.GetBuildings), '(int32)5')]"
							}
						}
					}

					widget = {
						size = { 130 40 }
						alwaystransparent = yes
						
						hbox = {
							spacing = 2
							visible = "[And(Not(Province.GetHolding.IsEmpty), Not(Holding.GetType.HasParameter('no_buildings')))]"
							blockoverride "special" {}
							
							expand = {}
							blockoverride "building_bg" {				
								alpha = 0.7
								margin = { -2 -2 }
							}
							
							widget_building_item_ledger = {
								visible = "[Holding.HasDuchyBuildingSlot]"
								datacontext = "[LedgerProvinceItem.GetGUIDuchyCapitalBuilding]"
							}
							widget_building_item_ledger = {
								visible = "[GUIBuildingItem.HasPotentialBuilding]"
								datacontext = "[LedgerProvinceItem.GetGUISpecialBuilding]"
							}
							
							widget_building_item_ledger = {
								visible = "[GUIBuildingItem.HasPotentialBuilding]"
								datacontext = "[LedgerProvinceItem.GetGUIGreatBuilding]"
							}
						}
					}

					widget = {
						size = { 80 45 }

						container = {
							visible = "[Not(Province.GetHolding.IsEmpty)]"

							datacontext = "[LedgerProvinceItem.GetGUIHoldingBuilding]"

							widget_building_item_ledger = {
								parentanchor = right
								visible = "[EqualTo_int32(Province.GetFortLevel, '(int32)0')]"
							}

							widget_building_item_ledger = {
								button_standard_clean = {
									alpha = 0
									alwaystransparent = yes
									size = { 100% 100% }
								}
								size = { 80 45 }
								visible = "[GreaterThan_int32(Province.GetFortLevel, '(int32)0')]"
								blockoverride "fort" {}
							}
						}
					}
				}
			}

			widget_ledger_header = {
				size = { 0 26 }
				blockoverride "ledger_header" {
					spacing = 5

					hbox = {
						spacing = 3

						widget = {
							size = { 30 26 }
							coa_title_tiny = {
								scale = 0.8
								parentanchor = center
								position = { 0 4 }
								datacontext = "[Province.GetTitle]"
							}
						}

						icon = {
							name = "terrain"
							datacontext = "[Province.GetTerrain]"
							texture = "[Terrain.GetIcon]"
							size = { 26 26 }
							tooltip = "HOLDING_TERRAIN_TOOLTIP"
						}
					}

					widget = {
						size = { 150 26 }
						layoutpolicy_horizontal = expanding

						hbox = {
							layoutpolicy_horizontal = expanding

							widget = {
								size = { 60 26 }
								layoutpolicy_horizontal = expanding

								text_single = {
									autoresize = no
									margin = { 5 0 }
									size = { 100% 21 }
									text = "[Province.GetNameNoTooltip]"
								}
							}

							hbox_title_shared_buttons = {
								spacing = 10
								blockoverride "button_size" {
									size = { 20 20 }
								}
								blockoverride "raze_shortcut" {}
								datacontext = "[Province.GetTitle]"
								datacontext = "[Title.GetHolder]"
							}
						}
					}

					hbox = {
						margin_right = 5
						spacing = 5
						datacontext = "[Province.GetCounty]"
						datacontext = "[County.GetTitle]"

						widget = {
							size = { 45 26 }

							icon = {
								name = "realm_capital_icon"
								visible = "[Province.GetTitle.IsCountyCapital]"
								size = { 24 24 }
								texture = "gfx/interface/icons/icon_capital.dds"
								framesize = { 60 60 }
								frame = 1
								parentanchor = hcenter
								tooltip = "COUNTY_CAPITAL_TOOLTIP"
							}
							
							coa_title_tiny = {
								visible = "[Not(Province.GetTitle.IsCountyCapital)]"
								position = { 0 4 }
								scale = 0.8
								parentanchor = center
							}
						}

						hbox = {
							spacing = 22

							hbox_province_county_stats = {}

							star_button = {
								size = { 30 26 }
							}

							block "no_sort" {
								hbox = {
									datacontext = "[County.GetCount]"
									visible = "[Character.IsValid]"
									spacing = 5

									widget = {
										size = { 25 26 }

										coa_realm_tiny = {
											scale = 0.8
											position = { 0 4 }
											parentanchor = center
											datacontext = "[Character.GetGovernment]"
											visible = "[Not(ObjectsEqual(Character.Self, Character.GetTopLiege))]"
										}
									}

									widget = {
										size = { 25 26 }
										datacontext = "[County.GetCount.GetTopLiege]"
										visible = "[Character.IsValid]"
										coa_realm_tiny = {
											scale = 0.8
											position = { 0 4 }
											parentanchor = center
											datacontext = "[Character.GetGovernment]"
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}

	type hbox_province_stats = hbox {
		spacing = 10
		margin_left = 3

		widget = {
			size = { 25 25 }
			block "no_sort" {
				icon_flat_standard = {
					size = { 25 25 }
					texture = "[Province.GetHolding.GetType.GetTabIcon]"
					# tooltip = "[Province.GetHolding.GetType.GetConceptName]"
				}
			}
		}

		widget = {
			size = { @num5 @height }

			block "tax" {
				text_ledger_center = {
					visible = "[Not( Holding.GetHolder.HasBarterGoods )]"
					text = "[Holding.GetIncome|1+=]"
					tooltip = "[Holding.GetTaxTooltip]"
					format_override = { zero_value low }
				}

				text_ledger_center = {
					visible = "[Holding.GetHolder.HasBarterGoods]"
					text = "[Holding.GetBarterGoodsIncome|1+=]"
				}
			}
		}

		widget = {
			size = { @num4 @height }

			block "loot" {
				text_ledger_center = {
					default_format = "#clickable"
					text = "[Province.GetLoot|0]"
					tooltip = "[Province.GetLootTooltip]"

					background = {
						visible = "[Holding.GetProvince.IsRecentlyLooted]"
						using = Status_Bad
						alpha = 0.3
						margin = { 0 0 }
						margin_bottom = -4
					}
				}
			}
		}

		widget = {
			size = { @num4 @height }

			block "levies" {
				widget = {
					size = { 100% 100% }
					visible = "[Not( Holding.GetType.HasParameter( 'no_levies' ) )]"

					text_ledger_center = {
						default_format = "#e"
						text = "[Holding.GetMaxLevySize|0]"
						tooltip = "[Holding.GetLeviesTooltip]"
					}
				}
			}
		}
	}

