	type item_ledger_char_strong = widget_ledger_item {
		datacontext = "[LedgerCharacterItem.GetCharacter]"
		size = { @widget 64 }

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			portrait_head_tiny = {}

			vbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding


				widget_ledger_char_header = {
					layoutpolicy_horizontal = expanding
					blockoverride "martial" {}
					blockoverride "prowess" {}
				}

				hbox_ledger_char_strong = {}
			}
		}
	}

	type hbox_ledger_char_strong = hbox {
		spacing = 5
		layoutpolicy_horizontal = expanding

		widget = {
			size = { 130 40 }

			block "no_sort" {
				hbox = {
					# margin = { 10 0 }

					widget = {
						size = { 30 30 }
						datacontext = "[Character.GetTraitFromGroup( GetTraitGroup('education_martial') )]"
						visible = "[Character.HasTrait( Trait.Self )]"
						icon_trait = {
							blockoverride "icon_size" {
								size = { 30 30 }
							}
						}
					}

					widget = {
						size = { 100 40 }
						block "no_sort" {
							blockoverride "trait_glow" {}
							overlappingitembox = {
								parentanchor = vcenter
								size = { 100% 30 }
								datacontext = "[LedgerCharacterItem.GetTraitArrays]"
								datamodel = "[TraitArrays.GetTraits]"
								item = {
									icon_trait = {
										visible = "[EqualTo_string(Trait.GetTraitCategoryLabel, GetTrait('logistician').GetTraitCategoryLabel)]"
										# visible = "[Trait.HasFlag('commander_trait_flag')]"
										blockoverride "icon_size" {
											size = { 30 30 }
										}
									}
								}
							}
						}
					}

					expand = {}
				}
			}
		}

		widget = {
			size = { @num6 @height }
			block "strength" {
				text_ledger_full = {
					visible = "[Character.IsRuler]"
					text = "[Character.GetMilitaryStrengthText]"
					tooltip = "[LedgerWindow.GetMilitaryStrengthTooltip( Character.Self )]"
				}
			}
		}

		widget = {
			size = { @num6 @height }
			block "maa" {
				text_ledger_full = {
					visible = "[Character.IsRuler]"
					text = "[Character.GetMenAtArmsStrength]"
					tooltip = "[men_at_arms|e]"
				}
			}
		}

		widget = {
			size = { @num3 @height }
			block "knights" {
				text_ledger_center = {
					visible = "[Character.IsRuler]"
					
					text = "[GetDataModelSize(Character.GetKnights)]"
					alpha = "[Select_float( DataModelHasItems(Character.GetKnights), '(float)1.0', '(float)0.5' )]"
					
					tooltip_visible = "[DataModelHasItems(Character.GetKnights)]"
					
					tooltipwidget = {
						container_ledger_tooltip = {
							blockoverride "top_tt" {
								text_single = {
									text = "[Character.Custom('KnightCulturePlural')]"
								}
							}
							blockoverride "tooltipwidget" {
								datamodel = "[Character.GetKnights]"
								item = {
									flowcontainer = {
										ignoreinvisible = yes
										spacing = 5
										text_single = {
											autoresize = no
											size = { @num4 20 }
											raw_text = "@skill_prowess_icon![Character.GetProwess]"
										}
										text_single = {
											text = "LEDGER_NAME_AGE"
										}
									}
								}
							}
						}
					}
				}
			}
		}

		widget = {
			size = { @num6 @height }
			block "knight_effectiveness" {
				text_ledger_center = {
					# visible = "[Character.IsRuler]"
					text = "[Character.GetKnightEffectiveness|+0%]"
					alpha = "[Select_float( And(GreaterThan_CFixedPoint(Character.GetKnightEffectiveness, '(CFixedPoint)1'), Character.IsRuler), '(float)1.0', '(float)0.5' )]"

					tooltipwidget = {
						container_ledger_tooltip = {
							blockoverride "tooltipwidget" {
								margin_bottom = -5
								text_single = {
									text = "[knight_effectiveness|e]"
								}
								text_single = {
									text = "[Character.GetKnightEffectivenessBreakdown]"
								}
							}
						}
					}
				}
			}
		}

		widget = {
			size = { @num3 @height }
			block "dread" {
				text_ledger_center = {
					visible = "[Character.IsRuler]"
					text = "[Character.GetDread|0]"
					tooltip = "[Character.GetDreadBreakdown]"
					alpha = "[Select_float( GreaterThan_CFixedPoint(Character.GetDread, '(CFixedPoint)1'), '(float)1.0', '(float)0.5' )]"

				}
			}
		}

		widget = {
			size = { @num3 @height }
			block "prisoners" {
				text_ledger_center = {
					visible = "[NotZero(Character.GetNumberOfPrisoners)]"
					text = "[Character.GetNumberOfPrisoners]"

					tooltipwidget = {
						container_ledger_tooltip = {
							blockoverride "top_tt" {
								text_single = {
									text = "[prisoners|e]"
								}
							}
							blockoverride "tooltipwidget" {
								datamodel = "[Character.GetPrisoners]"
								item = {
									text_single = {
										text = "LEDGER_NAME_AGE"
									}
								}
							}
						}
					}
				}
			}
		}

		widget = {
			size = { @num6 @height }
			block "herd" {
				widget = {
					visible = "[IsNomad(Character)]"
					size = { 100% 100% }

					text_ledger_right = {
						margin_right = 10
						tooltip = "[Character.GetDomicile.GetHerdBreakdown]"
						visible = "[Character.GetDomicile.IsValid]"
						text = "[Character.GetDomicile.GetHerd]"
					}
				}
			}
		}
	}

