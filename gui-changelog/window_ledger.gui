			position = {0 0}
		}

		tooltip = "LEDGER_DOCTRINE_TOOLTIP"
	}

	type item_ledger_religion = widget_ledger_item {
		size = { @widget 64 }
		datacontext = "[LedgerReligionItem.GetReligion]"

		vbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			widget_ledger_header = {
				blockoverride "ledger_header" {
					text_ledger = {
						size = { 250 20 }
						text = "[Religion.GetName]"
						format_override = { l medium }
					}

					text_ledger = {
						size = { 220 20 }
						text = "[Religion.GetFamily.GetNameNoTooltip]" # Pagan tooltip is enormous, better not show it
						default_format = "#low"
					}

					text_ledger = {
						size = { 60 20 }
						# text = "[Religion.GetFoundingDate]" #TODO TIT-70025
					}

					expand = {}


					star_button = {
						size = { 26 26 }
					}

					widget_ledger_place = {}
				}
			}

			blockoverride "hide_religion" {}
			blockoverride "counties" {
				text = "[Religion.GetNumberOfCounties]"
				tooltip = "RELIGION_COUNTIES_TT"
			}
			blockoverride "county_change" {
				text = "[Religion.GetCountiesChange|=+]"
				tooltip = "RELIGION_COUNTIES_CHANGE_TT"
			}
			blockoverride "followers" {
				text = "[Religion.GetNumberOfFollowers]"
				tooltip = "RELIGION_FOLLOWERS_TT"
			}
			blockoverride "rulers" {
				text = "[Religion.GetNumberOfRulers]"
				tooltip = "RELIGION_RULERS_TT"
				visible = "[NotZero(Religion.GetNumberOfRulers)]"
			}
			blockoverride "sinners" {
				text = "[Religion.GetNumberOfSinners]"
				tooltip = "RELIGION_SINNERS_TT"
				visible = "[NotZero(Religion.GetNumberOfRulers)]"
			}
			blockoverride "virtuous" {
				text = "[Religion.GetNumberOfVirtuous]"
				tooltip = "RELIGION_VIRTUOUS_TT"
				visible = "[NotZero(Religion.GetNumberOfRulers)]"
			}
			blockoverride "holy_wars" {
				raw_text = "[Religion.GetNumberOfHolyWars] @war_icon!"
				visible = "[NotZero(Religion.GetNumberOfHolyWars)]"
			}
			blockoverride "sites" {
				text = "RELIGION_CONTROLLED_HOLY_SITES"
				tooltip = "RELIGION_CONTROLLED_HOLY_SITES_TT"
			}
			blockoverride "strength" {
				text = "[Religion.GetTotalMilitaryStrength|*0]"
				tooltip = "RELIGION_TOTAL_STRENGTH_TT"
				visible = "[NotZero(Religion.GetNumberOfRulers)]"
			}
			blockoverride "stats" {
				widget = {
					size = { 180 @height }

					block "faiths" {
						hbox = {
							margin_left = 5
							hbox = {
								datamodel = "[DataModelFirst(Religion.GetFaiths, Min_int32('(int32)5', GetDataModelSize(Religion.GetFaiths)))]"

								item = {
									button_standard_hover = {
										size = { 30 30 }
										onclick = "[OpenGameViewData('faith', Faith.Self)]"
										icon = {
											alwaystransparent = yes
											size = { 100% 100% }
											texture = "[Faith.GetIcon]"
										}
										tooltipwidget = {
											faith_tooltip_click = {}
										}
									}
								}
							}
							text_single = {
								default_format = "#low"
								align = nobaseline
								visible = "[GreaterThan_int32(GetDataModelSize(Religion.GetFaiths), '(int32)5')]"
								raw_text = "+[Subtract_int32(GetDataModelSize(Religion.GetFaiths), '(int32)5')]"
							}

							expand = {}
						}
					}
				}
			}

			expand = {}

			hbox_faith_stats = {}
		}
	}
	
	type button_ledger_faith = button_standard_hover {
		onclick = "[OpenGameViewData('faith', Faith.Self)]"
		icon = {
			alwaystransparent = yes
			size = { 100% 100% }
			texture = "[Faith.GetIcon]"
		}
		tooltipwidget = {
			faith_tooltip_click = {}
		}
	}

	### cultures

	type item_ledger_culture = widget_ledger_item {
		size = { @widget 64 }
		datacontext = "[LedgerCultureItem.GetCulture]"
		widget = {
			size = { 375 64 }
			scissor = yes
			highlight_icon = {
				datacontext = "[Culture.GetEthos]"
				name = "icon"
				size = { 630 150 }
				position = { 0 10 }
				alpha = 0.2
				texture = "[CulturePillar.GetIcon]"
				using = Mask_Rough_Edges
				modify_texture = {
					texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
					blend_mode = alphamultiply
					mirror = horizontal
				}
			}
		}

		highlight_icon = {
			parentanchor = right|vcenter
			size = { 255 130 }
			texture = "[Culture.GetCultureEra.GetType.GetIllustration]"
			using = Mask_Rough_Edges
			alpha = 0.2

			modify_texture = {
				texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
				blend_mode = alphamultiply
			}
		}
		
		alpha = "[Select_float(  NotZero(Culture.GetNumberOfCharacters), '(float)1.0', '(float)0.5' )]"

		hbox = {
			layoutpolicy_horizontal = expanding

			vbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding

				widget_ledger_header = {
					scissor = yes

					blockoverride "ledger_header" {

						margin_left = 65
						datacontext = "[Culture.GetHeritage]"

						text_ledger = {
							size = { 180 20 }
							text = "[Culture.GetName]"
							format_override = { l medium }
						}

						text_ledger = {
							size = { 120 20 }
							text = "[CulturePillar.GetNameNoTooltip]"
							default_format = "#low"
							tooltip_visible = "[GetPlayer.IsValid]"
							tooltipwidget = {
								using = culture_pillar_tooltip
							}
						}

						expand = {}


						text_ledger = {
							align = nobaseline
							size = { 70 20 }
							text = "CULTURE_LEDGER_DATE"
							tooltip = "[Culture.GetCreationString]"
							visible = "[And(GreaterThan_int32(Culture.GetCreationDate.GetYear, '(int32)1'), LessThanOrEqualTo_int32(Culture.GetCreationDate.GetYear, GetCurrentDate.GetYear))]"
							default_format = "#low;emp"
						}

						text_ledger = {
							size = { 120 20 }
							margin_right = 10
							align = nobaseline|right
							datacontext = "[Culture.GetCultureEra]"
							text = "[Culture.GetCultureEra.GetType.GetName]"
							default_format = "#low"
							tooltipwidget = {
								using = culture_era_tooltip
							}
						}

						star_button = {
							size = { 30 26 }
						}

						widget_ledger_place = {}
					}

				}
				hbox_culture_stats = {}
			}
		}

		widget = {
			size = { 60 72 }
			datacontext = "[Culture.GetCultureHead]"
			portrait_ledger_trans = {
				size = { 60 72 }
				position = { 2 -7 }

				visible = "[Character.IsValid]"
			}

			highlight_icon = {
				name = "portrait_unknown_head_small_glow"
				parentanchor = center
				position = { 3 -9 }
				gfxtype = framedbuttongfx
				effectname = "NoHighlight"
				texture = "gfx/portraits/unknown_portraits/button_unknown_head.dds"
				size = { 80 100 }
				framesize = { 384 480 }
				upframe = 1
				overframe = 2
				tooltip = "CULTURE_WINDOW_NO_HEAD"
				block "glow_visible" {

					visible = "[Not(Character.IsValid)]"
				}

				block "glow_flip" {}

				block "onclick" {}
			}

		}
	}

	type hbox_culture_stats = hbox {
		layoutpolicy_horizontal = expanding
		margin_left = 65
		margin_right = 2
		spacing = 9

		widget = {
			size = { 185 @height }
			block "sort_traditions" {
				overlappingitembox = {
					size = { 100% 36 }
					datamodel = "[Culture.GetTraditions]"
					spacing = 4

					item = {
						widget = {
							tooltipwidget = {
								using = culture_tradition_tooltip
							}
							size = { 35 34 }
							scissor = yes

							# a shadow for the overlap if there are 6+ traditions
							background = {
								using = Background_Area_Border_Solid
								alpha = 0.5
								margin_left = 3
							}

							widget_tradition_icon = {
								size = { 276 138 } # to keep proportions
								scale = 0.33
								parentanchor = center
								datacontext = "[CultureTradition.GetLayeredIcon]"
							}
						}
					}
				}
			}
		}

		expand = {}

		widget = {
			size = { @num4 @height }
			block "sort_counties" {
				text_ledger_center = {
					text = "[Culture.GetNumberOfCounties]"
					tooltip = "LEDGER_CULTURES_COUNTIES"
				}
			}
		}

		widget = {
			size = { @num2 @height }
			block "sort_counties_change" {
				text_ledger_center = {
					text = "[Culture.GetCountiesChange|=+]"
					format_override = { zero_value low }
					tooltip = "CULTURE_COUNTIES_CHANGE_TT"
				}
			}
		}

		divider_light = {
			layoutpolicy_vertical = expanding
		}

		widget = {
			size = { @num4 @height }
			block "sort_characters" {
				text_ledger_center = {
					text = "[Culture.GetNumberOfCharacters]"
					tooltip = "LEDGER_CULTURES_CHARACTERS"
				}
			}
		}

		widget = {
			size = { @num3 @height }
			block "sort_rulers" {
				text_ledger_center = {
					text = "[Culture.GetNumberOfRulers]"
					default_format = "#clickable"
					visible = "[NotZero(Culture.GetNumberOfRulers)]"
					tooltip = "LEDGER_CULTURES_RULERS"
				}
			}
		}

		divider_light = {
			layoutpolicy_vertical = expanding
		}
		

		widget = {
			size = { @num3 @height }
			block "sort_average_development" {
				text_ledger_center = {
					text = "[Culture.GetAverageDevelopment]"
					visible = "[NotZero(Culture.GetNumberOfCounties)]"
					tooltip = "LEDGER_CULTURES_AVERAGE_DEVELOPMENT"
				}
			}
		}

		widget = {
			size = { @num4 @height }
			block "sort_acceptance" {
				widget = {
					size = { 100% 100% }
					visible = "[GetPlayer.IsValid]"

					text_ledger_center = {
						visible = "[Not(ObjectsEqual(Culture.Self, GetPlayer.GetCulture ))]"
						text = "[Divide_CFixedPoint(Culture.GetAcceptance( GetPlayer.GetCulture ), '(CFixedPoint)100')|0+%]"
						format_override = { zero_value low }
						tooltip = "CULTURE_ACCEPTANCE_TOOLTIP"
					}
				}
			}
		}

		widget = {
			size = { @num4 @height }
			block "sort_strength" {
				text_ledger_right = {
					text = "[Culture.GetTotalMilitaryStrength|*0]"
					visible = "[NotZero(Culture.GetNumberOfRulers)]"
					tooltip = "CULTURES_TOTAL_STRENGTH_TT"
				}
			}
		}
		
		widget = {
			size = { 10 34 }
			block "no_sort" {
				progressbar_royal_court = {
					position = { 0 1 }
					size = { 100% 100% }
					max = "[CultureEra.GetNumberOfInnovations]"
					value = "[CultureEra.GetNumberOfActiveInnovations]"
					direction = vertical
					datacontext = "[Culture.GetCultureEra]"
					tooltip = TT_LEDGER_INNOVATIONS
					using = tooltip_sw
				}
			}
		}
	}

	###

	# for the future

	type item_ledger_killer = widget_ledger_item {
		datacontext = "[LedgerCharacterItem.GetCharacter]"
		size = { @widget 42 }
		
		widget_ledger_char_header = {
			size = { 100% 100% }
			
			blockoverride "pre_ledger_coa" {
				widget = {
					size = { 45 42 }
					portrait_ledger_tiny = {
						parentanchor = center
						position = { 0 -3 }
						#AGOT Added
						visible = "[Not(IsCharacterDragon)]"
					}
					#AGOT Added
					agot_dragon_portrait_ledger_tiny = {}
				}
			}
			blockoverride "ledger_coa" {}
			blockoverride "pre_ledger_name" {
				text_ledger_c = {
					size = { 100 42 }
					text = "[Character.GetNumberOfKillsKnownTo( GetPlayer )]"
					default_format = "#bold"
					tooltip = "LEDGER_KNOWN_KILLS"
				}
			}
			blockoverride "name_width" {
				max_width = 300
			}
		}
	}

	type item_ledger_relation = widget {
		datacontext = "[LedgerCharacterItem.GetCharacter]"
		size = { @widget 40 }
	}

	type item_ledger_dev = widget {
		datacontext = "[LedgerCharacterItem.GetCharacter]"
		size = { @widget 85 }
	}

	###

	type text_ledger = text_single {
		autoresize = no
		align = nobaseline
		alwaystransparent = yes
		using = tooltip_below
	}

	type text_ledger_c = text_single {
		autoresize = no
		align = nobaseline|center
		alwaystransparent = yes
		using = tooltip_below
	}

	type text_ledger_full = text_single {
		autoresize = no
		size = { 100% 100% }
		align = nobaseline
		alwaystransparent = yes
		using = tooltip_below
	}

	type text_ledger_right = text_single {
		autoresize = no
		size = { 100% 100% }
		align = nobaseline|right
		margin_right = 5
		alwaystransparent = yes
		using = tooltip_below
	}

	type text_ledger_center = text_single {
		autoresize = no
		size = { 100% 100% }
		align = nobaseline|center
		alwaystransparent = yes
		using = tooltip_below
	}

	type ledger_divider = widget {
		size = { 3 @height }
		alwaystransparent = yes
		block "no_sort" {
			divider_light = {
				size = { 100% 100% }
			}
		}
	}

	type container_ledger_tooltip = container {
		alwaystransparent = no
		using = DefaultTooltipBackground
		
		flowcontainer = {
			ignoreinvisible = yes
			direction = vertical
			margin_bottom = 5
			
			flowcontainer = {
				ignoreinvisible = yes
				margin = { 20 15 }
				block "top_tt" {}
			}
			 
			scrollbox = {
				autoresizescrollarea = yes
				maximumsize = { 600 600 }
				size = { 0 0 }
				blockoverride "scrollbox_margins" {
					margin = { 10 5 }
				}
				blockoverride "scrollbox_content" {
					flowcontainer = {
						margin = { 10 10 }
						ignoreinvisible = yes
						spacing = 3
						direction = vertical
						margin_bottom = 15
						
						block "tooltipwidget" {}
					}
				}
			}
		}
	}
}

template color_local_player {
	color = { 0.5 0.6 0.7 0.6 }
}
template color_other_player {
	color = { 0.8 0.4 0.55 0.6 }
}
template tintcolor_local_player {
	tintcolor = { 0.5 0.6 0.7 0.6 }
}
template tintcolor_other_player {
	tintcolor = { 0.8 0.4 0.55 0.6 }
}

