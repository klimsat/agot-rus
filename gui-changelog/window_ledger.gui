	# auto-centers
	type hbox_sort_ledger = hbox {
		button_sort_ledger = {}
	}

	# can change position
	type button_sort_ledger = button {
		size = { 46 38 }
		block "sort_name" {}

		background = {
			using = Background_Area
			margin = { 0 4 }
		}
		
		hbox = {
			layoutpolicy_vertical = expanding
			divider_light = {
				layoutpolicy_vertical = expanding
			}
			vbox = {
				spacing = -8

				button_icon = {
					alwaystransparent = yes
					size = { 28 28  }
					texture = "gfx/interface/colors/black.dds"
					inherit_visual_state = yes
					block "sort_down" {}

					modify_texture = {
						block "icon" {
							texture = "gfx/interface/icons/icon_opinion.dds"
						}
						blend_mode = alphamultiply
					}
				}

				ledger_sort_icon = {
					block "sort_icon" {}
				}
			}
			
			divider_light = {
				layoutpolicy_vertical = expanding
			}
		}
	}
	
	type button_sort_ledger_short = button_sort_ledger {
		block "sort_tooltip" {
			tooltip = "BUTTON_SORT_LEDGER"
		}
		onclick = "[LedgerWindow.SortBy(PdxGuiWidget.GetName)]"
		
		blockoverride "sort_icon" {
			visible = "[LedgerWindow.IsSortingBy(PdxGuiWidget.AccessParent.AccessParent.AccessParent.GetName)]"
		}
		blockoverride "sort_down" {
			down = "[LedgerWindow.IsSortingBy(PdxGuiWidget.AccessParent.AccessParent.AccessParent.GetName)]"
		}
	}
	
	type hbox_sort_ledger_short = hbox {
		block "sort_tooltip" {
			tooltip = "BUTTON_SORT_LEDGER"
		}
		blockoverride "sort_icon" {
			visible = "[LedgerWindow.IsSortingBy(PdxGuiWidget.AccessParent.AccessParent.AccessParent.AccessParent.GetName)]"
		}
		blockoverride "sort_down" {
			down = "[LedgerWindow.IsSortingBy(PdxGuiWidget.AccessParent.AccessParent.AccessParent.AccessParent.GetName)]"
		}
		button_sort_ledger = {
			onclick = "[LedgerWindow.SortBy(PdxGuiWidget.AccessParent.GetName)]"
		}
	}

	type ledger_sort_icon = widget {
		size = { 18 18 }

		icon = {
			frame = "[BoolTo1And2(LedgerWindow.GetSortOrder)]"
			parentanchor = center

			alwaystransparent = yes
			texture = "gfx/interface/buttons/button_sort_toggle.dds"
			framesize = { 36 36 }
			size = { 140% 140% }

			using = Master_Button_Modify_Texture

			blockoverride "master_color_frame" {
				frame = 6
			}
		}

		icon = {
			frame = "[BoolTo1And2(LedgerWindow.GetSortOrder)]"

			parentanchor = center
			alwaystransparent = yes
			texture = "gfx/interface/buttons/button_sort_toggle.dds"
			framesize = { 36 36 }
			size = { 100% 100% }

			using = Master_Button_Modify_Texture

			blockoverride "master_color_frame" {
				frame = 2
			}
		}
	}

