	### title

	type item_ledger_title = widget_ledger_item {
		size = { @widget 64	 }
		datacontext = "[LedgerTitleItem.GetTitle]"

		# unlanded titles open the title view
		blockoverride "ledger_click" {
			onclick = "[DefaultOnCoatOfArmsClick(Title.GetID)]"
			#AGOT Added
			visible = "[IsTitleShownInLedger]"
		}

		# counties open the county view
		blockoverride "ledger_click2" {
			#AGOT Modified
			# visible = "[And(Title.IsLanded, Title.IsCounty)]"
			visible = "[And(IsTitleShownInLedger,And(Title.IsLanded, Title.IsCounty))]"
			onclick = "[DefaultOnCoatOfArmsRightClick(Title.GetID)]"
			onclick = "[OpenGameViewData('holding_view', Title.GetProvince.Self)]"
		}

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			widget = {
				size = { 58 58 }

				coa_title_medium = {
					scale = 0.8
					#AGOT Added
					visible = "[IsTitleShownInLedger]"
				}
				#AGOT Added
				agot_ledger_coa_title_medium = {}
			}

			vbox = {
				layoutpolicy_horizontal = expanding
				
				alpha = "[Select_float(  Title.GetHolder.IsValid, '(float)1.0', '(float)0.75' )]"

				widget_ledger_header = {
					hbox = {
						layoutpolicy_horizontal = expanding
						margin_left = 15

						background = {
							texture = "gfx/interface/colors/red.dds"
							alpha = 0.15
							visible = "[Not(Title.GetHolder.IsValid)]"
						}

						text_ledger = {
							text = "[Title.GetNameNoTierNoTooltip]"
							size = { 190 20 }
							layoutpolicy_horizontal = expanding
							tooltip = "TITLE_VIEW_NOT_CREATED"
							tooltip_visible = "[Not(Title.GetHolder.IsValid)]"
							#AGOT Added
							visible = "[IsTitleShownInLedger]"
						}
						#AGOT Added
						agot_ledger_hide_title_name = {}

						hbox = {
							spacing = 5
							block "title_faith" {
								datacontext = "[Title.GetDominantFaith]"
								tooltip = "LEDGER_DOMINANT_TITLE_FAITH"
							}
							visible = "[Faith.IsValid]"
							

							icon = {
								size = { 25 25 }
								texture = "[Faith.GetIcon]"
							}

							text_ledger = {
								size = { 120 20 }
								text = "[Faith.GetAdjectiveNoTooltip]"
								default_format = "#low"
							}
						}

						hbox = {
							spacing = 5
							visible = "[Culture.IsValid]"
							block "title_culture" {
								datacontext = "[Title.GetDominantCulture]"
								tooltip = "LEDGER_DOMINANT_TITLE_CULTURE"
							}

							text_ledger = {
								size = { 120 20 }
								text = "[Culture.GetNameNoTooltip]"
								default_format = "#low"
							}
						}


						expand = {}

						star_button = {
							size = { 30 26 }
						}

						widget_ledger_place = {}
					}
				}

				hbox_title_stats = {}
			}
		}
	}

	type hbox_title_stats = hbox {
		layoutpolicy_horizontal = expanding
		margin_left = 15
		
		hbox = {
			layoutpolicy_horizontal = expanding
			block "landed" {}
			widget = {
				size = { @num3 @height }
				block "county_hide" {}
				block "counties" {
					text_ledger_full = {
						text = "[Title.GetNumberOfDeJureCounties|*0]"
						tooltip = "DEJURE_TITLE_COUNTIES_TT"
						visible = "[IsZero(Title.GetNumberOfDeFactoCounties)]"
					}
					text_ledger_full = {
						text = "[Title.GetNumberOfDeFactoCounties|*0]"
						tooltip = "DEFACTO_TITLE_COUNTIES_TT"
						visible = "[NotZero(Title.GetNumberOfDeFactoCounties)]"
					}
				}
			}

			widget = {
				size = { @num3 @height }
				block "holdings" {
					text_ledger_full = {
						visible = "[Or(Title.HasDeJureCounties, NotZero(Title.GetNumberOfDeFactoCounties))]"
						text = "[Title.GetNumberOfHoldings|*0]"
						block "holdings_format" {
							default_format = "#low"
						}
						tooltip = "sort_l_holdings"
					}
				}
			}

			ledger_divider = {}
			
			widget = {
				size = { @num5 @height }
				block "tax" {
					text_ledger_center = {
						visible = "[Or(Title.HasDeJureCounties, NotZero(Title.GetNumberOfDeFactoCounties))]"
						text = "[Title.GetTotalIncome|0+=]"
						format_override = { zero_value low }
