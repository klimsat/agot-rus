					datamodel = "[LedgerWindow.GetKillers]"
				}
				blockoverride "pinned_ledger_datamodel" {
					datamodel = "[LedgerWindow.GetKillersPinned]"
				}
				blockoverride "podium_datamodel" {
					datamodel = "[LedgerWindow.GetKillersPodium]"
				}
				
				blockoverride "podium_1" {
					visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetKillersPodium), '(int32)0')]"
				}
				blockoverride "podium_2" {
					visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetKillersPodium), '(int32)1')]"
				}
				blockoverride "podium_3" {
					visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetKillersPodium), '(int32)2')]"
				}
				
				blockoverride "resize" {}

				blockoverride "addrow_legder" {
					addrow = 46
				}
				
				blockoverride "filters_visible" {
					visible = no
				}
				
				blockoverride "scrollbox_empty_visibility" {
					visible = "[IsDataModelEmpty(LedgerWindow.GetKillers)]"
					text = "NO_LEDGER_ITEMS"
				}
				
				blockoverride "expand_pinned_visibility" {
					visible = "[GreaterThanOrEqualTo_int32( GetDataModelSize(LedgerWindow.GetKillersPinned), '(int32)1' )]"
				}
				blockoverride "pinned_ledger_scrollbox_visibility" {
					visible = "[GreaterThanOrEqualTo_int32( GetDataModelSize(LedgerWindow.GetKillersPinned), '(int32)4' )]"
				}
				blockoverride "pinned_ledger_vbox_visibility" {
					visible = "[LessThan_int32( GetDataModelSize(LedgerWindow.GetKillersPinned), '(int32)4' )]"
				}

				blockoverride "ledger_text" {
					datacontext = "[LedgerCharacterItem.GetCharacter]"
					text = "[Character.GetNameNoTooltip]"
				}

				blockoverride "ledger_item" {
					item_ledger_killer = {}
				}
				
				blockoverride "ledger_click" {
					onclick = "[DefaultOnCharacterClick(Character.GetID)]"
					onclick = "[OpenGameViewData( 'kill_list', Character.GetID  )]"
				}
				
				blockoverride "ledger_podium_widget" {
					portrait_torso_podium = {
						datacontext = "[LedgerCharacterItem.GetCharacter]"
					}
				}

				blockoverride "ledger_count" {
					text = "[GetDataModelSize(LedgerWindow.GetKillers)]"
				}
				blockoverride "sorting_line" {
					spacer = { size = { 85 0 } }
					hbox_sort_ledger_short = {
						name = "kills"
						blockoverride "icon" {
							texture = "gfx/interface/icons/icon_kill.dds"
						}
					}
				}

				# pins
				blockoverride "ledger_pin" {
					onclick = "[LedgerWindow.ToggleKillerPin(Character.Self)]"
				}
				blockoverride "down_ledger_pin" {
					visible = "[LedgerWindow.IsKillerPinned(Character.Self)]"
				}
			}

			# Relations (characters with num of children, lovers, etc)
			vbox_ledger = {
				visible = "[GetVariableSystem.HasValue('ledger_tab', 'relations')]"
				# datamodels
				blockoverride "ledger_datamodel" {
					datamodel = "[LedgerWindow.GetRelations]"
				}
				blockoverride "pinned_ledger_datamodel" {
					datamodel = "[LedgerWindow.GetRelationsPinned]"
				}
				blockoverride "podium_datamodel" {
					datamodel = "[LedgerWindow.GetRelationsPodium]"
				}
				blockoverride "scrollbox_empty_visibility" {
					visible = "[IsDataModelEmpty(LedgerWindow.GetRelations)]"
					text = "NO_LEDGER_ITEMS"
				}

				blockoverride "ledger_text" {
					text = "[Character.GetName]"
				}

				blockoverride "ledger_item" {
					item_ledger_relation = {}
				}

				blockoverride "ledger_count" {
					text = "[GetDataModelSize(LedgerWindow.GetRelations)]"
				}

				# pins
				blockoverride "ledger_pin" {
					onclick = "[LedgerWindow.ToggleRelationPin(Character.Self)]"
				}
				blockoverride "down_ledger_pin" {
					visible = "[LedgerWindow.IsRelationPinned(Character.Self)]"
				}
			}

			expand = {}
		}

		window_ledger_filters = {}
	}
}

@drop = 295
@dropheight = 500
@widget = 630
@height = 40
@num2 = 30
@num3 = 35
@num4 = 40
@num5 = 45
@num6 = 50

types LedgerTypes {
	type ledger_filter_item = hbox {
		spacing = 10
		margin_bottom = 10

		text_single = {
			layoutpolicy_horizontal = expanding
			text = "[LedgerListFilter.GetName]"
			default_format = "#medium"
			align = nobaseline
			autoresize = no
		}

		expand = {}

		dropdown_sort_characterlist = {
			datamodel = "[LedgerListFilter.GetOptions]"
			onselectionchanged = "[LedgerListFilter.SetCurrentFilterFromIndex]"
			selectedindex = "[LedgerListFilter.GetCurrentFilterIndex]"

			blockoverride "text_button_drop" {
				text = "[LedgerListFilterOption.GetName]"
				# tooltip = "[LedgerListFilterOption.GetDescription]"
			}

			blockoverride "size_button_drop" {
				size = { 185 33 }
			}

			blockoverride "size_dropdown" {
				size = { 175 33 }
			}
		}
	}

	type vbox_ledger = vbox {
		layoutpolicy_vertical = expanding
		layoutpolicy_horizontal = expanding
		margin_top = -5

		vbox = {
			layoutpolicy_horizontal = expanding
			spacing = 5
			
			bottomtotop = yes

			background = {
				block "background_art" {
					texture = "gfx/interface/illustrations/decisions/decision_dynasty_house.dds"
				}
				alpha = 0.15
				color = { 0.65 0.65 0 1 }
				fittype = centercrop

				modify_texture = {
					texture = "gfx/interface/component_masks/mask_fade_textured_vertical_up.dds"
					blend_mode = alphaMultiply
				}
			}
			
			# podium
			vbox = {
				block "podium" {
					visible = "[Not(GetVariableSystem.Exists('ledger_podium'))]"
				}
				layoutpolicy_horizontal = expanding
				spacing = 5
				margin_top = -10
				margin_bottom = 4
				
				widget = {
					block "podium_check" {}
					size = { 0 190 }
					layoutpolicy_horizontal = expanding
					
					widget_ledger_podium = {
						position = { -200 -5 }
						parentanchor = center
						blockoverride "style" {
							default_format = "#bold;e;glow_color:{0.1,0.1,0.1,1.0}"
						}
						block "podium_2" {}
						blockoverride "podium_index" {
							index = 1
						}
					}
					
					widget_ledger_podium = {
						background = {
							name = "selected"
							using = Background_Portrait_Glow
							color = { 0.8 0.7 0.5 0.22 }
							margin = { 10 0 }
							margin_top = -30
							block "podium_bg" {}
						}
						
						position = { 0 -20 }
						parentanchor = center
						blockoverride "style" {
							default_format = "#bold;highlight;glow_color:{0.1,0.1,0.1,1.0}"
						}
						blockoverride "podium_index" {
							index = 0
						}
						block "podium_1" {}
					}
					
					widget_ledger_podium = {
						parentanchor = center
						position = { 200 0 }
						blockoverride "style" {
							default_format = "#bold;clickable;glow_color:{0.1,0.1,0.1,1.0}"
						}
						blockoverride "podium_index" {
							index = 2
						}
						block "podium_3" {}
					}
				}
			}

			# podium toggle
			widget = {
				layoutpolicy_horizontal = expanding
				size = { 0 35 }

				hbox = {
					layoutpolicy_horizontal = expanding

					hbox = {
						margin = { 10 0 }

						background = {
							using = Text_Label_Background
							margin = { 0 3 }
							margin_right = 50
							alpha = 0.7

							modify_texture = {
								name = "mask"
								texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
								spriteType = Corneredstretched
								spriteborder = { 0 0 }
								blend_mode = alphamultiply
								mirror = horizontal
							}
						}

						hbox = {
							spacing = 5

							button_standard = {
								name = "filters"
								size = { 25 25 }

								frame = "[BoolTo1And2(LedgerWindow.CanResetFilters)]"
								onclick = "[GetVariableSystem.Toggle('ledger_filters')]"
								down = "[GetVariableSystem.Exists('ledger_filters')]"
								shortcut = ledger_filters

								tooltip = "TOGGLE_FILTERS"
								using = tooltip_nw

								button_search = {
									alwaystransparent = yes
									parentanchor = center
									size = { 20 20 }
								}

								block "filters_visible" {}
							}

							button_replace = {
								size = { 25 25 }
								visible = "[LedgerWindow.CanResetFilters]"
								onclick = "[LedgerWindow.ResetFilters]"
								tooltip = "CHARACTER_RESET_FILTERS"
								using = tooltip_se
								tooltip_offset = { 40 0 } # I want players to see the number update
							}

							divider_light = {
								size = { 3 20 }
								block "filters_visible" {}
							}
						}

						button = {
							size = { 220 32 }
							onclick = "[GetVariableSystem.Toggle( 'ledger_podium' )]"
							tooltip = "TT_TOGGLE_PODIUM"
							block "podium_tt" {}
							
							widget = {
								# there are multiple "podium" blocks to hide all these things with one override, when there is no podium
								block "podium" {}
								size = { 100% 100% }
								alwaystransparent = yes
								
								button_standard_hover = {
									size = { 100% 100% }
									alwaystransparent = yes
								}
								
								button_standard_list = {
									visible = "[Not(GetVariableSystem.Exists('ledger_toggle_shown'))]"
									size = { 100% 100% }
									
									state = {
										name = _mouse_hierarchy_enter
										on_finish = "[GetVariableSystem.Set('ledger_toggle_shown', 'yes')]"
									}
								}
							}
							
							hbox = {
								resizeparent = yes
								spacing = 8

								margin = { 10 0 }

								button_expand = {
									block "podium" {}
									alwaystransparent = yes
									frame = "[BoolTo2And1(GetVariableSystem.Exists('ledger_podium'))]"
								}

								text_single = {
									align = nobaseline
									block "ledger_count" {}
									max_width = 80
								}

								text_single = {
									align = nobaseline
									using = Font_Type_Flavor
									using = Font_Size_Medium
									max_width = 130
									block "ledger_title" {
										text = "[Localize(Concatenate(GetVariableSystem.Get('ledger_tab'), '_name'))]"
									}
								}

								expand = {}
							}
						}
					}

					expand = {}

					hbox_ledger_sort_buttons = {
						background = {
							using = Text_Label_Background
							margin = { 10 3 }
							margin_left = 50
							alpha = 0.7

							modify_texture = {
								name = "mask"
								texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
								spriteType = Corneredstretched
								spriteborder = { 0 0 }
								blend_mode = alphamultiply
							}
						}
					}
				}
			}
		}

		spacer = {
			size = { 0 5 }
		}

		block "tabs" {
			divider_light = {
				layoutpolicy_horizontal = expanding
			}
		}
		
		block "filters_line" {}

		# sorting line
		# reuses the "stats" widget of an item
		widget = {
			size = { @widget 50 }
			
			block "sorting_widget" {}

			hbox = {
				layoutpolicy_horizontal = expanding
				block "sorting_line" {}
				# we're slightly offset comapred to the scrollbox
				margin_right = 5
				margin_left = -5
				margin_top = 5

				expand = {}
			}
			blockoverride "no_sort" {}
		}

		scrollbox = {
			layoutpolicy_vertical = expanding
			layoutpolicy_horizontal = expanding
			background = { using = Background_Area_Border_Solid alpha = 0.5 }

			blockoverride "scrollbox_content" {

				vbox = {
					layoutpolicy_horizontal = expanding
					spacing = 5


					fixedgridbox = {
						name = "gridbox"
						block "ledger_datamodel" {}
						block "addrow_legder" {
							addrow = 40
						}
						addcolumn = 630
						layoutpolicy_horizontal = expanding
						block "resize" {
							setitemsizefromcell = yes
						}

						item = {
							block "ledger_item" {
								button_basic_ledger_item = {}
							}
						}
					}
				}
			}

			blockoverride "scrollbox_empty" {
				layoutpolicy_vertical = expanding
				block "scrollbox_empty_visibility"
				{
				}
			}
		}

		vbox = {
			oncreate = "[BindFoldOutContext]"
			oncreate = "[PdxGuiFoldOut.Unfold]"
			layoutpolicy_horizontal = expanding

			button_expandable_toggle_field = {
				block "expand_pinned_visibility" {
					visible = no
				}
				blockoverride "text" {
					margin_left = 5
					text = "LEDGER_PINNED_ITEMS"
				}
			}
			vbox = {
				visible = "[PdxGuiFoldOut.IsUnfolded]"

				background = { using = Background_Area_Border_Solid alpha = 0.5 }

				### Pinned Items Scrollbox
				vbox = {
					layoutpolicy_horizontal = expanding

					block "pinned_ledger_scrollbox_visibility" {}

					scrollbox = {
						layoutpolicy_vertical = expanding
						layoutpolicy_horizontal = expanding

						size = { 660 280}

						blockoverride "scrollbox_content" {
							vbox = {
								layoutpolicy_horizontal = expanding
								layoutpolicy_vertical = expanding
								spacing = 8

								fixedgridbox = {
									name = "pinned_gridbox"
									block "pinned_ledger_datamodel" {}
									block "addrow_legder" {
										addrow = 40
									}
									addcolumn = 630
									layoutpolicy_horizontal = expanding
									block "resize" {
										setitemsizefromcell = yes
									}
									# pinned items are slightly golden
									blockoverride "item_bg" {
										background = {
											texture = "gfx/interface/colors/gold.dds"
											alpha = 0.04
										}
									}
									blockoverride "favorite_tooltip" {
										tooltip = "UNFAVORITE_LEDGER"
									}

									item = {
										block "ledger_item" {
											button_basic_ledger_item = {}
										}
									}
								}

								vbox = {
									layoutpolicy_horizontal = expanding
									margin_bottom = 8
									visible = "[GreaterThan_int32(PdxGuiWidget.AccessParent.FindChild('pinned_gridbox').GetChildrenCount, '(int32)0')]"

									divider_light = {
										layoutpolicy_horizontal = expanding
									}
								}
							}
						}
					}
				}

				### Pinned Items Vbox
				vbox = {
					layoutpolicy_horizontal = expanding

					block "pinned_ledger_vbox_visibility" {}

					vbox = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding

						spacing = 8

						fixedgridbox = {
							name = "pinned_gridbox"
							block "pinned_ledger_datamodel" {}
							block "addrow_legder" {
								addrow = 40
							}
							addcolumn = 630
							layoutpolicy_horizontal = expanding
							block "resize" {
								setitemsizefromcell = yes
							}
							# pinned items are slightly golden
							blockoverride "item_bg" {
								background = {
									texture = "gfx/interface/colors/gold.dds"
									alpha = 0.04
								}
							}
							blockoverride "favorite_tooltip" {
								tooltip = "UNFAVORITE_LEDGER"
							}

							item = {
								block "ledger_item" {
									button_basic_ledger_item = {}
								}
							}
						}
					}
				}
			}
		}

		margin_bottom = 5

		expand = {}
	}

	type widget_ledger_podium = widget {
		size = { 200 150 }
		
		widget = {
			size = { 100% 100% }
			block "ledger_podium_widget" {}
			datacontext_from_model = {
				block "podium_datamodel" {}
				block "podium_index" {
					index = "1"
				}
			}
			icon = {
				size = { 100% 36 }
				texture = "gfx/interface/icons/banners/banner_brown_center.dds"
				spriteType = Corneredtiled
				spriteborder = { 72 0 }
				spriteborder_right = 114
				texture_density = 4
				parentanchor = hcenter|bottom
				position = { 0 20 }
				
				flowcontainer = {
					ignoreinvisible = yes
					spacing = 5
					parentanchor = center
					position = { 0 3 }
					
					background = {
						using = Text_Label_Background
						margin = { 35 2 }
						alpha = 0.6
					}

					text_single = {
						max_width = 120
						min_height = 21
						align = nobaseline
						
						block "style" {
							default_format = "#bold;highlight"
						}
						block "ledger_text" {}
						block "podium_format" {}
					}
				}
			}
		}
	}

	type flow_ledger_bookmarks = flowcontainer {
		ignoreinvisible = yes
		spacing = -5
		parentanchor = right
		direction = vertical

		state = {
			name = default_ledger_tab
			# trigger_on_create = yes
			trigger_when = "[Not(GetVariableSystem.Exists('ledger_tab'))]"
			on_finish = "[GetVariableSystem.Set('ledger_tab', 'ongoing_wars')]"
		}

		button_tab_ledger_bookmark = {
			shortcut = "ledger_tab_1"
			blockoverride "tab_down" {
				down = "[GetVariableSystem.HasValue( 'ledger_tab', 'ongoing_wars' )]"
			}
			blockoverride "tab_button" {
				onclick = "[GetVariableSystem.Set('ledger_tab', 'ongoing_wars')]"
				tooltip = "ongoing_wars_name"
			}
			blockoverride = "tab_glow" {
				visible = "[GetVariableSystem.HasValue( 'ledger_tab', 'ongoing_wars' )]"
			}
			blockoverride "tab_active" {
				trigger_when = "[GetVariableSystem.HasValue( 'ledger_tab', 'ongoing_wars' )]"
			}
			blockoverride "tab_inactive" {
				trigger_when = "[Not(GetVariableSystem.HasValue( 'ledger_tab', 'ongoing_wars' ))]"
			}
			blockoverride "tab_texture" {
				using = icon_wars_ledger
			}
		}

		button_tab_ledger_bookmark = {
			shortcut = "ledger_tab_2"
			blockoverride "tab_down" {
				down = "[GetVariableSystem.HasValue( 'ledger_tab', 'artifacts' )]"
			}
			blockoverride "tab_button" {
				onclick = "[GetVariableSystem.Set('ledger_tab', 'artifacts')]"
				tooltip = "artifacts_name"
			}
			blockoverride = "tab_glow" {
				visible = "[GetVariableSystem.HasValue( 'ledger_tab', 'artifacts' )]"
			}
			blockoverride "tab_active" {
				trigger_when = "[GetVariableSystem.HasValue( 'ledger_tab', 'artifacts' )]"
			}
			blockoverride "tab_inactive" {
				trigger_when = "[Not(GetVariableSystem.HasValue( 'ledger_tab', 'artifacts' ))]"
			}
			blockoverride "tab_texture" {
				using = icon_artifacts_ledger
			}
		}

		button_tab_ledger_bookmark = {
			shortcut = "ledger_tab_3"
			blockoverride "tab_down" {
				down = "[GetVariableSystem.HasValue( 'ledger_tab', 'characters' )]"
			}
			blockoverride "tab_button" {
				onclick = "[GetVariableSystem.Set('ledger_tab', 'characters')]"
				tooltip = "characters_name"
			}
			blockoverride = "tab_glow" {
				visible = "[GetVariableSystem.HasValue( 'ledger_tab', 'characters' )]"
			}
			blockoverride "tab_active" {
				trigger_when = "[GetVariableSystem.HasValue( 'ledger_tab', 'characters' )]"
			}
			blockoverride "tab_inactive" {
				trigger_when = "[Not(GetVariableSystem.HasValue( 'ledger_tab', 'characters' ))]"
			}
			blockoverride "tab_texture" {
				using = icon_characters_ledger
			}
		}

		button_tab_ledger_bookmark = {
			shortcut = "ledger_tab_4"
			blockoverride "tab_down" {
				down = "[GetVariableSystem.HasValue( 'ledger_tab', 'houses' )]"
			}
			blockoverride "tab_button" {
				onclick = "[GetVariableSystem.Set('ledger_tab', 'houses')]"
				tooltip = "houses_name"
			}
			blockoverride = "tab_glow" {
				visible = "[GetVariableSystem.HasValue( 'ledger_tab', 'houses' )]"
			}
			blockoverride "tab_active" {
				trigger_when = "[GetVariableSystem.HasValue( 'ledger_tab', 'houses' )]"
			}
			blockoverride "tab_inactive" {
				trigger_when = "[Not(GetVariableSystem.HasValue( 'ledger_tab', 'houses' ))]"
			}
			blockoverride "tab_texture" {
				using = icon_houses_ledger
			}
		}

		button_tab_ledger_bookmark = {
			shortcut = "ledger_tab_5"
			blockoverride "tab_down" {
				down = "[GetVariableSystem.HasValue( 'ledger_tab', 'provinces' )]"
			}
			blockoverride "tab_button" {
				onclick = "[GetVariableSystem.Set('ledger_tab', 'provinces')]"
				tooltip = "provinces_name"
			}
			blockoverride = "tab_glow" {
				visible = "[GetVariableSystem.HasValue( 'ledger_tab', 'provinces' )]"
			}
			blockoverride "tab_active" {
				trigger_when = "[GetVariableSystem.HasValue( 'ledger_tab', 'provinces' )]"
			}
			blockoverride "tab_inactive" {
				trigger_when = "[Not(GetVariableSystem.HasValue( 'ledger_tab', 'provinces' ))]"
			}
			blockoverride "tab_texture" {
				using = icon_holdings_ledger
			}
		}

		button_tab_ledger_bookmark = {
			shortcut = "ledger_tab_6"
			blockoverride "tab_down" {
				down = "[GetVariableSystem.HasValue( 'ledger_tab', 'counties' )]"
			}
			blockoverride "tab_button" {
				onclick = "[GetVariableSystem.Set('ledger_tab', 'counties')]"
				tooltip = "counties_name"
			}
			blockoverride = "tab_glow" {
				visible = "[GetVariableSystem.HasValue( 'ledger_tab', 'counties' )]"
			}
			blockoverride "tab_active" {
				trigger_when = "[GetVariableSystem.HasValue( 'ledger_tab', 'counties' )]"
			}
			blockoverride "tab_inactive" {
				trigger_when = "[Not(GetVariableSystem.HasValue( 'ledger_tab', 'counties' ))]"
			}
			blockoverride "tab_texture" {
				using = icon_counties_ledger
			}
		}

		button_tab_ledger_bookmark = {
			shortcut = "ledger_tab_7"
			blockoverride "tab_down" {
				down = "[GetVariableSystem.HasValue( 'ledger_tab', 'titles' )]"
			}
			blockoverride "tab_button" {
				onclick = "[GetVariableSystem.Set('ledger_tab', 'titles')]"
				tooltip = "titles_name"
			}
			blockoverride = "tab_glow" {
				visible = "[GetVariableSystem.HasValue( 'ledger_tab', 'titles' )]"
			}
