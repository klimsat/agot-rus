	type widget_ledger_item = widget {
		block "item_bg" {}
		scissor = yes

		state = {
			name = _mouse_hierarchy_enter
			on_finish = "[PdxGuiWidget.FindChild('button_favorite').TriggerAnimation('hover_enter')]"
		}

		state = {
			name = _mouse_hierarchy_leave
			on_finish = "[PdxGuiWidget.FindChild('button_favorite').TriggerAnimation('hover_leave')]"
		}

		block "ledger_decoration" {
			background = {
				using = Background_Area_Light
				alpha = 0.2
				block "character_bg" {
					# visible = "[Character.IsRuler]"
					# alpha = "[Select_float( Character.IsRuler, '(float)0.5', '(float)0.1' )]"
				}
			}

			background = {
				using = Background_Area_Light
				alpha = 0.2
			}

			icon = {
				size = { 100% 1 }
				texture = "gfx/interface/colors/blue.dds"
				alpha = 0.5
			}

			icon = {
				size = { 100% 1 }
				texture = "gfx/interface/colors/blue.dds"
				parentanchor = bottom
				alpha = 0.2
			}
		}

		widget = {
			size = { 100% 100% }
			block "player_item_check" {
				visible = "[GetPlayer.IsValid]"
			}

			background = {
				texture = "gfx/interface/colors/white.dds"
				tintcolor = { 0.5 0.6 0.7 0.6 }
				alpha = 0.1
				block "player_item" {
					visible = no
				}
			}
		}

		button_standard_hover = {
			block "ledger_click" {}
			button_ignore = none
			size = { 100% 100% }
		}

		# if we need to check for something
		button_standard_hover = {
			size = { 100% 100% }
			button_ignore = none
			block "ledger_click2" {
				visible = no
			}
		}
	}

	### wars

	type item_ledger_war = button_standard_hover {
		layoutpolicy_vertical = expanding
		layoutpolicy_horizontal = expanding
		size = { 100% 68 }
		datacontext = "[LedgerWarItem.GetWar]"
		visible = "[War.IsValid]"

		down = "[IsGameViewDataShown( 'war_overview', War.GetID )]"

		button_ignore = none
		onclick = "[LedgerWindow.OpenWarOverview( War.Self )]"
		onclick = "[DefaultOnCoatOfArmsRightClick(War.GetActiveCasusBelli.GetDefender.GetPrimaryTitle.GetID)]"

		onrightclick = "[DefaultOnCoatOfArmsRightClick(War.GetActiveCasusBelli.GetDefender.GetPrimaryTitle.GetID)]"

		# helps with the title
		background = { using = Background_Area_Light }

		block "item_bg" {}

		state = {
			name = _mouse_hierarchy_enter
			on_finish = "[PdxGuiWidget.FindChild('button_favorite').TriggerAnimation('hover_enter')]"
		}

		state = {
			name = _mouse_hierarchy_leave
			on_finish = "[PdxGuiWidget.FindChild('button_favorite').TriggerAnimation('hover_leave')]"
		}

		block "button" {
			progressbar_standard_transparent = {
				size = { 99% 44 }
				position = { 0 0 }
				# werid size so we get the highlight from the button around the progressbar
				parentanchor = bottom|hcenter
				min = -100
				max = 100
				value = "[War.GetWarScore]"
				alpha = 0.85
			}
		}

		vbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			widget = {
				size = { 0 26 }
				layoutpolicy_horizontal = expanding

				star_button = {
					parentanchor = right
					# bigger so it's easier to find
					size = { 105 26 }
					blockoverride "button" {
						parentanchor = left
					}

					text_ledger = {
						size = { 80 26 }
						autoresize = no
						align = nobaseline|right
						parentanchor = right
						position = { -10 0 }
						text = "[GetTimeBetweenDates(War.GetStartDate, GetCurrentDate)]"
						alwaystransparent = yes
						default_format = "#emp"
						format_override = { v low }
					}
				}

				widget = {
					size = { 100% 100% }

					widget = {
						size = { 50% 100% }

						hbox = {
							layoutpolicy_horizontal = expanding
							spacing = 5
							margin_left = 5

							icon = {
								size = { 20 20 }
								texture = "[War.GetActiveCasusBelli.GetType.GetIcon]"
							}

							# text_ledger = {
							# 	alwaystransparent = yes
							# 	size = { 400 20 }
							# 	align = nobaseline
							# 	text = "[War.GetName]"
							# 	# overrides to remove bright white and underlines
							# 	format_override = { high low }
							# 	format_override = { L e }
							# }

							text_ledger = {
								layoutpolicy_horizontal = growing
								alwaystransparent = yes
								size = { 0 21 }
								margin_bottom = 1
								align = nobaseline
								text = "[War.GetActiveCasusBelli.GetType.GetName]"
								margin_right = 10
								default_format = "#low"
								format_override = { e low }
							}

							text_single = {
								alwaystransparent = yes
								autoresize = yes
								max_width = 160
								align = nobaseline|right
								text = "[War.GetActiveCasusBelli.GetAttacker.GetPrimaryTitle.GetNameNoTierNoTooltip]"
							}
							margin_right = 35
						}
					}

					
					widget = {
						size = { 20 20 }
						parentanchor = hcenter
						divider_light = {
							size = { 3 20 }
							parentanchor = center
						}
						
						icon = {
							size = { 20 20 }
							texture = "gfx/interface/icons/war_score/icon_war_score_objectives.dds"
							visible = "[GreaterThan_CFixedPoint(War.GetTickingWarScore, '(CFixedPoint)0')]"

							tooltipwidget = {
								container_ledger_tooltip = {
									blockoverride "tooltipwidget" {
										text_single = {
											text = "LEDGER_HELD_OBJECTIVE"
										}
									}
								}
							}
						}
					}


					text_ledger = {
						alwaystransparent = yes
						size = { 150 20 }
						widgetanchor = left|vcenter
						position = { 36 0 } # it's 1 pixel off at 35 for some reason
						parentanchor = center
						align = nobaseline
						text = "[War.GetActiveCasusBelli.GetDefender.GetPrimaryTitle.GetNameNoTierNoTooltip]"
					}
				}
			}

			hbox_war_stats = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				background = {
					using = Background_Area
					alpha = 0.5
				}
				margin = { 5 0 }
				margin_top = 3
			}
		}
	}

	type hbox_war_stats = hbox {
		layoutpolicy_vertical = expanding

		widget_ledger_war_casualties = {
			blockoverride "right" {
				righttoleft = yes
			}
			block "sort_losses" {
				datacontext = "[War.GetAttackers]"
				datacontext = "[War.GetActiveCasusBelli.GetAttacker]"
			}
		}

		expand = { }

		widget = {
			size = { 70 0 }
			layoutpolicy_vertical = expanding

			block "no_sort" {
				flow_war_ledger_participants = {
					parentanchor = right
					righttoleft = yes

					blockoverride "text" {
						visible = "[GreaterThan_int32(GetDataModelSize(LedgerWarItem.GetAttackersParticipantItems), '(int32)1')]"
						raw_text = "+[Subtract_int32(GetDataModelSize(LedgerWarItem.GetAttackersParticipantItems), '(int32)1')]"
					}

					blockoverride "datamodel" {
						visible = "[DataModelHasItems(LedgerWarItem.GetAttackersParticipantItems)]"
						datamodel = "[DataModelFirst(LedgerWarItem.GetAttackersParticipantItems, Min_int32('(int32)1', GetDataModelSize(LedgerWarItem.GetAttackersParticipantItems)))]"
					}

					blockoverride "right" {
						righttoleft = yes
					}
				}
			}
		}

		widget = {
			size = { 130 0 }
			layoutpolicy_vertical = expanding

			block "attacker_strength" {
				# Attacker
				datacontext = "[War.GetActiveCasusBelli.GetAttacker]"

				hbox = {
					spacing = 5

					expand = {}

					coa_realm_tiny = {}

					hbox_soldiers_and_quality_ledger = {
						datacontext = "[LedgerWarItem.GetAttackersComposition]"
						blockoverride "mirror" {
							mirror = horizontal
						}
						blockoverride "progress" {
							mirror = horizontal
						}
					}
				}
			}
		}

		# war score
		widget = {
			size = { 50 0 }
			layoutpolicy_vertical = expanding

			block "total_strength" {
				text_single = {
					size = { 100% 100% }
					autoresize = no
					align = center|nobaseline

					text = "[War.GetWarScore|+=0]"
					tooltip = "[War.GetWarScoreTooltip]"
					alwaystransparent = yes

					default_format = "#bold"
					format_override = { zero_value medium } # so 0 isn't so blidingly bright
				}
			}
		}

		widget = {
			size = { 130 0 }
			layoutpolicy_vertical = expanding

			block "defender_strength" {
				datacontext = "[War.GetActiveCasusBelli.GetDefender]"

				hbox = {
					righttoleft = yes
					spacing = 5
					expand = {}
					coa_realm_tiny = {}

					hbox_soldiers_and_quality_ledger = {
						datacontext = "[LedgerWarItem.GetDefendersComposition]"
						righttoleft = yes
						blockoverride "strength" {
							align = nobaseline
						}
					}
				}
			}
		}

		widget = {
			size = { 70 0 }
			layoutpolicy_vertical = expanding

			block "no_sort" {
				flow_war_ledger_participants = {}
			}
		}

		expand = { }

		widget_ledger_war_casualties = {
			block "date" {
				datacontext = "[War.GetDefenders]"
				datacontext = "[War.GetActiveCasusBelli.GetDefender]"
			}
			blockoverride "align" {
				align = nobaseline|right
			}
		}
	}

	type flow_war_ledger_participants = flowcontainer {
		spacing = 5
		ignoreinvisible = yes

		flowcontainer = {
			block "datamodel" {
				visible = "[DataModelHasItems(LedgerWarItem.GetDefendersParticipantItems)]"
				datamodel = "[DataModelFirst(LedgerWarItem.GetDefendersParticipantItems, Min_int32('(int32)1', GetDataModelSize(LedgerWarItem.GetDefendersParticipantItems)))]"
			}
			item = {
				widget = {
					datacontext = "[WarParticipantItem.GetCharacter]"
					size = { 25 40 }
					coa_realm_tiny = {
						parentanchor = center
						scale = 0.8
					}
				}
			}
		}

		text_single = {
			default_format = "#low"
			margin_top = 5
			block "text" {
				visible = "[GreaterThan_int32(GetDataModelSize(LedgerWarItem.GetDefendersParticipantItems), '(int32)1')]"
				raw_text = "+[Subtract_int32(GetDataModelSize(LedgerWarItem.GetDefendersParticipantItems), '(int32)1')]"
			}
		}
	}

	type widget_ledger_war_casualties = widget {
		size = { 75 @height }

		block "no_sort" {
			hbox = {
				margin = { 5 0 }
				block "right" {}
				expand = {}
				spacing = 3
				alpha = "[Select_float( NotZero(Add_int32(Add_int32(WarSide.GetCharactersLost, WarSide.GetBattleLosses), WarSide.GetAttritionLosses)) , '(float)0.9', '(float)0.4' )]"
				
				tooltip = "LEDGER_WAR_LOSSES"
				
				text_single = {
					text = "[Add_int32(WarSide.GetCharactersLost, Add_int32(WarSide.GetBattleLosses, WarSide.GetAttritionLosses))|*1]"
					max_width = 38
					block "align" {
						align = nobaseline
					}
				}
				
				icon_flat_standard_ash = {
					texture = "gfx/interface/icons/flat_icons/prison_execute.dds"
					size = { 20 20 }
					alpha = 0.7
				}
			}
		}
	}

	type hbox_soldiers_and_quality_ledger = hbox {
		tooltip = "[ArmyComposition.GetArmyCompositionTooltip]"
		spacing = 3
		margin = { 5 0 }

		icon = {
			name = "icon_soldier"
			texture = "gfx/interface/icons/icon_soldier.dds"
			size = { 30 30 }
			block "mirror" {}
		}

		vbox = {
			text_single = {
				layoutpolicy_horizontal = expanding
				size = { 45 20 }
				autoresize = no
				name = "strength"
				text = "[ArmyComposition.GetCurrentNumberOfSoldiers|*1]"
				block "strength" {
					align = nobaseline|right
					margin_left = 5
				}
				default_format = "#high"
				alpha = 0.8 # it feels too bright
				margin = { 2 0 }
			}

			progressbar_standard = {
				name = "soldiers_max"
				block "progress" {}

				block "spacing"
				{
					size = { 45 8 }
				}

				min = 0
				max = "[Max_float(IntToFloat(ArmyComposition.GetMaxNumberOfSoldiers), '(float)1')]"
				value = "[IntToFloat(ArmyComposition.GetCurrentNumberOfSoldiers)]"
			}
		}

		army_quality_icon = {
			block "army_quality" {
				visible = no
			}
			tooltip_visible = no
		}
	}

	### artifact

	type item_ledger_artifact = widget {
		datacontext = "[LedgerArtifactItem.GetArtifact]"
		size = { @widget @height }
		visible = "[Artifact.IsValid]"

		state = {
			name = _mouse_hierarchy_enter
			on_finish = "[PdxGuiWidget.FindChild('button_favorite').TriggerAnimation('hover_enter')]"
		}

		state = {
			name = _mouse_hierarchy_leave
			on_finish = "[PdxGuiWidget.FindChild('button_favorite').TriggerAnimation('hover_leave')]"
		}

		button_standard = {
			size = { 100% 102% } # to make it thinner
			alwaystransparent = yes
			visible = "[Artifact.IsUnique]"
			alpha = 0.5
		}

		button = {
			size = { 100% 100% }
			alwaystransparent = yes
			texture = "gfx/interface/colors/grey.dds"
			alpha = 0.2

			background = {
				texture = "gfx/interface/colors/white.dds"
				tintcolor = "[Artifact.GetRarityColor]"
				alpha = 0
			}
		}

		divider_light = {
			size = { 100% 2 }
		}

		button_standard_hover = {
			inherit_visual_state = no
			size = { 100% 100% }
			onclick = "[DefaultOnCharacterClick(Artifact.GetOwner.GetID)]"
			onclick = "[DefaultOnCharacterClick(Artifact.GetOwner.GetID)]"
			onclick = "[OpenGameViewData('artifact_details', Artifact.GetID)]"
		}

		hbox_ledger_artifact_stats = {
			background = {
				texture = "gfx/interface/icons/artifact/artifact_bg.dds"
				frame = "[Artifact.GetIconFrame]"
				framesize = { 240 240 }
				fittype = centercrop
				margin = { 120 0 }
				alpha = 0.1
			}
		}
	}

	type hbox_ledger_artifact_stats = hbox {
		spacing = 5
		margin = { 5 0 }
		margin_left = 3
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = expanding

		widget = {
			size = { 40 0 }
			layoutpolicy_vertical = expanding

			block "no_sort" {
				icon = {
					size = { @height @height }

					icon = {
						name = "rarity_icon"
						size = { 100% 100% }
						parentanchor = top
						alwaystransparent = yes

						texture = "gfx/interface/icons/artifact/artifact_bg.dds"
						frame = "[Artifact.GetIconFrame]"
						framesize = { 240 240 }
						alpha = 0.7
					}

					icon = {
						size = { 100% 100% }
						# size = { @num3 30 }

						texture = "[Artifact.GetIcon]"
						frame = "[Artifact.GetIconFrame]"
						framesize = { 240 240 }

						tooltipwidget = {
							artifact_tooltip = {}
						}
					}
				}
			}
		}

		widget = {
			size = { 30 @height }

			block "rarity" {
				text_ledger_c = {
					size = { 100% 100% }
					text = "[Artifact.Custom('artifact_rarity_ledger')]"
					fonttintcolor = "[Artifact.GetRarityColor]"
					default_format = "#z"
					tooltip = "[Artifact.GetRarityAndType]"
				}
			}
		}

		# name
		widget = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			block "no_sort" {
				text_ledger = {
					size = { 100% 100% }
					raw_text = "[AddTextIf(Artifact.IsUnique, '#clickable ')][Artifact.GetNameNoTooltip]"
				}
			}
		}

		# kills and claimants
		hbox = {
			spacing = 5
			
			hbox = {
				block "no_sort" {
					
					hbox = {
						visible = "[DataModelHasItems( Artifact.GetKills )]"
						spacing = 5
						
						tooltip = "OPEN_ARTIFACT_KILL_LIST_TOOLTIP"
						
						text_single = {
							text = "[GetDataModelSize(Artifact.GetKills)]"
							align = nobaseline
						}
						
						button_kill_list = {
							onclick = "[ToggleGameViewData( 'artifact_kill_list', Artifact.GetID  )]"
							size = { 25 25 }
						}
					}

					hbox = {
						visible = "[Artifact.GetOwner.IsLocalPlayer]"
						
						button_round = {
							name = "reforge"
							size = { 30 30 }
							
							button_icon_highlight = {
								parentanchor = center
								size = { 20 20 }
								texture = "gfx/interface/icons/flat_icons/reforge.dds"
							}
							
							onclick = "[ToggleGameViewData( 'reforge_artifact', Artifact.GetID )]"
							
							tooltipwidget = {
								container = {
									using = DefaultTooltipBackground
									
									flowcontainer = {
										ignoreinvisible = yes
										direction = vertical
										margin = { 20 15 }
										spacing = 15
										margin_bottom = 10
										
										text_single = {
											text = "[Artifact.GetReforgeOrRepairTooltip( Artifact.GetOwner.Self )]"
										}
										
										widget = {
											size = { 220 30 }
											scissor = yes
											background = {
												using = Background_Area_Border
												margin = { 15 5 }
											}
											
											hbox_artifact_durability = {}
										}
									}
								}
							}
							visible = "[Artifact.CanReforgeOrRepair( Artifact.GetOwner.Self )]"
							
							icon = {
								name = "selection_glow"
								visible = "[Artifact.IsDurabilityLow]"
								parentanchor = center
								size = { 35 35 }
								
								alpha = 0.5
								
								state = {
									trigger_on_create = yes
									
									name = max_glow
									next = min_glow
									duration = 1
									using = Animation_Curve_Default
									alpha = 0.5
								}
								
								state = {
									name = min_glow
									next = max_glow
									duration = 1.6
									using = Animation_Curve_Default
									alpha = 0.3
								}
								
								background = {
									texture = "gfx/interface/component_masks/mask_fade_circle.dds"
									tintcolor = { 1 0.8 0.6 0.5 }
								}
							}
						}
					}
	
					hbox = {
						visible = "[Artifact.GetOwner.IsPlayerInteractionWithTargetArtifactValid( 'destroy_artifact_interaction', Artifact.Self )]"
	
						button_round = {
							name = "destroy"
							size = { 30 30 }
							
							button_icon_highlight = {
								parentanchor = center
								size = { 20 20 }
								texture = "gfx/interface/icons/flat_icons/destroy_artifact.dds"
							}
							
							visible = "[Artifact.GetOwner.IsPlayerInteractionShown( 'destroy_artifact_interaction' )]"
							enabled = "[Artifact.GetOwner.IsPlayerInteractionWithTargetArtifactValid( 'destroy_artifact_interaction', Artifact.Self )]"
							onclick = "[Artifact.GetOwner.OpenPlayerInteractionWithTargetArtifact( 'destroy_artifact_interaction', Artifact.Self )]"
							tooltip = "[Artifact.GetOwner.GetPlayerInteractionWithTargetArtifactTooltip( 'destroy_artifact_interaction', Artifact.Self )]"
						}
					}
	
					hbox = {
						visible = "[And( Not( Artifact.GetOwner.IsLocalPlayer ), Artifact.HasClaim( GetPlayer ) )]"
	
						button_round = {
							name = "steal"
							size = { 30 30 }
							
							button_icon_highlight = {
								parentanchor = center
								size = { 25 25 }
								texture = "gfx/interface/icons/flat_icons/scheme.dds"
							}
							
							enabled = "[Artifact.GetOwner.IsPlayerInteractionValid('start_stealing_back_artifact')]"
							onclick = "[Artifact.GetOwner.OpenPlayerInteraction('start_stealing_back_artifact')]"
							tooltip = "[Artifact.GetOwner.GetPlayerInteractionTooltip( 'start_stealing_back_artifact' )]"
						}
						
						button_round = {
							name = "declare_war"
							size = { 30 30 }
							
							button_icon_highlight = {
								size = { 25 25 }
								parentanchor = center
								texture = "gfx/interface/icons/flat_icons/declare_war.dds"
							}
							
							enabled = "[Artifact.GetOwner.IsPlayerInteractionValid('declare_war_interaction')]"
							onclick = "[Artifact.GetOwner.OpenPlayerInteraction('declare_war_interaction')]"
							tooltip = "[Artifact.GetOwner.GetPlayerInteractionTooltip('declare_war_interaction')]"
						}
						
						button_round = {
							name = "duel"
							size = { 30 30 }
							
							button_icon_highlight = {
								parentanchor = center
								size = { 25 25 }
								texture = "gfx/interface/icons/flat_icons/duel.dds"
							}
							
							enabled = "[Artifact.GetOwner.IsPlayerInteractionValid('challenge_for_artifact_interaction')]"
							onclick = "[Artifact.GetOwner.OpenPlayerInteraction('challenge_for_artifact_interaction')]"
							tooltip = "[Artifact.GetOwner.GetPlayerInteractionTooltip('challenge_for_artifact_interaction')]"
						}
					}
				}
			}

			widget = {
				size = { 105 @height }

				hbox = {
					layoutpolicy_horizontal = expanding
					block "claimants" {
						hbox = {
							ignoreinvisible = no
							widget = {
								size = { 30 @height }
								visible = "[DataModelHasItems(Artifact.GetPersonalClaimants)]"

								text_ledger_c = {
									size = { 100% 100% }
									default_format = "#low"
									tooltip = "LEDGER_ARTIFACTS_CLAIMANTS"
									text = "[GetDataModelSize(Artifact.GetPersonalClaimants)]"
								}
							}
						}

						hbox = {
							visible = "[DataModelHasItems(Artifact.GetHouseClaimants)]"
							widget = {
								size = { 40 @height }

								widget = {
									size = { 100% 100% }
									# index errors if we put it in the same widget with the visible statement
									parentanchor = center
									coa_house_tiny = {
										scale = 0.7
										position = { 2 2 }

										datacontext_from_model = {
											datamodel = "[Artifact.GetHouseClaimants]"
											index = 0
										}
									}
								}
							}

							widget = {
								size = { 30 @height }

								text_ledger_c = {
									tooltip = "LEDGER_ARTIFACTS_HOUSE_CLAIMANTS"
									default_format = "#low"
									size = { 100% 100% }
									text = "[GetDataModelSize(Artifact.GetHouseClaimants)]"
								}
							}
						}
					}
				}
			}

			widget = {
				size = { @num5 40 }

				block "age" {
					text_ledger_c = {
						size = { 100% 100% }
						default_format = "#low;emp"
						visible = "[LessThan_int32(Artifact.GetAge, GetCurrentDate.GetYear)]"
						text = "[Artifact.GetAge]"
						tooltip = "LEDGER_ARTIFACT_AGE"
					}
				}
			}

			star_button = {
				size = { 25 40 }
			}
		}

		# inherited with title
		hbox = {
			layoutpolicy_vertical = expanding
			widget = {
				size = { 25 30 }

				block "no_sort" {
					# this shows that it's a house artifact, inherited with the title
					icon_flat_standard = {
						size = { 20 20 }
						using = icon_title_ledger
						visible = "[And(Title.IsValid, ObjectsEqual(Title.Self, Artifact.GetOwner.GetPrimaryTitle))]"
						parentanchor = vcenter
						alpha = 0.75
						datacontext = "[Artifact.GetAssociatedTitle]"

						tooltipwidget = {
							artifact_tooltip = {}
						}
					}
				}
			}

			widget = {
				size = { 25 30 }
				layoutpolicy_vertical = expanding

				block "no_sort" {
					widget = {
						size = { 100% 100% }
						visible = "[Artifact.GetOwner.HasLandedTitles]"

						coa_realm_tiny = {
							visible = "[Artifact.GetOwner.IsValid]"
							blockoverride "government_datacontext"
							{
								datacontext = "[Artifact.GetOwner.GetGovernment]"
							}
							datacontext = "[Artifact.GetOwner]"
							parentanchor = center
							scale = 0.7
							position = { 0 3 }
						}
					}
				}
			}
		}

		# owner
		widget = {
			size = { 36 40 }
			layoutpolicy_vertical = expanding
			scissor = yes

			block "no_sort" {
				datacontext = "[Artifact.GetOwner]"
				portrait_ledger_tiny = {
					position = { 0 -3 }
					alwaystransparent = yes
					size = { 100% 100% }
				}
			}
		}
	}

	### rich

	type item_ledger_char_rich = widget_ledger_item {
		datacontext = "[LedgerCharacterItem.GetCharacter]"
		size = { @widget 64 }
		visible = "[Character.IsValid]"

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			portrait_head_tiny = {}

			vbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding

				widget_ledger_char_header = {
					layoutpolicy_horizontal = expanding
					blockoverride "stewardship" {}
				}

				hbox_char_rich_stats = {
					layoutpolicy_horizontal = expanding
				}

				expand = {}
			}
		}
	}

	type hbox_char_rich_stats = hbox {
		spacing = 5
		layoutpolicy_horizontal = expanding

		block "pre_sort" {}

		widget = {
			size = { 135 40 }

			block "no_sort" {
				hbox = {
					margin_left = 2

					widget = {
						size = { 30 30 }
						datacontext = "[Character.GetTraitFromGroup( GetTraitGroup('education_stewardship') )]"
						visible = "[Character.HasTrait( Trait.Self )]"
						icon_trait = {
							blockoverride "icon_size" {
								size = { 30 30 }
							}
						}
					}

					widget = {
						size = { 90 40 }
						blockoverride "trait_glow" {}
						overlappingitembox = {
							parentanchor = vcenter
							size = { 100% 30 }
							datamodel = "[TraitArrays.GetPersonalityTraits]"
							datacontext = "[LedgerCharacterItem.GetTraitArrays]"

							item = {
								icon_trait = {
									blockoverride "icon_size" {
										size = { 30 30 }
									}
								}
							}
						}
					}

					expand = {}
				}
			}
		}

		hbox = {
			block "no_sort" {
				tooltip = "[Character.GetGoldTooltipWithBalance]"
				tooltip_visible = "[Character.IsAlive]"
			}
			spacing = 5
			widget = {
				size = { @num6 @height }
				block "gold" {
					alpha = "[Select_float( EqualTo_CFixedPoint(Character.GetGold, '(CFixedPoint)0'), '(float)0.5', '(float)1' )]"
					text_ledger_full = {
						visible = "[Character.IsAlive]"
						text = "[Character.GetGold|+0]"
						format_override = { positive_value clickable }
					}
				}
			}

			widget = {
				size = { @num6 @height }
				block "income" {
					text_ledger_full = {
						visible = "[Not(EqualTo_CFixedPoint(Character.GetBalance, '(CFixedPoint)0'))]"
						text = "[Character.GetBalance|=+1]"
						using = tooltip_es
						tooltipwidget = {
							container_ledger_tooltip = {
								blockoverride "top_tt" {
									text_single = {
										text = "[Character.GetGoldTooltipWithBalance]"
									}
								}
								blockoverride "tooltipwidget" {
									text_multi = {
										max_width = 340
										autoresize = yes
										alwaystransparent = yes
										text = "[Character.GetBalanceBreakdown]"
									}
								}
							}
						}
					}
				}
			}
		}

		widget = {
			size = { @num5 @height }
			block "realm_size" {
				text_ledger_center = {
					tooltip = "realm_size"
					visible = "[GreaterThan_int32(Character.RealmSize, '(int32)0')]"
					text = "[Character.RealmSize]"
				}
			}
		}

		widget = {
			size = { @num5 @height }
			block "buildings" {
				text_ledger_center = {
					visible = "[GreaterThan_int32(Character.RealmSize, '(int32)0')]"
					tooltip = "TT_BUILDINGS_LEDGER"
					text = "[Character.GetNumberOfBuildings]"
				}
			}
		}

		widget = {
			size = { @num5 @height }
			block "development" {
				text_ledger_center = {
					tooltip = "TT_AVG_DEVELOPMENT"
					visible = "[GreaterThan_int32(Character.RealmSize, '(int32)0')]"
					text = "[Character.GetAverageDevelopment|0]"
				}
			}
		}

		widget = {
			size = { 90 @height }
			block "treasury" {
				hbox = {
					layoutpolicy_horizontal = expanding
					tooltip = "[Character.GetTreasuryTooltipWithBalance]"
					visible = "[Character.HasTreasury]"
					text_ledger = {
						size = { @num5 20 }
						text = "[Character.GetTreasury|0]"
						default_format = "#clickable"
					}

					text_ledger = {
						size = { @num5 20 }
						text = "[Character.GetTreasuryBalance|=+1]"
					}

					expand = {}
				}
			}
		}
	}

