	type button_basic_ledger_item = button_standard {
		block "ledger_click" {}
		button_ignore = none

		hbox = {
			layoutpolicy_horizontal = expanding
			spacing = 10
			margin = { 10 0 }

			text_single = {
				align = nobaseline
				block "ledger_text" {}
			}

			expand = {}

			button = {
				size = { 20 30 }
				alpha = 0

				state = {
					name = _mouse_hierarchy_enter
					alpha = 1
				}

				state = {
					name = _mouse_hierarchy_leave
					alpha = 0
				}

				button_pin = {
					block "ledger_pin" {}
				}

				button_close = {
					block "down_ledger_pin" {
						visible = yes
					}
					block "ledger_pin" {}
				}
			}

			text_single = {
				text = "[Add_int32(PdxGuiWidget.GetIndexInDataModel, '(int32)1')]"
				min_width = 25
				default_format = "#low"
				align = nobaseline|right
			}
		}
	}

	type widget_ledger_sort_dropdown = widget {
		size = { 100 40 }
		block "sort_buttons" {}
	}

	# sorting
	type hbox_ledger_sort_buttons = hbox {
		block "margins" {
			margin = { 10 0 }
			spacing = 5
		}

		hbox = {
			name = "sort_buttons"
			spacing = 5

			righttoleft = yes

			block "hide_ledger_sort" {}

			block "sort_dropdown" {
				dropdown_sort_ledger = {
					visible = "[DataModelHasItems(LedgerWindow.GetOrderByOptions)]"
					block "sort_dropdown_model" {
						datamodel = "[LedgerWindow.GetOrderByOptions]"
						onselectionchanged = "[LedgerWindow.OnOrderBySelectionChanged]"
						selectedindex = "[LedgerWindow.GetOrderBySelectedIndex]"
					}
					blockoverride "text_button_drop" {
						text = "DROP_SORT_LEDGER"
						tooltip = "[Localize(Concatenate(OrderLedgerOption.GetLocalizationKey, '_tt'))]"
						tooltip_visible = "[StringIsEmpty(Localize(OrderLedgerOption.GetLocalizationKey))]"
						format_override = { e clickable }
					}
				}
			}
		}
	}

	type dropdown_sort_ledger = dropDown {
		name = "sort_options"
		block "size_button_drop" {
			size = { 300 32 }
		}

		active_item = {
			widget = {
				size = { 100% 100% }

				button_standard_hover = {
					size = { 100% 100% }
					button_trigger = none

					state = {
						name = _mouse_hierarchy_enter
						on_finish = "[GetVariableSystem.Set('ledger_drop', 'yes')]"
						on_finish = "[GetVariableSystem.Set('ledger_drop_shown', 'yes')]"
					}

					state = {
						name = _mouse_hierarchy_leave
						on_finish = "[GetVariableSystem.Clear('ledger_drop')]"
					}

					button_drop = {
						mirror = horizontal
						name = drop
						visible = "[GetVariableSystem.Exists('ledger_drop')]"
						background = {
							using = Background_Area_Border
							margin = { -3 -3 }
						}
					}
					
					button_standard_list = {
						size = { 100% 100% }
						visible = "[Not(GetVariableSystem.Exists('ledger_drop_shown'))]"
						button_drop = {
							mirror = horizontal
						}
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						margin_right = 30

						text_single = {
							layoutpolicy_horizontal = expanding
							alwaystransparent = yes
							margin_right = 10
							margin_left = 20
							max_width = 280
							
							align = nobaseline|right
							autoresize = no
							tooltip = "[Localize(Concatenate(OrderLedgerOption.GetLocalizationKey, '_tt'))]"
							tooltip_visible = "[StringIsEmpty(Localize(OrderLedgerOption.GetLocalizationKey))]"
							
							block "active_text_button_drop" {
								using = Font_Type_Flavor
								# fontsize = 16 # for this font this feels better
								text = "ACTIVE_SORTING_LEDGER"
							}
						}
					}
				}

				button_standard = {
					name = "sort_order"
					size = { 25 25 }
					parentanchor = right|vcenter
					position = { -2 0 }

					onclick = "[LedgerWindow.RevertSortOrder]"
					tooltip = "LEDGER_SORT_BY"
					using = tooltip_nw

					button_icon = {
						alwaystransparent = yes
						parentanchor = center
						size = { 25 25 }
						texture = "gfx/interface/icons/flat_icons/sort_icon.dds"
						framesize = { 66 66 }

						frame = "[BoolTo1And2(LedgerWindow.GetSortOrder)]"

						blockoverride "button_frames" {
							effectname = "NoHighlight"
						}
					}
				}
			}
		}

		item = {
			widget = {
				alwaystransparent = no
				block "size_dropdown" {
					size = { @drop 33 }
				}

				button_normal = {
					size = { 100% 30 }
					button_trigger = none
					gfxtype = framedbuttongfx
					effectname = "NoHighlight"
					shaderfile = "gfx/FX/pdxgui_pushbutton.shader"
					upframe = 1
					overframe = 2
					downframe = 3
					disableframe = 1
					texture = "gfx/interface/buttons/button_interaction_menu.dds"
					framesize = { 317 30 }
				}

				button_dropdown = {
					block "size_dropdown" {
						size = { @drop 33 }
					}
						
					text_single = {
						size = { 100% 100% }
						margin_right = 35
						autoresize = no
						align = nobaseline|right
						alwaystransparent = yes
						default_format = "#clickable"
						tooltip_visible = no
						block "text_button_drop" {
							text = "[CharacterListSortItem.GetName]"
						}
					}

				}
			}
		}

		list = {
			scrollarea = {
				position = { 5 33 }
				maximumsize = { @drop @dropheight }
				autoresizescrollarea = yes
				scrollbarpolicy_horizontal = always_off

				using = Background_DropDown

				scrollwidget = {
					dynamicgridbox = {
						alwaystransparent = no
					}
				}

				scrollbar_vertical = {
					using = Scrollbar_Vertical
				}
			}
		}
	}

	type window_ledger_filters = window {
		name = "ledger_filter_window"
		visible_at_creation = no
		visible = "[GetVariableSystem.Exists('ledger_filters')]"
		parentanchor = top|right
		position = { -720 60 }
		size = { 420 700 }
		focuspolicy = click

		allow_outside = yes
		
		state = {
			name = auto_close
			trigger_when = "[Or(GetVariableSystem.HasValue('ledger_tab', 'houses'), GetVariableSystem.HasValue('ledger_tab', 'killers'))]"
			on_finish = "[GetVariableSystem.Clear('ledger_filters')]"
		}

		using = Window_Movable
		using = Window_Background_Subwindow

		state = {
			name = _show
			using = Animation_FadeIn_Quick
		}

		state = {
			name = _hide
			using = Animation_FadeOut_Quick
		}

		vbox = {
			margin = { 4 4 }

			spacing = 10

			header_pattern = {
				layoutpolicy_horizontal = expanding

				blockoverride "header_text" {
					text = "CHARACTER_LIST_FILTERS"
				}
				blockoverride "button_close" {
					onclick = "[GetVariableSystem.Clear('ledger_filters')]"
				}
			}

			scrollbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding

				blockoverride "scrollbox_content" {
					vbox = {
						layoutpolicy_horizontal = expanding
						visible = "[GetVariableSystem.HasValue('ledger_tab', 'ongoing_wars')]"

						ledger_filter_item = {
							layoutpolicy_horizontal = expanding
							datacontext = "[LedgerWindow.GetFilter('type')]"
						}

						ledger_filter_item = {
							layoutpolicy_horizontal = expanding
							datacontext = "[LedgerWindow.GetFilter('relation')]"
						}
					}

					vbox = {
						visible = "[GetVariableSystem.HasValue('ledger_tab', 'artifacts')]"
						layoutpolicy_horizontal = expanding

						ledger_filter_item = {
							layoutpolicy_horizontal = expanding
							datacontext = "[LedgerWindow.GetFilter('rarity')]"
