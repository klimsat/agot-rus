window = {
	name = "ledger_window"
	widgetid = "ledger_window"
	parentanchor = top|right
	position = { -50 65 }
	allow_outside = yes
	layer = middle
	
	size = { 745 89% }

	state = {
		name = _show
		using = Animation_FadeIn_Quick
		# on_finish = "[GetVariableSystem.Set('mapmode_before_ledger', GetCurrentMapMode.GetKey)]" #TODO mapmodes later
	}

	state = {
		name = _hide
		using = Animation_FadeOut_Quick
		# on_finish = "[SetMapMode(GetVariableSystem.Get('mapmode_before_ledger'))]"
	}
	#bookmarks
	margin_widget = {
		size = { 100 100% }
		allow_outside = yes
		margin_top = 154
		margin_bottom = 60
		position = { 45 0 }
		widgetanchor = right

		scrollarea = {
			size = { 100% 100% }
			alwaystransparent = yes

			scrollbarpolicy_horizontal = always_off

			scrollbar_vertical = {
				using = Scrollbar_Vertical
			}

			scrollwidget = {
				flow_ledger_bookmarks = {}
			}
		}
	}

	widget = {
		using = Window_Background
		using = Window_Decoration_Spike
		size = { 100% 100% }

		allow_outside = yes

		vbox = {
			using = Window_Margins

			header_pattern = {
				layoutpolicy_horizontal = expanding

				blockoverride "header_text" {
					text = "LEDGER_WINDOW_TITLE"
					max_width = 560
				}

				blockoverride "button_close" {
					onclick = "[CloseGameView('ledger')]"
				}

				# mapmodes
				container = {
					ignoreinvisible = yes
					position = { 5 5 }
					visible = no# "[CanChangeMapMode]" TODO set up mapmodes and auto-switch

					state = {
						name = "remove_title_mapmode"
						trigger_when = "[Not(GetVariableSystem.HasValue('ledger_tab', 'titles'))]"
						on_finish = "[SetMapMode(GetVariableSystem.Get('mapmode_before_ledger'))]"
					}


					container = {
						visible = "[GetVariableSystem.HasValue('ledger_tab', 'titles')]"

						icon_button_mapmode = {
							visible = "[GetVariableSystem.HasValue('ledger_titles_tab', 'duchies')]"
							name = "map_mode_duchies_button"

							size = { 38 38 }

							blockoverride "mm_datacontext" {
								datacontext = "[GetMapMode('dejure_duchies')]"
							}

							blockoverride "mm_button" {
								shortcut = "map_mode_9"
							}

							blockoverride "button_bg_color" {
								color = { 0.1 0.14 0.1 1 } #TODO template
							}
						}

						icon_button_mapmode = {
							visible = "[GetVariableSystem.HasValue('ledger_titles_tab', 'kingdoms')]"
							name = "map_mode_kingdoms_button"
							size = { 38 38 }

							blockoverride "mm_datacontext" {
								datacontext = "[GetMapMode('dejure_kingdoms')]"
							}

							blockoverride "mm_button" {
								shortcut = "map_mode_10"
							}

							blockoverride "button_bg_color" {
								color = { 0.18 0.1 0.1 1 }
							}
						}

						icon_button_mapmode = {
							visible = "[GetVariableSystem.HasValue('ledger_titles_tab', 'empires')]"
							name = "map_mode_empires_button"
							size = { 38 38 }

							blockoverride "mm_datacontext" {
								datacontext = "[GetMapMode('dejure_empires')]"
							}

							blockoverride "mm_button" {
								shortcut = "map_mode_11"
							}

							blockoverride "button_bg_color" {
								color = { 0.12 0.12 0.18 1 }
							}
						}

						icon_button_mapmode = {
							visible = "[GetVariableSystem.HasValue('ledger_titles_tab', 'hegemonies')]"
							name = "map_mode_hegemonies_button"
							size = { 38 38 }

							blockoverride "mm_datacontext" {
								datacontext = "[GetMapMode('dejure_hegemonies')]"
							}

							blockoverride "button_bg_color" {
								color = { 0.12 0.12 0.18 1 }
							}
						}
					}
				}
			}

			# each vbox_ledger has a sorting line, above the list
			# the line uses the same widget as the each item, with the same "cells" inside it
			# this way we can change the spacing in the item and on the sorting line at the same time
			# first blockoverride replaces

			# wars ledger
			vbox_ledger = {
				visible = "[GetVariableSystem.HasValue('ledger_tab', 'ongoing_wars')]"

				blockoverride "background_art" {}

				# datamodels
				blockoverride "ledger_datamodel" {
					datamodel = "[LedgerWindow.GetWars]"
				}
				blockoverride "pinned_ledger_datamodel" {
					datamodel = "[LedgerWindow.GetWarsPinned]"
				}
				blockoverride "expand_pinned_visibility" {
					visible = "[GreaterThanOrEqualTo_int32( GetDataModelSize(LedgerWindow.GetWarsPinned), '(int32)1' )]"
				}
				blockoverride "pinned_ledger_scrollbox_visibility" {
					visible = "[GreaterThanOrEqualTo_int32( GetDataModelSize(LedgerWindow.GetWarsPinned), '(int32)4' )]"
				}
				blockoverride "pinned_ledger_vbox_visibility" {
					visible = "[LessThan_int32( GetDataModelSize(LedgerWindow.GetWarsPinned), '(int32)4' )]"
				}
				blockoverride "scrollbox_empty_visibility" {
					visible = "[IsDataModelEmpty(LedgerWindow.GetWars)]"
					text = "NO_LEDGER_ITEMS"
				}
				blockoverride "ledger_item" {
					item_ledger_war = {
						datacontext = "[LedgerWarItem.GetWar]"
					}
				}
				blockoverride "ledger_text" {
					text = "[LedgerWarItem.GetWar.GetName]"
				}
				blockoverride "resize" {}

				blockoverride "addrow_legder" {
					addrow = 76
				}
				blockoverride "ledger_count" {
					text = "[GetDataModelSize(LedgerWindow.GetWars)]"
				}

				# pins
				blockoverride "ledger_pin" {
					onclick = "[LedgerWindow.ToggleWarPin(LedgerWarItem.GetWar)]"
				}
				blockoverride "down_ledger_pin" {
					visible = "[LedgerWindow.IsWarPinned(LedgerWarItem.GetWar)]"
				}

				blockoverride "podium" {
					visible = no
				}
				blockoverride "podium_tt" {
					tooltip_visible = no
					enabled = no
				}
				blockoverride "sorting_line" {
					datacontext = "[GetNullWar]"
					
					hbox_war_stats = {
						layoutpolicy_horizontal = expanding
						blockoverride "sort_losses" {
							button_sort_ledger_short = {
								name = "total_casualties" # the name is referened by the type for sorting! don't change
								blockoverride "icon" {
									texture = "gfx/interface/icons/flat_icons/prison_execute.dds"
								}
							}
						}
						
						blockoverride "attacker_strength" {
							hbox_sort_ledger_short = {
								name = "attacker_strength" # same here
								blockoverride "icon" {
									texture = "gfx/interface/icons/flat_icons/attacking_troops.dds"
								}
							}
						}

						blockoverride "defender_strength" {
							hbox_sort_ledger_short = {
								name = "defender_strength"
								blockoverride "icon" {
									texture = "gfx/interface/icons/flat_icons/title_troops.dds"
								}
							}
						}

						blockoverride "total_strength" {
							hbox_sort_ledger_short = {
								name = "total_strength"
								blockoverride "icon" {
									using = icon_levies_ledger
								}
							}
						}

						blockoverride "date" {
							hbox_sort_ledger_short = {
								name = "date"
								blockoverride "icon" {
									using = icon_time_ledger
								}
							}
						}

					}
				}
			}

			# artifacts ledger
			vbox_ledger = {
				visible = "[GetVariableSystem.HasValue('ledger_tab', 'artifacts')]"

				blockoverride "background_art" {
					texture = "gfx/interface/illustrations/decisions/decision_smith.dds"
				}

				# datamodels
				blockoverride "ledger_datamodel" {
					datamodel = "[LedgerWindow.GetArtifacts]"
				}
				blockoverride "pinned_ledger_datamodel" {
					datamodel = "[LedgerWindow.GetArtifactsPinned]"
				}
				blockoverride "expand_pinned_visibility" {
					visible = "[GreaterThanOrEqualTo_int32( GetDataModelSize(LedgerWindow.GetArtifactsPinned), '(int32)1' )]"
				}
				blockoverride "pinned_ledger_scrollbox_visibility" {
					visible = "[GreaterThanOrEqualTo_int32( GetDataModelSize(LedgerWindow.GetArtifactsPinned), '(int32)7' )]"
				}
				blockoverride "pinned_ledger_vbox_visibility" {
					visible = "[LessThan_int32( GetDataModelSize(LedgerWindow.GetArtifactsPinned), '(int32)7' )]"
				}
				blockoverride "podium_datamodel" {
					datamodel = "[LedgerWindow.GetArtifactsPodium]"
				}
				
				blockoverride "podium_1" {
					visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetArtifactsPodium), '(int32)0')]"
				}
				blockoverride "podium_2" {
					visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetArtifactsPodium), '(int32)1')]"
				}
				blockoverride "podium_3" {
					visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetArtifactsPodium), '(int32)2')]"
				}
				
				blockoverride "scrollbox_empty_visibility" {
					visible = "[IsDataModelEmpty(LedgerWindow.GetArtifacts)]"
					text = "NO_LEDGER_ITEMS"
				}
				blockoverride "ledger_text" {
					text = "[LedgerArtifactItem.GetArtifact.GetNameNoTooltip]"
				}

				blockoverride "ledger_item" {
					item_ledger_artifact = {}
				}

				blockoverride "ledger_count" {
					text = "[GetDataModelSize(LedgerWindow.GetArtifacts)]"
				}

				# pins
				blockoverride "ledger_pin" {
					onclick = "[LedgerWindow.ToggleArtifactPin(Artifact.Self)]"
				}
				blockoverride "down_ledger_pin" {
					visible = "[LedgerWindow.IsArtifactPinned(Artifact.Self)]"
				}

				blockoverride "ledger_podium_widget" {
					button = {
						datacontext = "[LedgerArtifactItem.GetArtifact]"
						size = { 130 130 }
						parentanchor = center
						visible = "[Artifact.IsValid]"

						texture = "gfx/interface/icons/artifact/artifact_bg.dds"
						frame = "[Artifact.GetIconFrame]"
						framesize = { 240 240 }

						icon = {
							size = { 90% 90% }
							parentanchor = center

							texture = "[Artifact.GetIcon]"
							frame = "[Artifact.GetIconFrame]"
							framesize = { 240 240 }

							tooltipwidget = {
								artifact_tooltip = {}
							}
						}

						onclick = "[DefaultOnCharacterClick(Artifact.GetOwner.GetID)]"
						onclick = "[DefaultOnCharacterClick(Artifact.GetOwner.GetID)]"
						onclick = "[OpenGameViewData('artifact_details', Artifact.GetID)]"
					}
				}

				blockoverride "sorting_line" {
					hbox_ledger_artifact_stats = {
						
						blockoverride "rarity" {
							hbox_sort_ledger_short = {
								name = "rarity"
								blockoverride "icon" {
									using = icon_rarity_ledger
								}
							}
						}

						blockoverride "claimants" {
							hbox_sort_ledger_short = {
								name = "claimants"
								blockoverride "icon" {
									using = icon_house_ledger
								}
							}
						}

						blockoverride "age" {
							hbox_sort_ledger_short = {
								name = "age"
								blockoverride "icon" {
									using = icon_time_ledger
								}
							}
						}
					}
				}
			}

			# characters
			vbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				visible = "[GetVariableSystem.HasValue('ledger_tab', 'characters')]"

				state = {
					name = default_tab
					trigger_when = "[Not(GetVariableSystem.Exists('ledger_character_tab'))]"
					on_finish = "[GetVariableSystem.Set('ledger_character_tab', 'rich')]"
				}

				# label for the podium
				blockoverride "ledger_text" {
					text = "[LedgerCharacterItem.GetCharacter.GetFirstNameNoTooltip]"
				}

				blockoverride "ledger_title" {
					text = "[Localize(Concatenate(GetVariableSystem.Get('ledger_character_tab'), '_name'))]"
				}
				blockoverride "character_bg" {
					visible = "[Character.IsRuler]"
				}

				blockoverride "tabs" {
					hbox = {
						layoutpolicy_horizontal = expanding

						button_tab = {
							layoutpolicy_horizontal = expanding
							shortcut = "ledger_subtab_1"
							text = "RICH_LEDGER_TAB"
							onclick = "[GetVariableSystem.Set('ledger_character_tab', 'rich')]"
							down = "[GetVariableSystem.HasValue('ledger_character_tab', 'rich')]"
						}

						button_tab = {
							layoutpolicy_horizontal = expanding
							shortcut = "ledger_subtab_2"
							text = "STRONG_LEDGER_TAB"
							onclick = "[GetVariableSystem.Set('ledger_character_tab', 'strong')]"
							down = "[GetVariableSystem.HasValue('ledger_character_tab', 'strong')]"
						}

						button_tab = {
							layoutpolicy_horizontal = expanding
							shortcut = "ledger_subtab_3"
							text = "FAMED_LEDGER_TAB"
							onclick = "[GetVariableSystem.Set('ledger_character_tab', 'pious')]"
							down = "[GetVariableSystem.HasValue('ledger_character_tab', 'pious')]"
						}
					}
				}

				blockoverride "ledger_podium_widget" {
					portrait_torso_podium = {
						datacontext = "[LedgerCharacterItem.GetCharacter]"
					}
				}

				blockoverride "ledger_click" {
					onclick = "[DefaultOnCharacterClick(Character.GetID)]"
				}

				# rich
				vbox_ledger = {
					visible = "[GetVariableSystem.HasValue('ledger_character_tab', 'rich')]"
					# datamodels
					blockoverride "ledger_datamodel" {
						datamodel = "[LedgerWindow.GetCharactersRich]"
					}
					blockoverride "pinned_ledger_datamodel" {
						datamodel = "[LedgerWindow.GetCharactersRichPinned]"
					}
					blockoverride "podium_datamodel" {
						datamodel = "[LedgerWindow.GetCharactersRichPodium]"
					}
					
					
					blockoverride "podium_1" {
						visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetCharactersRichPodium), '(int32)0')]"
					}
					blockoverride "podium_2" {
						visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetCharactersRichPodium), '(int32)1')]"
					}
					blockoverride "podium_3" {
						visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetCharactersRichPodium), '(int32)2')]"
					}
					
					
					blockoverride "scrollbox_empty_visibility" {
						visible = "[IsDataModelEmpty(LedgerWindow.GetCharactersRich)]"
						text = "NO_LEDGER_ITEMS"
					}
					blockoverride "expand_pinned_visibility" {
						visible = "[GreaterThanOrEqualTo_int32( GetDataModelSize(LedgerWindow.GetCharactersRichPinned), '(int32)1' )]"
					}
					blockoverride "pinned_ledger_scrollbox_visibility" {
						visible = "[GreaterThanOrEqualTo_int32( GetDataModelSize(LedgerWindow.GetCharactersRichPinned), '(int32)4' )]"
					}
					blockoverride "pinned_ledger_vbox_visibility" {
						visible = "[LessThan_int32( GetDataModelSize(LedgerWindow.GetCharactersRichPinned), '(int32)4' )]"
					}
					blockoverride "player_item" {
						visible = "[Character.IsLocalPlayer]"
					}

					blockoverride "ledger_item" {
						item_ledger_char_rich = {}
					}
					blockoverride "sorting_line" {
						widget = {
							size = { 65 30 }
							allow_outside = yes
							datacontext = "[LedgerWindow.GetFilter('ruler')]"
							
							blockoverride "text" {
								text = "LEDGER_FILTER_RULERS_ONLY"
								max_width = 170
							}
							
							button_checkbox_label = {
								position = { 5 0 }
								visible = "[LedgerListFilter.IsFilteringBy('all')]"		
								onclick = "[LedgerListFilter.SetCurrentFilter('landed_ruler')]"
								
								blockoverride "checkbox" {
									checked = "no"
								}
							}
							
							button_checkbox_label = {
								position = { 5 0 }
								visible = "[LedgerListFilter.IsFilteringBy('landed_ruler')]"		
								onclick = "[LedgerListFilter.SetCurrentFilter('all')]"
								
								blockoverride "checkbox" {
									checked = "yes"
								}
							}
						}
						
						hbox_char_rich_stats = {

							blockoverride "gold" {
								hbox_sort_ledger_short = {
									name = "gold"
									blockoverride "icon" {
										using = icon_gold_ledger
									}
								}
							}
							blockoverride "income" {
								hbox_sort_ledger_short = {
									name = "gold_balance"
									blockoverride "icon" {
										using = icon_income_ledger
									}
								}
							}
							blockoverride "strength" {
								hbox_sort_ledger_short = {
									name = "strength"
									blockoverride "icon" {
										using = icon_levies_ledger
									}
								}
							}
							blockoverride "realm_size" {
								hbox_sort_ledger_short = {
									name = "realm_size"
									blockoverride "icon" {
										using = icon_title_ledger
									}
								}
							}
							blockoverride "buildings" {
								hbox_sort_ledger_short = {
									name = "buildings"
									blockoverride "sort_tooltip" {
										tooltip = "SORT_L_BUILDINGS_REALM"
									}
									blockoverride "icon" {
										using = icon_building_ledger
									}
								}
							}
							blockoverride "development" {
								hbox_sort_ledger_short = {
									name = "average_development"
									blockoverride "sort_tooltip" {
										tooltip = "SORT_L_AVG_DEVELOPMENT_CHARACTER"
									}
									blockoverride "icon" {
										using = icon_development_ledger
									}
								}
							}
							blockoverride "treasury" {
								hbox_sort_ledger_short = {
									name = "treasury"
									#TODO check if the player has DLC allowing treasury
									blockoverride "icon" {
										using = icon_treasury_ledger
									}
								}
							}
						}
					}
					blockoverride "resize" {}

					blockoverride "addrow_legder" {
						addrow = 70
					}
					blockoverride "ledger_count" {
						text = "[GetDataModelSize(LedgerWindow.GetCharactersRich)]"
					}

					# pins
					blockoverride "ledger_pin" {
						onclick = "[LedgerWindow.ToggleRichestPin(Character.Self)]"
					}
					blockoverride "down_ledger_pin" {
						visible = "[LedgerWindow.IsRichestPinned(Character.Self)]"
					}
				}

				# strong
				vbox_ledger = {
					visible = "[GetVariableSystem.HasValue('ledger_character_tab', 'strong')]"
					# datamodels
					blockoverride "ledger_datamodel" {
						datamodel = "[LedgerWindow.GetCharactersStrong]"
					}
					blockoverride "pinned_ledger_datamodel" {
						datamodel = "[LedgerWindow.GetCharactersStrongPinned]"
					}
					blockoverride "podium_datamodel" {
						datamodel = "[LedgerWindow.GetCharactersStrongPodium]"
					}
					
					blockoverride "podium_1" {
						visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetCharactersStrongPodium), '(int32)0')]"
					}
					blockoverride "podium_2" {
						visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetCharactersStrongPodium), '(int32)1')]"
					}
					blockoverride "podium_3" {
						visible = "[GreaterThan_int32(GetDataModelSize(LedgerWindow.GetCharactersStrongPodium), '(int32)2')]"
					}					
					
					blockoverride "scrollbox_empty_visibility" {
						visible = "[IsDataModelEmpty(LedgerWindow.GetCharactersStrong)]"
						text = "NO_LEDGER_ITEMS"
					}
					blockoverride "expand_pinned_visibility" {
						visible = "[GreaterThanOrEqualTo_int32( GetDataModelSize(LedgerWindow.GetCharactersStrongPinned), '(int32)1' )]"
					}
					blockoverride "pinned_ledger_scrollbox_visibility" {
						visible = "[GreaterThanOrEqualTo_int32( GetDataModelSize(LedgerWindow.GetCharactersStrongPinned), '(int32)4' )]"
					}
					blockoverride "pinned_ledger_vbox_visibility" {
						visible = "[LessThan_int32( GetDataModelSize(LedgerWindow.GetCharactersStrongPinned), '(int32)4' )]"
					}
					blockoverride "ledger_item" {
						item_ledger_char_strong = {}
					}
					blockoverride "resize" {}

					blockoverride "addrow_legder" {
						addrow = 70
					}

					blockoverride "ledger_count" {
						text = "[GetDataModelSize(LedgerWindow.GetCharactersStrong)]"
					}

					# pins
					blockoverride "ledger_pin" {
						onclick = "[LedgerWindow.ToggleStrongestPin(Character.Self)]"
					}
					blockoverride "down_ledger_pin" {
						visible = "[LedgerWindow.IsStrongestPinned(Character.Self)]"
					}

					blockoverride "sorting_line" {
						widget = {
							size = { 65 30 } # keep the size so it doesn't push the buttons
							allow_outside = yes
							datacontext = "[LedgerWindow.GetFilter('ruler')]"
							
							blockoverride "text" {
								text = "LEDGER_FILTER_RULERS_ONLY"
								max_width = 170
							}
							
							button_checkbox_label = {
								position = { 5 0 }
								visible = "[LedgerListFilter.IsFilteringBy('all')]"		
								onclick = "[LedgerListFilter.SetCurrentFilter('landed_ruler')]"
								
								blockoverride "checkbox" {
									checked = "no"
								}
							}
							
							button_checkbox_label = {
								position = { 5 0 }
								visible = "[LedgerListFilter.IsFilteringBy('landed_ruler')]"		
								onclick = "[LedgerListFilter.SetCurrentFilter('all')]"
								
								blockoverride "checkbox" {
									checked = "yes"
								}
							}
						}
						
						hbox_ledger_char_strong = {

							blockoverride "strength" {
								hbox_sort_ledger_short = {
									name = "military_strength"
									blockoverride "icon" {
										using = icon_levies_ledger
									}
								}
							}
							blockoverride "maa" {
								hbox_sort_ledger_short = {
									name = "men_at_arms"
									blockoverride "icon" {
										using = icon_maa_ledger
									}
								}
							}
							blockoverride "knights" {
								hbox_sort_ledger_short = {
									name = "knights"
									blockoverride "icon" {
										using = icon_knights_ledger
									}
								}
							}
							blockoverride "knight_effectiveness" {
								hbox_sort_ledger_short = {
									name = "knight_effectiveness"
									blockoverride "icon" {
										using = icon_knights_effectiveness_ledger
									}
								}
							}
							blockoverride "dread" {
								hbox_sort_ledger_short = {
									name = "dread"
									blockoverride "icon" {
										using = icon_dread_ledger
									}
								}
							}
							blockoverride "prisoners" {
