									layoutpolicy_horizontal = expanding
									datacontext = "[LedgerWindow.GetFilter('personal')]"
								}
								ledger_filter_item = {
									layoutpolicy_horizontal = expanding
									datacontext = "[LedgerWindow.GetFilter('court')]"
								}
								ledger_filter_item = {
									layoutpolicy_horizontal = expanding
									visible = "[GetPlayer.IsValid]"
									datacontext = "[LedgerWindow.GetFilter('relation')]"
								}
								ledger_filter_item = {
									layoutpolicy_horizontal = expanding
									visible = "[GetPlayer.IsValid]"
