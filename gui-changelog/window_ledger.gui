						button_tab = {
							visible = "[Or(GameHasMultiplePlayers, LedgerListFilter.IsFilteringBy( 'player_domains' ))]"
							layoutpolicy_horizontal = expanding
							text = "provinces_relation_player_domains"
							onclick = "[LedgerListFilter.SetCurrentFilter( 'player_domains' )]"
							down = "[LedgerListFilter.IsFilteringBy( 'player_domains' )]"
							shortcut = "sub_tab_4"
						}
						button_tab = {
							visible = "[Or(GameHasMultiplePlayers, LedgerListFilter.IsFilteringBy( 'player_realms' ))]"
							layoutpolicy_horizontal = expanding
							text = "provinces_relation_player_realms"
							onclick = "[LedgerListFilter.SetCurrentFilter( 'player_realms' )]"
							down = "[LedgerListFilter.IsFilteringBy( 'player_realms' )]"
							shortcut = "sub_tab_5"
						}
					}
				}

				blockoverride "filters_line" {
					spacer = {
						size = { 0 5 }
					}
					divider_light = {
						layoutpolicy_horizontal = expanding
					}
					
					hbox = {
						layoutpolicy_horizontal = expanding
						margin = { 10 5 }
						margin_left = 60
						
						background = { using = Background_Area_Border alpha = 0.6 }

						spacing = 30
						
						hbox = {
							enabled = "[Or(GetPlayer.IsValid, LedgerListFilter.IsFilteringBy( 'can_construct' ))]"
							datacontext = "[LedgerWindow.GetFilter('can_build')]"
							blockoverride "text" {
								text = "provinces_can_build_can_construct"
							}
							
							button_checkbox_label = {
								visible = "[Not(LedgerListFilter.IsFilteringBy( 'can_construct' ))]"
								
								# if we enable this, reset ongoing construction, since we can't build when there is one
								onclick = "[LedgerListFilter.SetCurrentFilter('can_construct')]"
								onclick = "[LedgerWindow.GetFilter('ongoing_construction').SetCurrentFilter('any')]"
								
								blockoverride "checkbox" {
									checked = "no"
								}
							}
							
							button_checkbox_label = {
								visible = "[LedgerListFilter.IsFilteringBy( 'can_construct' )]"
								
								onclick = "[LedgerListFilter.SetCurrentFilter('any')]"
								
								blockoverride "checkbox" {
									checked = "yes"
								}
							}
						}
						
						hbox = {
							datacontext = "[LedgerWindow.GetFilter('ongoing_construction')]"
							blockoverride "text" {
								text = "provinces_ongoing_construction"
							}
							
							button_checkbox_label = {
								visible = "[Not(LedgerListFilter.IsFilteringBy( 'yes' ))]"
								
								# if we enable this, reset can construct, since we can't do that with ongoing construction
								onclick = "[LedgerListFilter.SetCurrentFilter('yes')]"
								onclick = "[LedgerWindow.GetFilter('can_build').SetCurrentFilter('any')]"
								
								blockoverride "checkbox" {
									checked = "no"
								}
							}
							
							button_checkbox_label = {
								visible = "[LedgerListFilter.IsFilteringBy( 'yes' )]"
								
								onclick = "[LedgerListFilter.SetCurrentFilter('any')]"
								
								blockoverride "checkbox" {
									checked = "yes"
								}
							}
						}

						expand = {}
					}
					
					divider_light = {
						layoutpolicy_horizontal = expanding
					}
				}
			}

