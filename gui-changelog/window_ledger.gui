	type hbox_ledger_char_pious = hbox {
		# spacing = 5
		margin_right = 5
		layoutpolicy_horizontal = expanding

		widget_ledger_currency_wide = {
			block "prestige" {}
			blockoverride "show_widget_ledger" {
				tooltip = "[Character.GetPrestigeTooltipWithBalance]"
			}
			blockoverride "alpha_ledger" {
				tooltip = "[Character.GetPrestigeTooltipWithBalance]"
				alpha = "[Divide_CFixedPoint(IntToFixedPoint(Character.GetPrestigeLevel), '(CFixedPoint)40')]"
			}
			blockoverride "icon" {
				texture = "[Character.GetPrestigeLevelTexture]"
			}
			blockoverride "value" {
				text = "[Character.GetPrestige|0]"
			}
			blockoverride "gain" {
				text = "[Character.GetPrestigeBalance|=0]"
				visible = "[GreaterThanOrEqualTo_CFixedPoint(Character.GetPrestigeBalance, '(CFixedPoint)1')]"
			}
			blockoverride "progress" {
				value = "[Character.GetPrestigeProgressTowardNextLevel]"
			}
		}

		widget_ledger_currency_wide = {
			block "piety" {}
			blockoverride "show_widget_ledger" {
				tooltip = "[Character.GetPietyTooltipWithBalance]"
			}
			blockoverride "alpha_ledger" {
				tooltip = "[Character.GetPietyTooltipWithBalance]"
				alpha = "[Divide_CFixedPoint(IntToFixedPoint(Character.GetPietyLevel), '(CFixedPoint)40')]"
			}
			blockoverride "icon" {
				texture = "[Character.GetPietyLevelTexture]"
			}
			blockoverride "value" {
				text = "[Character.GetPiety|0]"
			}
			blockoverride "gain" {
				text = "[Character.GetPietyBalance|=0]"
				visible = "[GreaterThanOrEqualTo_CFixedPoint(Character.GetPietyBalance, '(CFixedPoint)1')]"
			}
			blockoverride "progress" {
				value = "[Character.GetPietyProgressTowardNextLevel]"
			}
		}

		widget = {
			size = { 30 40 }
			block "legitimacy" {}
			block "no_sort" {
				# tooltip = "[legitimacy|e]"
				widget = {
					position = { 0 2 }
					tooltip = "ledger_legitimacy_tt"
					datacontext = "[Character.GetLegitimacyType]"
					datacontext = "[Character.GetLegitimacyLevel]"
					visible = "[Character.ShouldShowLegitimacy]"
					size = { 100% 30 }
					using = tooltip_se

					icon = {
						texture = "gfx/interface/icons/activity_phases/button_activity_base.dds"
						size = { 100% 100% }
					}

					icon = {
						name = "progress_frame"
						texture = "gfx/interface/progressbars/action_progress_frame.dds"
						size = { 100% 100% }
						#alpha = 0.5
					}

					icon = {
						size = { 30 30 }
						texture = "[Character.GetLegitimacyType.GetLevelsIcon]"
						framesize = { 70 70 }
						frame = "[IntToFrameIndex( LegitimacyLevel.GetIndex )]"
					}

					progresspie = {
						name = "progress"
						size = { 34 34 }

						texture = "gfx/interface/progressbars/action_progress_thin_blue.dds"
						framesize = { 128 128 }
						frame = 2
						max = "[LegitimacyType.GetMaxLegitimacy( Character.Self )]"
						value = "[Character.GetLegitimacy]"
						parentanchor = center

						modify_texture = {
							texture = "gfx/interface/colors/blue.dds"
							blend_mode = normal
						}
					}
				}
			}
		}

		widget_ledger_currency_wide = {
			block "influence" {}
			blockoverride "show_widget_ledger" {}
			blockoverride "show_widget" {
				visible = "[Character.GetGovernment.HasGovernmentFlag( 'government_has_influence' )]"
				tooltip = "[Character.GetInfluenceTooltipWithBalance]"
			}
			blockoverride "icon" {
				texture = "[Character.GetInfluenceLevelTexture]"
			}
			blockoverride "value" {
				text = "[Character.GetInfluence|0]"
			}
			blockoverride "gain" {
				text = "[Character.GetInfluenceBalance|=0]"
				visible = "[GreaterThanOrEqualTo_CFixedPoint(Character.GetInfluenceBalance, '(CFixedPoint)1')]"
			}
			blockoverride "progress" {
				value = "[Character.GetInfluenceProgressTowardNextLevel]"
			}
		}

		widget_ledger_currency_wide = {
			block "merit" {}
			blockoverride "alpha_ledger" {
				alpha = "[Divide_CFixedPoint(IntToFixedPoint(Character.GetMeritLevel), '(CFixedPoint)90')]"
			}
			blockoverride "show_widget" {
				visible = "[Character.HasMerit]"
				tooltip = "[Character.GetMeritTooltipWithBalance]"
			}
			blockoverride "icon" {
				texture = "[Character.GetMeritLevelTexture]"
			}
			blockoverride "value" {
				text = "[SelectLocalization(GreaterThan_int32(Character.GetMeritLevel, '(int32)0'), GetMeritLevelShortNameNoTooltip(Character.GetMeritLevel), ' ')]"
			}
			blockoverride "value_size" {
				size = { 25 20 }
			}
			blockoverride "gain" {
				text = "[Character.GetMeritBalance|=0]"
				visible = "[GreaterThanOrEqualTo_CFixedPoint(Character.GetMeritBalance, '(CFixedPoint)1')]"
			}
			blockoverride "progress" {
				value = "[Select_CFixedPoint(EqualTo_int32(Character.GetMeritLevel, '(int32)9'), '(CFixedPoint)100', Character.GetMeritProgressTowardNextLevel)]"
			}
		}

		widget_ledger_currency_wide = {
			size = { 55 40 }
			block "radiance" {}
			blockoverride "alpha_ledger" {
				alpha = "[Divide_CFixedPoint(Character.GetRadianceValueNoTooltip, '(CFixedPoint)300')]"
			}
			blockoverride "show_widget" {
				visible = "[Character.ShouldShowRadiance]"
			}
			blockoverride "icon" {
				widget = {
					size = { 100% 100% }
					visible = "[Character.HasDynasty]"
					datacontext = "[Character.GetHouse]"

					powerful_family_bonus = {
						size = { 30 30 }
					}
				}
			}
			blockoverride "value" {
				margin_left = 2
				text = "[Character.GetRadianceValueNoTooltip|0]"
			}
			blockoverride "gain" {}
			blockoverride "progress" {
				visible = no
			}
		}

		widget = {
			size = { 30 40 }
			block "dominance" {}
			block "no_sort" {
				icon_dominance_ledger = {
					parentanchor = center
				}
			}
		}
	}

	type icon_dominance_ledger = icon {
