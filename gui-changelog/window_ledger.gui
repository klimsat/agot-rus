		highlight_icon = {
			name = "dominance icon"
			size = { 100% 100% }
			texture = "[Law.GetIcon]"
			parentanchor = center
		}
	}

	type widget_ledger_currency_wide = widget {
		size = { 100 40 }

		block "no_sort" {
			widget = {
				block "show_widget_ledger" {}
				size = { 100% 100% }
				widget = {
					block "show_widget" {}
					size = { 100% 100% }
					background = {
						texture = "gfx/interface/colors/gold.dds"
						block "alpha_ledger" {
							alpha = 0
						}
					}
					hbox = {
						spacing = 2
						layoutpolicy_vertical = expanding
						block "left" {}

						icon = {
							size = { 30 30 }
							block "icon" {}
						}

						vbox = {
							block "spacing" {
								spacing = 2
							}
							layoutpolicy_horizontal = expanding
							layoutpolicy_vertical = expanding
							margin_bottom = 6

							hbox = {
								layoutpolicy_horizontal = expanding
								spacing = 5
								text_ledger = {
									align = left
									block "value_size" {
										size = { @num3 20 }
									}
									block "value" {
										text = ""
									}
								}

								text_ledger = {
									size = { @num2 20 }
									align = left
									format_override = { zero_value low }
									default_format = "#low"
									block "gain" {
										text = ""
									}
								}
								expand = {}
							}

							hbox = {
								layoutpolicy_horizontal = expanding

								progressbar_standard = {
									block "progress" {}
									block "progress_size" {
										size = { 60 10 }
									}
								}

								expand = {}

							}
						}
					}
				}
			}
		}
	}

	### character types

	type widget_ledger_char_header = widget {
		layoutpolicy_horizontal = expanding
		size = { 0 26 }
		allow_outside = yes

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			block "char_header_margins" {
				margin_left = 5
				margin_right = -5
			}

			background = {
				using = Background_Area_Characterlist
				margin = { 0 0 }
				margin_right = 10
				using = Mask_Rough_Edges
				block "bg" {
					alpha = "[Select_float( Character.IsRuler, '(float)1.0', '(float)0.5' )]"
				}
			}

			background = {
				texture = "gfx/interface/colors/white.dds"
				using = tintcolor_local_player
				alpha = 0.2
				block "player_item" {
					visible = no
				}
			}

			block "pre_ledger_coa" {}

			widget = {
				size = { @num2 30 }
				block "ledger_coa" {
					visible = "[Character.HasLandedTitles]"
				}
				widget = {
					size = { 100% 100% }
					visible = "[Character.HasLandedTitles]"
					coa_realm_tiny = {
						position = { 1 3 }
						scale = 0.7
					}
				}
			}
			
			block "pre_ledger_name" {}
 
			text_single = {
				layoutpolicy_horizontal = expanding
				block "name_width" {
					max_width = 350
				}
				align = nobaseline
				text = "[Character.GetFullNameNoTooltip]"
				alwaystransparent = yes
			}

			expand = { }

			button = {
				clicksound = ""
				state = {
					name = _mouse_hierarchy_enter
					on_finish = "[PdxGuiWidget.FindChild('button_favorite').TriggerAnimation('hover_enter')]"
					on_finish = "[PdxGuiWidget.FindChild('stats').TriggerAnimation('hover_enter')]"
				}

				state = {
					name = _mouse_hierarchy_leave
					on_finish = "[PdxGuiWidget.FindChild('button_favorite').TriggerAnimation('hover_leave')]"
					on_finish = "[PdxGuiWidget.FindChild('stats').TriggerAnimation('hover_leave')]"
				}

				hbox = {
					resizeparent = yes
					hbox = {
						name = "stats"
						alpha = 0.5

						state = {
							name = hover_enter
							alpha = 1
							duration = 0.1
							using = Animation_Curve_Default

						}

						state = {
							name = hover_leave
							alpha = 0.5
							duration = 0.2
							using = Animation_Curve_Default
						}

						hbox_skills_ledger_character = {}

						widget = {
							size = { 10 0 }
						}

						text_single = {
							name = "character_age"
							# layoutpolicy_horizontal = expanding
							# size = { 20 20 }

							text = "[Character.GetAge]"
							# default_format = "#low"
							align = nobaseline


							tooltip = "CHARACTER_VIEW_AGE_TT"
						}

						hbox = {
							block "health_margin"
							{
								margin_left = 2
							}

							icon = {
								visible = "[Not( Character.IsDeadAndValid )]"
								size = { 23 23 }

								framesize = { 60 60 }
								frame = "[Character.GetHealthIconFrame]"
								texture = "gfx/interface/icons/character_status/icon_health.dds"

								tooltip = "CHARACTER_VIEW_ALIVE_TT"
							}

							icon = {
								visible = "[Character.IsDeadAndValid]"
								size = { 23 23 }

								texture = "gfx/interface/icons/character_status/icon_dead.dds"

								tooltip = "CHARACTER_DEAD_TOOLTIP"
							}
						}
					}

					star_button = {}

					widget_ledger_place = {}
				}
			}
		}

		# widget_player_item = {}
	}

