	type star_button = button {
		clicksound = ""
		size = { 26 30 }
		allow_outside = yes

		block "no_sort" {
			button = {
				size = { 26 26 }
				position = { 0 -1 }

				allow_outside = yes
				block "button" {
					parentanchor = center
				}

				button_star_frames = {
					size = { 100% 100% }

					alpha = 0
					name = "button_favorite"

					block "ledger_pin" {}
					block "favorite_tooltip" {
						tooltip = "FAVORITE_LEDGER"
					}
					using = tooltip_sw

					inherit_visual_state = no

					state = {
						name = hover_enter
						alpha = 1
						# duration = 0.1 # gets stuck much when moving fast
						using = Animation_Curve_Default
					}

					state = {
						name = hover_leave
						alpha = 0
						# duration = 0.2
						using = Animation_Curve_Default
					}
				}

				button_star_frames = {
					size = { 100% 100% }
					alwaystransparent = yes
					down = yes
				
					block "down_ledger_pin" {}
				}
			}
		}
	}

	type widget_ledger_place = widget {
		size = { @num4 0 }
		layoutpolicy_vertical = expanding
		tooltip = "LEDGER_LIST_POSITION"
		using = tooltip_sw

		text_single = {
			parentanchor = center
			default_format = "#bold;highlight"
			alpha = 0.8
			align = nobaseline|center
			text = "['(int32)1']"
			visible = "[EqualTo_int32(PdxGuiWidget.GetIndexInDataModel, '(int32)0')]"
		}

		text_single = {
			parentanchor = center
			default_format = "#bold;e"
			alpha = 0.8
			align = nobaseline|center
			text = "['(int32)2']"
			visible = "[EqualTo_int32(PdxGuiWidget.GetIndexInDataModel, '(int32)1')]"
		}

		text_single = {
			parentanchor = center
			default_format = "#bold;clickable"
			alpha = 0.8
			align = nobaseline|center
			text = "['(int32)3']"
			visible = "[EqualTo_int32(PdxGuiWidget.GetIndexInDataModel, '(int32)2')]"
		}

		text_single = {
			parentanchor = center
			default_format = "#low;bold"
			alpha = 0.75
			align = nobaseline|center
			text = "[Add_int32(PdxGuiWidget.GetIndexInDataModel, '(int32)1')]"
			visible = "[And(GreaterThan_int32(PdxGuiWidget.GetIndexInDataModel, '(int32)2'), LessThan_int32(PdxGuiWidget.GetIndexInDataModel, '(int32)100'))]"
		}

		text_single = {
			parentanchor = center
			default_format = "#low"
			align = nobaseline|center
			raw_text = "..."
			visible = "[GreaterThan_int32(PdxGuiWidget.GetIndexInDataModel, '(int32)99')]"
		}
	}

