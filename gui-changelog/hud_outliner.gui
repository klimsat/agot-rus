	type outliner_pinned_titles_info = vbox {
		visible = "[Outliner.IsCategoryShown('pinned_titles')]"
		layoutpolicy_horizontal = expanding
		margin = { 8 5 }
		margin_bottom = 4		
		
		datamodel = "[Outliner.GetPinnedTitles]"

		item = {
			button_list = {
				layoutpolicy_horizontal = expanding
				size = { 0 34 }
				block "context" {}
				onclick = "[DefaultOnCoatOfArmsClick(Title.GetID)]"
				onrightclick = "[DefaultOnCoatOfArmsRightClick(Title.GetID)]"
				button_ignore = none

				down = "[Or(Title.IsHovered, Title.IsSelected)]"
				using = tooltip_ws

				# margin_widget = {
				# 	size = { 100% 100% }
				# 	margin = { 0 2 }
				# 	margin_left = 40
				# 
				# 	progressbar_standard_transparent = {
				# 		name = "progress_bar"
				# 		size = { 100% 100% }
				# 		value = 50
				# 		alpha = 0.8
				# 	}
				# }

				hbox = {
					widget = {
						size = { 40 28 }

						coa_title_tiny = {
							parentanchor = center
							tooltip_visible = no
							position = { 0 5 }
						}
					}

					hbox = {
						margin = { 4 0 }
						layoutpolicy_horizontal = expanding

						hbox = {
							text_single = {
								max_width = 135
								layoutpolicy_horizontal = expanding
								text = "[Title.GetNameNoTierNoTooltip]"
								default_format = "#high"
								align = nobaseline
							}
						}

						expand = {}
						
						# counties you own / counties needed to create or usurp
						# triggers from the Title window, for creating and usurping
						datacontext = "[Title.GetHolder]"
						hbox = {
							visible = "[And(Not(Or(Title.IsMercenaryCompany,Title.IsHolyOrder)), Not(Or(Title.IsBarony, Title.IsCounty)))]"
							hbox = {
								# if we're a nomad, the title has to be higher or equal to ours (for some reason)
								visible = "[Or(Not( IsNomad( GetPlayer ) ), GreaterThanOrEqualTo_int32( GetPlayer.GetPrimaryTitle.GetTierFrame, Title.GetTierFrame ))]"
								# either there's no holder, so we can create it
								# or we don't hold it and we can usurp it
								hbox = {
									visible = "[Or( And( Not( Title.HasHolder ), Not( Title.IsNobleFamilyTitle )), And( Not(Character.IsLocalPlayer), Title.ShowUsurp ))]"
									
									# raw_tooltip = "#D Amount of counties you hold / minimum to create or usurp"
									# 
									# text_single = {
									# 	raw_text = "#D 5"  #TODO code
									# 	# text = "[Title.GetOwnedDeJureCounties( GetPlayer )]"
									# 	autoresize = no
									# 	size = { 45 20 }
									# 	align = nobaseline|right
									# 	default_format = "#high"
									# }
									# 
									# text_single = {
									# 	raw_text = "#D /10"  #TODO code
									# 	# text = "[Title.GetMinimumDeJureCounties( GetPlayer )]"
									# 	alpha = 0.7
									# 	align = nobaseline
									# }
								}						
							}
						}
					}
				}
			}
		}		
	}
}


local_template character_tooltip
{
	tooltip_visible = "[Not(IsInteractionMenuOpenForCharacter(Character.GetID))]"
	tooltipwidget = {
		cooltip_type = {
			blockoverride "interaction_info"
			{
				text = "CHARACTER_TOOLTIP_INSTRUCTION"
			}
		}
	}
	using = tooltip_ws
}
