widget = {
	name = "outliner_window"
	parentanchor = top|right
	position = { -36 55 }
	alwaystransparent = no
	filter_mouse = all
	layer = windows_layer

	state = {
		name = _show
		using = Animation_FadeIn_Quick
		start_sound = {
			soundeffect = "event:/SFX/UI/Generic/Windows/sfx_ui_generic_window_outliner_show"
		}
	}

	state = {
		name = _hide
		using = Animation_FadeOut_Standard
		start_sound = {
			soundeffect = "event:/SFX/UI/Generic/Windows/sfx_ui_generic_window_outliner_hide"
		}
	}

	state = {
		name = "hide_outliner"
		using = Animation_FadeOut_Standard
		trigger_when = "[Not(IsDefaultGUIMode)]"
	}

	state = {
		name = "show_outliner"
		using = Animation_FadeIn_Quick
		trigger_when = "[IsDefaultGUIMode]"
	}

	flowcontainer = {
		visible = "[And( Not(IsGameViewOpen('barbershop')), And( Not( IsPauseMenuShown ), Not(IsRightWindowOpen) ) )]"
		resizeparent = yes
		margin = { 10 10 }
		margin_bottom = 15

		state = {
			name = _show
			using = Animation_FadeIn_Standard
		}

		state = {
			name = _hide
			using = Animation_FadeOut_Quick
		}

		background = {
			name = "paper_texture_shadow"
			texture = "gfx/interface/skinned/window_letter/tile_letter_shadow.dds"
			spriteType = Corneredtiled
			spriteborder = { 200 200 }
			margin = { -15 0 }
			margin_right = -20
		}

		background = {
			name = "paper_texture_flat"
			texture = "gfx/interface/skinned/window_letter/tile_letter_flat.dds"
			spriteType = Corneredtiled
			spriteborder = { 200 200 }
			alpha = 0.9
			color = { 0.51 0.53 0.58 1 }
			margin = { -15 0 }
			margin_right = -20

			modify_texture = {
				name = "paper_texture_overlay"
				texture = "gfx/interface/window_event/overlay_letter_texture.dds"
				spriteType = Corneredstretched
				blend_mode = overlay
			}
		}

		scrollarea = {
			autoresizescrollarea = yes
			scrollbarpolicy_horizontal = always_off
			maximumsize = { -1 500 }
			size = { 300 0 }

			scrollbar_vertical = {
				using = Scrollbar_Vertical
			}

			scrollwidget = {
				vbox = {
					set_parent_size_to_minimum = yes
					min_width = 300
					margin = { 10 0 }
					margin_right = 15
					spacing = 2

					outliner_pinned_characters_header = {
						shortcut = "tab_1"
					}
					outliner_pinned_characters_info = {}

					outliner_players_header = {}
					outliner_players_info = {}

					outliner_units_header = {
						shortcut = "tab_2"
					}
					outliner_units_info = {}

					outliner_holdings_header = {
						shortcut = "tab_3"
					}
					outliner_holdings_info = {
						blockoverride "context" {
							datacontext = "[OutlinerHoldingItem.GetTitle]"
							datacontext = "[OutlinerHoldingItem.GetTitle.GetProvince.GetHolding]"
						}
					}

					outliner_domicile_header = {}
					outliner_domicile_info = {}
					
					outliner_pinned_holdings_header = {
						shortcut = tab_4
					}
					outliner_pinned_holdings_info = {
						blockoverride "context" {
							datacontext = "[OutlinerHoldingItem.GetTitle]"
							datacontext = "[OutlinerHoldingItem.GetTitle.GetProvince.GetHolding]"
						}
					}
					
					outliner_pinned_titles_header = {
						shortcut = tab_5
					}
					outliner_pinned_titles_info = {}

					expand = {}
				}
			}
		}
	}
}

types Outliner {
	type button_outliner_header = button_tab {
		size = { 0 31 }

		block "oh_button" {}

		blockoverride "icon_visible" 
		{
			visible = no
		}

		hbox = {
			margin = { 15 0 }
			spacing = 5

			using = tooltip_ws

			button_expand = {
				size = { 22 22 }
				alwaystransparent = yes
				block "button_expand_frame" {}
			}

			text_single = {
				name = "category"
				layoutpolicy_horizontal = expanding
				align = nobaseline
				default_format = "#high"
				max_width = 180

				block "oh_name"
				{
					text = "DEFAULT_TEXT"
				}
			}

			text_single = {
				name = "count"
				align = nobaseline

				block "oh_count"
				{
					text = "DEFAULT_TEXT"
				}
			}

		}
	}

	type outliner_pinned_characters_header = button_outliner_header {
		name = "pinned_characters_header"
		layoutpolicy_horizontal = expanding

		blockoverride "button_expand_frame"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('pinned_character'))]"
		}

		blockoverride "oh_button"
		{
			onclick = "[Outliner.ToggleCategory('pinned_character')]"
			tooltip = "[SelectLocalization( Outliner.IsCategoryShown('pinned_character'), 'OUTLINER_COLLAPSE', 'OUTLINER_EXPAND' )]"
		}

		blockoverride "oh_toggle_frame"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('pinned_character'))]"
		}

		blockoverride "oh_name"
		{
			text = "OUTLINER_PINNED_CHARACTERS"
		}

		blockoverride "oh_count"
		{
			text = "[Outliner.GetCategoryItemsCount('pinned_character')|V]"
		}

		blockoverride "expanded"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('pinned_character'))]"
		}
	}

	type outliner_pinned_characters_info = vbox {
		name = "pinned_characters"
		visible = "[Outliner.IsCategoryShown('pinned_character')]"
		datamodel = "[Outliner.GetPinnedCharacters]"
		layoutpolicy_horizontal = expanding
		margin = { 5 5 }
		margin_bottom = 4


		text_single = {
			visible = "[And(Outliner.IsCategoryShown('pinned_character'), IsDataModelEmpty(Outliner.GetPinnedCharacters))]"
			name = "no_pinned_characters"
			text = "OUTLINER_NO_PINNED_CHARACTERS"
			default_format = "#light_background;italic"
			align = hcenter|nobaseline

			autoresize = no
			layoutpolicy_horizontal = expanding
		}
		

		item = {
			hbox = {
				name = "pinned_character_item"
				layoutpolicy_horizontal = expanding
				using = character_tooltip

				background = {
					using = Background_Area
				}

				button_list = {
					name = "character_button"
					size = { 0 54 }
					layoutpolicy_horizontal = expanding

					onclick = "[DefaultOnCharacterClick(Character.GetID)]"
					down = "[Character.IsShownInCharacterWindow]"
					onrightclick = "[DefaultOnCharacterRightClick(Character.GetID)]"
					button_ignore = none

					state = {
						name = _mouse_hierarchy_enter
						on_start = "[PdxGuiWidget.FindChild('button_unpin').TriggerAnimation('button_unpin_show')]"
					}

					state = {
						name = _mouse_hierarchy_leave
						on_start = "[PdxGuiWidget.FindChild('button_unpin').TriggerAnimation('button_unpin_hide')]"
					}

					hbox = {
						margin = { 5 0 }

						vbox = {
							layoutpolicy_horizontal = expanding
							
							hbox = {
								layoutpolicy_horizontal = expanding
								margin_top = -4
								
								# Realm CoA
								coa_realm_tiny_crown = {
									datacontext = "[Character]"
									visible = "[Character.HasLandedTitles]"
								}
								
								# Unlanded
								icon = {
									#AGOT Modified
									# visible = "[Not( Character.HasLandedTitles )]"
									visible = "[And(Not(Character.HasLandedTitles), Not(IsCharacterDragon))]"
									size = { 32 38 }
									texture = "gfx/interface/icons/unlanded_realm_flag.dds"
								}
								
								spacer = { size = { 3 } }
								
								vbox = {
									layoutpolicy_horizontal = expanding
									spacing = 2
									
									# First row
									hbox = {
										layoutpolicy_horizontal = expanding
										#AGOT Added
										agot_dragon_pin_icon = {}
										agot_dragon_pin_name = {}
										
										# Name
										text_single = {
											layoutpolicy_horizontal = expanding
											autoresize = no
											text = "OUTLINER_PINNED_CHARACTER"
											default_format = "#high"
											max_width = 164
											#AGOT Added
											visible = "[Not(IsCharacterDragon)]"
										}

										# Health icon
										icon = {
											visible = "[Character.IsDeadAndValid]"
											size = { 20 20 }
											texture = "[Character.GetDeathReasonIcon]"
											tooltip = "CHARACTER_DEAD_TOOLTIP"
										}

										# Death icon
										icon = {
											visible = "[Not(Character.IsDeadAndValid)]"
											size = { 23 23 }
											framesize = { 60 60 }
											frame = "[Character.GetHealthIconFrame]"
											tooltip = "[Character.GetHealthInfo]"
											using = tooltip_ws
											texture = "gfx/interface/icons/character_status/icon_health.dds"
										}
										
										spacing = 5
										
										# Opinion
										text_single = {
											text = "[Character.GetOpinionOf( GetPlayer )|=]"
											fonttintcolor = "[Character.GetOpinionOfTint( GetPlayer )]"
											default_format = "#true_white"
											align = hcenter
											#AGOT Modified
											# visible = "[Character.IsAlive]"
											visible = "[And(Character.IsAlive, Not(IsCharacterDragon))]"
											min_width = 32

											tooltipwidget = character_opinion_tooltip
											using = tooltip_ws
											using = Font_Size_Small

											background = {
												name = "portrait_opinion_bg"
												texture = "gfx/interface/component_tiles/solid_black_label.dds"
												spritetype = Corneredtiled
												spriteborder = { 20 20 }
												margin = { 5 0 }
												margin_bottom = 6
												texture_density = 2
											}
										}
									}
									
									# Second row
									hbox = {
										layoutpolicy_horizontal = expanding
										#AGOT Added
										visible = "[Not(IsCharacterDragon)]"
										
										# At war
										icon = {
											visible = "[Character.IsAtWar]"
											name = "at_war_icon"
											size = { 20 20 }
											texture = "gfx/interface/icons/memory_types/war_started.dds"
											tooltip = "OUTLINER_PINNED_CHARACTER_IS_AT_WAR"
											using = tooltip_ws
										}
										
										# Factions
										icon = {
											visible = "[Character.IsInFactionTargetingPlayer]"
											size = { 20 20 }
											texture = "gfx/interface/icons/portraits/faction_member_small.dds"
										}

										# Powerful vassal
										icon = {
											visible = "[And(Character.IsMyPowerfulVassal, Not(Character.IsInFactionTargetingPlayer))]"
											size = { 20 20 }
											texture = "gfx/interface/icons/portraits/powerful_vassal_small.dds"
											framesize = { 28 28 }
											frame = "[Character.GetPowerfulVassalFrame]"

											tooltip = "[Character.GetPowerfulVassalTooltip]"
											using = tooltip_ws
										}
										
										# Relation string
										text_single = {
											layoutpolicy_horizontal = expanding
											text = "[Character.GetRelationToString( GetPlayer )]"
											tooltip = "EXTENDED_RELATIONS_TOOLTIP"
											using = tooltip_ws
											autoresize = no
											align = nobaseline
											alwaystransparent = yes
										}
										
										# Army strength
										icon = {
											name = "outliner_char_combat_strength"
											visible = "[Character.HasLandedTitles]"
											size = { 20 20 }
											texture = "gfx/interface/icons/icon_soldier.dds"
										}
										text_single = {
											visible = "[Character.HasLandedTitles]"
											text = "[Character.GetMilitaryStrengthText]"
											using = tooltip_ws
											align = nobaseline
											default_format = "#high"
										}
										
										
									}
									#AGOT Added
									agot_dragon_pin_relation = {}
								}
								
								# Unpin button
								hbox = {
									margin_left = 3
									
									button_round = {
										name = "button_unpin"
										size = { 30 30 }
										onclick = "[Character.ToggleCharacterPinned]"
										tooltip = "PIN_TT"
										inherit_visual_state = no

										alpha = 0.6
										
										state = {
											name = button_unpin_show
											alpha = 1
											duration = 0.15
											using = Animation_Curve_Default
											size = { 30 30 }
										}
										
										state = {
											name = button_unpin_hide
											trigger_on_create = yes
											alpha = 0
											duration = 0.15
											using = Animation_Curve_Default
											size = { 0 0 }
										}

										state = {
											name = _mouse_enter
											alpha = 1
											duration = 0.1
											using = Animation_Curve_Default
										}

										state = {
											name = _mouse_leave
											alpha = 0.6
											duration = 0.2
											using = Animation_Curve_Default
										}

										button_unpin = {
											parentanchor = center
											size = { 22 22 }
											alwaystransparent = yes
											inherit_visual_state = no
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}

	type outliner_players_header = button_outliner_header {
		name = "players_header"
		layoutpolicy_horizontal = expanding
		visible = "[GameHasMultiplePlayers]"

		blockoverride "button_expand_frame"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('players'))]"
		}

		blockoverride "oh_button"
		{
			onclick = "[Outliner.ToggleCategory('players')]"
			tooltip = "[SelectLocalization( Outliner.IsCategoryShown('players'), 'OUTLINER_COLLAPSE', 'OUTLINER_EXPAND' )]"
		}

		blockoverride "oh_toggle_frame"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('players'))]"
		}

		blockoverride "oh_name"
		{
			text = "OUTLINER_PLAYERS"
		}

		blockoverride "oh_count"
		{
			text = "[Outliner.GetCategoryItemsCount('players')|V]"
		}

		blockoverride "expanded"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('players'))]"
		}
	}

	type outliner_players_info = vbox {
		name = "players"
		datamodel = "[Outliner.GetPlayers]"
		visible = "[And( Outliner.IsCategoryShown('players'), GameHasMultiplePlayers )]"
		layoutpolicy_horizontal = expanding
		margin = { 8 5 }
		margin_bottom = 10
		spacing = 5

		item = {
			button_list = {
				name = "player_button"
				datacontext = "[OutlinerPlayer.GetCharacter]"
				layoutpolicy_horizontal = expanding
				size = { 0 40 }

				enabled = "[Character.IsValid]"
				onclick = "[DefaultOnCharacterClick(Character.GetID)]"
				down = "[Character.IsShownInCharacterWindow]"
				onrightclick = "[DefaultOnCharacterRightClick(Character.GetID)]"
				button_ignore = none

				hbox = {
					spacing = 5
					margin = { 5 0 }

					coa_realm_tiny = {
						visible = "[Character.HasLandedTitles]"
					}

					widget = {
						size = { 34 41 }
						visible = "[Not( Character.HasLandedTitles )]"

						icon_observer = {
							size = { 40 40 }
							widgetanchor = center
							parentanchor = center
						}
					}

					using = character_tooltip

					using = tooltip_ws

					vbox = {
						layoutpolicy_horizontal = expanding
						margin_bottom = 7

						text_single = {
							name = "player_name"
							layoutpolicy_horizontal = expanding
							text = "[OutlinerPlayer.GetName]"
							default_format = "#high"
							using = Font_Size_Medium
							align = nobaseline
							max_width = 220
							tooltip = "[OutlinerPlayer.GetName]"
						}

						widget = {
							text_single = {
								name = "joining_status"
								#visible = "[OutlinerPlayer.IsJoining]"
								layoutpolicy_horizontal = expanding
								text = "[OutlinerPlayer.GetDescription]"
								default_format = "#high"
								using = Font_Size_Small
								align = nobaseline
								max_width = 220
							}
						}
					}
				}
			}

		}
	}

	type outliner_units_header = button_outliner_header {
		name = "units_header"
		layoutpolicy_horizontal = expanding
		visible = "[GetPlayer.IsValid]"

		blockoverride "button_expand_frame"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('unit'))]"
		}

		blockoverride "oh_button"
		{
			onclick = "[Outliner.ToggleCategory('unit')]"
			tooltip = "OUTLINER_ARMIES_TT"
			oversound = "event:/SFX/UI/Generic/sfx_ui_generic_icon_pointer_over"
			clicksound = "event:/SFX/UI/Generic/sfx_ui_generic_icon_select"
		}

		blockoverride "oh_toggle_frame"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('unit'))]"
		}

		blockoverride "oh_name"
		{
			text = "OUTLINER_ARMIES"
		}

		blockoverride "oh_count"
		{
			text = "[Outliner.GetCategoryItemsCount('unit')|V]"
		}
		blockoverride "expanded"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('unit'))]"
		}
	}

	type outliner_units_info = vbox {
		name = "units"
		datamodel = "[Outliner.GetUnitItems]"
		visible = "[And(Outliner.IsCategoryShown('unit'), GetPlayer.IsValid)]"
		layoutpolicy_horizontal = expanding
		margin = { 4 4 }
		margin_bottom = 4

		text_single = {
			visible = "[And(And(Outliner.IsCategoryShown('unit'), IsDataModelEmpty(Outliner.GetUnitItems)), GetPlayer.IsValid)]"
			name = "no_units"
			text = "OUTLINER_NO_ARMIES"
			default_format = "#light_background;italic"

			autoresize = no
			align = hcenter|nobaseline
			layoutpolicy_horizontal = expanding
		}

		################################
		# / \ |Name of the Army        #
		# \ / | A 1000 ¤¤       @ &(^) #
		################################
		item = {
			button_list = {
				name = "unit_item"
				datacontext = "[UnitItem.GetArmy]"
				layoutpolicy_horizontal = expanding
				size = { 0 58 }
				using = SubTabShortcut

				onclick = "[UnitItem.SelectAndPanUnit]"
				onrightclick = "[UnitItem.PanToUnit]"
				button_ignore = none
				down = "[UnitItem.IsSelected]"

				background = {
					using = Background_Area
				}
				
				vbox = {
					layoutpolicy_horizontal = expanding
					margin = { 5 0 }
					
					# First row
					hbox = {
						layoutpolicy_horizontal = expanding
						
						# No commander
						icon = {
							datacontext = "[Army.GetCommander]"
							visible = "[Not( Character.IsValid )]"
							texture = "gfx/interface/icons/icon_commander.dds"
							size = { 28 28 }
							
							icon = {
								texture = "gfx/interface/icons/map_icons/provision_travel_warning_exclamation_mark.dds"
								size = { 12 26 }
							}
							
							tooltip = "ARMY_TOOLTIP_NO_COMMANDER"
							using = tooltip_ws
						}
						
						# Commander
						icon = {
							datacontext = "[Army.GetCommander]"
							visible = "[And( Character.IsValid, Not( Character.IsPlayer ) )]"
							texture = "gfx/interface/icons/icon_commander.dds"
							size = { 28 28 }

							tooltip = "OUTLINER_ARMY_COMMANDER_TOOLTIP"
							using = tooltip_ws
						}
						
						# Commanded by ruler
						icon = {
							datacontext = "[Army.GetCommander]"
							visible = "[Character.IsPlayer]"
							texture = "gfx/interface/icons/commander_is_leader.dds"
							size = { 28 28 }

							tooltip = "COMMANDER_IS_LEADER_TOOLTIP"
							using = tooltip_ws
						}
						
						# Army name
						text_single = {
							layoutpolicy_horizontal = expanding
							autoresize = no
							text = "[Army.GetNameNoTooltip]"
							default_format = "#high"
							align = nobaseline
						}
					}
					
					# Second row
					hbox = {
						layoutpolicy_horizontal = expanding
						margin_top = -5
						
						# Army automation
						icon = {
							visible = "[Army.IsControlledByCompanionAI]"
							size = { 28 28 }
							army_automation_on_big = {
							}
							icon_ai_order = {
								size = { 20 20 }
								position = { 5 5 }
							}
						}
						
						# Status icon
						icon = {
							visible = "[Not( Army.IsControlledByCompanionAI )]"
							texture = "[Army.GetArmyStatusOutlinerIcon]"
							size = { 28 28 }

							tooltip = "[Army.GetArmyStatusTooltip]"
							using = tooltip_ws
						}
						
						spacer = { size = { 5 } }
						
						# Army size (bar and number)
						progressbar_standard = {
							name = "soldiers_max"
							datacontext = "[Army.GetComposition]"

							block "spacing"
							{
								size = { 100 20 }
							}

							min = 0
							max = "[IntToFloat(ArmyComposition.GetMaxNumberOfSoldiers)]"
							value = "[IntToFloat(ArmyComposition.GetCurrentNumberOfSoldiers)]"
							
							text_single = {
								layoutpolicy_horizontal = expanding
								text = "[Army.GetSoldierCountString]"
								align = nobaseline
								default_format = "#high"
								parentanchor = center
							}
						}
						
						spacer = { size = { 5 } }
						
						icon_unit_quality = {}
						
						expand = {}
						
						# Attrition
						icon = {
							visible = "[Army.IsArmySufferingFromAttrition]"
							texture = "gfx/interface/icons/map_icons/attrition_icon.dds"
							size = { 28 28 }
						}
						
						spacer = { size = { 4 } }
						
						container_supply_icon = {
							size = { 35 28 }
							
							blockoverride "supply_icon" {
								framesize = { 25 25 }
								size = { 24 24 }
							}
						}
					}
					
					using = tooltip_ws
					
					tooltipwidget = {
						using = unit_icon_item_tooltip
						
						blockoverride "extra_unit_info"
						{
							vbox = {
								name = "army_extra_info"
								layoutpolicy_horizontal = expanding
								ignoreinvisible = yes
								margin = { 15 0 }

								text_single = {
									name = "status_info"
									layoutpolicy_horizontal = expanding
									text = "[UnitItem.GetStatusDescription]"
									align = left
									margin_bottom = 6
								}

								text_single = {
									name = "warning_info"
									layoutpolicy_horizontal = expanding
									text = "[UnitItem.GetOutlinerWarning]"
								}

								text_single = {
									name = "click_info"
									layoutpolicy_horizontal = expanding
									text = "[SelectLocalization(UnitItem.IsSelectedOnArmyWindow, 'OUTLINER_ARMY_CLICK_TO_PAN', 'OUTLINER_ARMY_CLICK_TO_SELECT')]"
								}

								text_single = {
									name = "right_click_info"
									layoutpolicy_horizontal = expanding
									text = "OUTLINER_ARMY_RIGHT_CLICK_TO_PAN"
									margin_bottom = 12
								}
							}
						}
					}
				}
			}
		}
	}

	type outliner_holdings_header = button_outliner_header {
		name = "holdings_header"
		layoutpolicy_horizontal = expanding
		visible = "[GetPlayer.IsValid]"

		blockoverride "button_expand_frame"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('holding'))]"
		}

		blockoverride "oh_button"
		{

			onclick = "[Outliner.ToggleCategory('holding')]"
			tooltip = "[SelectLocalization( Outliner.IsCategoryShown('holding'), 'OUTLINER_COLLAPSE', 'OUTLINER_EXPAND' )]"
		}

		blockoverride "oh_name"
		{
			text = "OUTLINER_HOLDINGS"
		}

		blockoverride "oh_count"
		{
			text = "[Outliner.GetCategoryItemsCount('holding')|V]"
		}

		blockoverride "expanded"
		{
			frame = "[BoolTo1And2(Outliner.IsCategoryShown('holding'))]"
		}
	}

	type outliner_holdings_info = vbox {
		name = "holdings"
		block "model" {
			datamodel = "[Outliner.GetHoldingItems]"
			visible = "[Outliner.IsCategoryShown('holding')]"
		}
		layoutpolicy_horizontal = expanding
		margin = { 8 5 }
		margin_bottom = 4

		item = {
			button_list = {
				name = "holding_item"
				layoutpolicy_horizontal = expanding
				size = { 0 34 }
				block "context" {}

				block "click" {
					onclick = "[OutlinerHoldingItem.OnClick]"
				}
				down = "[Or(Holding.IsHoldingOrNonCapitalHoldingHovered, Holding.IsSelected)]"
				tooltipwidget = { holding_tooltip_click = {} }
				using = tooltip_ws
				using = Holding_Mouse_Entry

				margin_widget = {
					size = { 100% 100% }
					margin = { 0 2 }
					margin_left = 40

					progressbar_standard_transparent = {
						name = "progress_bar"
						size = { 100% 100% }
						visible = "[Holding.IsConstructionInProgress]"
						value = "[Holding.GetConstructionProgress]"
						alpha = 0.8
					}
				}

				hbox = {
					widget = {
						size = { 40 28 }

						coa_title_tiny = {
							name = "claim"
							datacontext = "[Holding.GetProvince.GetTitle]"
							parentanchor = center
							tooltip_visible = no
							position = { 0 5 }
						}

						# Conditional status indicators
						# Raid indicator
						button = {
							datacontext = "[Holding.GetProvince.GetRaid]"
							visible = "[Holding.GetProvince.HasActiveRaid]"
							onclick = "[DefaultOnRaidClick( Raid.Self )]"
							texture = "gfx/interface/icons/map_icons/onmap_raid_icon.dds"
							size = { 28 28 }
							position = { -7 3 }
							tooltip = "MAP_RAID_TOOLTIP"
							using = tooltip_ws
						}

						# Siege indicator
						button = {
							datacontext = "[Holding.GetProvince.GetSiege]"
							visible = "[Holding.GetProvince.HasSiege]"
							onclick = "[DefaultOnSiegeClick(Siege.GetID)]"
							texture = "gfx/interface/icons/map_icons/onmap_siege_icon.dds"
							size = { 28 28 }
							position = { -7 3 }
							tooltip = "[Holding.GetProvince.GetSiege.GetSiegeDescription]"
							using = tooltip_ws
						}
					}

					hbox = {
						margin = { 4 0 }
						layoutpolicy_horizontal = expanding

						hbox = {

							text_single = {
								max_width = 80
								name = "holding_name"
								layoutpolicy_horizontal = expanding
								text = "[Holding.GetProvince.GetNameNoTooltip]"
								default_format = "#high"
								align = nobaseline
							}
						}

						expand = {}

						# Construction in progress
						hbox = {
							visible = "[Holding.IsConstructionInProgress]"

							icon = {
								texture = "gfx/interface/icons/map_icons/county_building_available.dds"
								size = { 18 18 }
							}
							text_single = {
								max_width = 120
								name = "construction_name"
								text = "[Holding.GetConstructionBuilding.GetNameNoTooltip]"
								align = right|nobaseline
								default_format = "#high"
							}
						}

						# Tax and levies (for non-nomads)
						hbox = {
							visible = "[And( Not( Holding.IsConstructionInProgress ), Not( IsNomad( GetPlayer ) ) )]"

							text_single = {
								text = "HOLDING_TAX_VALUE"
								min_width = 70
								max_width = 70
								align = left|nobaseline
								default_format = "#high"
							}

							text_single = {
								text = "HOLDING_LEVY_SIZE"
								min_width = 60
								max_width = 60
								align = left|nobaseline
								default_format = "#high"
							}
						}

						# County fertility and herd
						hbox = {
							visible = "[And( Not( Holding.IsConstructionInProgress ), IsNomad( GetPlayer ) )]"

							text_single = {
								text = "HOLDING_COUNTY_FERTILITY"
								min_width = 70
								max_width = 70
								align = left|nobaseline
								default_format = "#high;glow_color:{0.1,0.1,0.1,1.0}"
							}

							text_single = {
								text = "HOLDING_COUNTY_HERD"
								min_width = 60
								max_width = 60
								align = left|nobaseline
								default_format = "#high;glow_color:{0.1,0.1,0.1,1.0}"
							}
						}
					}
				}
			}
		}
	}


