######################################################
################# ACCOLADE VIEW ###################
######################################################

window = {
	name = "accolade_view"
	size = { 480 770 }
	parentanchor = top|right
	position = { -630 170 }
	movable = no
	layer = middle
	datacontext = "[AccoladeView.AccessMilitaryView]"

	using = Window_Background_Subwindow

	state = {
		name = _show
		using = Animation_FadeIn_Quick

		position_x = -630
	}

	state = {
		name = _hide
		using = Animation_FadeOut_Quick

		position_x = -570
	}

	vbox = {
		datacontext = "[AccoladeView.GetAccolade]"
		visible = "[Not( AccoladeView.IsShowingHistory)]"
		layoutpolicy_vertical = expanding
		layoutpolicy_horizontal = expanding

		margin = { 5 5 }

		header_pattern = {
			layoutpolicy_horizontal = expanding

			blockoverride "header_text"
			{
				text = "[Accolade.GetNameNoTooltip]"
				visible = "[Not( AccoladeView.IsRenaming )]"
				max_width = 360
			}
			blockoverride "header_text_placement"
			{
				parentanchor = vcenter|left
				position = { 10 -5 }
			}

			editbox_standard = {
				layoutpolicy_horizontal = expanding
				parentanchor = top|left
				size = { 380 30 }
				position = { 10 10 }
				visible = "[AccoladeView.IsRenaming]"

				blockoverride "editbox_properties"
				{
					name = "accolade_name"
					text = "[AccoladeView.GetTempName]"
					ontextedited = "[AccoladeView.EditName]"
					onreturnpressed = "[AccoladeView.SubmitName]"
				}
			}

			blockoverride "button_me"
			{
				texture = "gfx/interface/icons/flat_icons/edit_text.dds"

				tooltip = "RENAME_ACCOLADE"

				visible = "[Not( AccoladeView.IsRenaming )]"
				onclick = "[AccoladeView.ToggleRenaming]"
			}

            blockoverride "button_back" {
				onclick = "[AccoladeView.Close]"
				onclick = "[OpenGameView( 'knights' )]"
				tooltip = "BACK_TOOLTIP"
            }

			blockoverride "button_close"
			{
				onclick = "[AccoladeView.Close]"
				tooltip = "CLOSE_TOOLTIP"
			}

		}

		vbox = {
			layoutpolicy_horizontal = expanding

			background = {
				margin_top = 10
				texture = "gfx/interface/illustrations/event_scenes/armory.dds"
				alpha = 0.6
				using = Mask_Rough_Edges
				fittype = centercrop

				modify_texture = {
					name = "mask"
					texture = "gfx/interface/component_masks/mask_fade_vertical.dds"
					blend_mode = alphamultiply
					mirror = vertical
				}
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				spacing = 10
				margin_left = 10
				margin_right = 10

				background = {
					texture = "gfx/interface/component_tiles/tile_title_bg_01.dds"
					spriteType = Corneredtiled
					spriteborder = { 40 8 }
					texture_density = 2

					modify_texture = {
						name = "mask"
						texture = "gfx/interface/component_masks/mask_fade_horizontal_extended.dds"
						spriteType = Corneredstretched
						spriteborder = { 0 0 }
						blend_mode = alphamultiply
					}
				}

				hbox = {
					icon = {
						texture = "gfx/interface/icons/icon_knight_acclaimed.dds"
						size = { 50 50 }
					}

					text_single = {
						#AGOT Modified
						# text = "[Accolade.GetAcclaimedKnight.GetFullNameNoTooltip]"
						text = "ACCLAIMED_KNIGHT_NAME_DISPLAY"
						align = left|nobaseline
						using = Font_Size_Medium
						max_width = 265
					}
				}

				vbox = {
					layoutpolicy_vertical = expanding
					margin_left = 5
					margin_top = 7
					margin_bottom = 7

					divider_light = {
						layoutpolicy_vertical = expanding
					}
				}

				text_single  = {
					text = "[prowess_i][Accolade.GetAcclaimedKnight.GetSkill( 'prowess' )]"
					align = nobaseline
					default_format = "#high"
					using = Font_Size_Big
					max_width = 100
				}

				expand = {}
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				margin_left = 55
				margin_right = 20

				widget = {
					datacontext = "[Accolade.GetAcclaimedKnight]"
					size = { 190 300 }
					allow_outside = yes

					portrait_body = {
						position = { 0 108 }
						allow_outside = yes

						blockoverride "portrait_texture"
						{
							portrait_texture = "[Character.GetPortrait( 'environment_body', 'camera_body', GetAccoladePose( Accolade.Self ), PdxGetWidgetScreenSize(PdxGuiWidget.Self ) )]"
							size = { 360 420 }
						}

						blockoverride "mask" {
							mask = "gfx/portraits/portrait_mask_council.dds"
						}

						blockoverride "position_portrait_opinion_body" {
							position = { 0 -108 }
						}

						blockoverride "coa" {
							coa_realm_medium_crown = {
								visible = "[Character.HasLandedTitles]"
								parentanchor = left|vcenter
								position = { -45 -13 }
							}
						}

						blockoverride "portrait_icons" {
							portrait_status_icons = {
								parentanchor = bottom|right
								position = { 0 -110 }

								background = {
									using = Background_Area_Dark
									margin = { 3 3 }
									alpha = 0.8
								}
							}
						}
					}
				}

				expand = {}

				vbox = {
					layoutpolicy_vertical = expanding
					margin_top = 15
					allow_outside = yes

					vbox = {
						spacing = 10
						allow_outside = yes

						vbox = {
							datamodel = "[Accolade.GetObtainedAccoladeTypes]"
							spacing = 10
							allow_outside = yes

							item = {

								hbox = {
									layoutpolicy_horizontal = expanding
									allow_outside = yes

									widget = {
										size = { 67 84 }
										allow_outside = yes
										text_label_right = {
											position = { -70 2 }
											parentanchor = top|right
											text = "[ObtainedAccoladeType.GetType.GetNameNoTooltip]"
											multiline = yes
										}
										icon = {
											datacontext = "[ObtainedAccoladeType.GetType.GetMaaUnlock]"
											visible = "[MenAtArmsType.IsValid]"
											texture = "[MenAtArmsType.GetIcon]"
											tooltipwidget = {
												widget_maa_type_container_tooltip = {
													blockoverride "maa_texture"
													{
														texture = "[MenAtArmsType.GetHorizontalImageForCulture( GetPlayer.GetCulture )]"
													}
												}
											}
											size = { 30 30 }
											parentanchor = vcenter|left
											position = { -33 2 }
										}

										icon = {
											parentanchor = center
											size = { 64 80 }
											texture = "[ObtainedAccoladeType.GetType.GetIcon]"
											alwaystransparent = yes
											framesize = { 100 100 }

											tooltipwidget = {
												object_tooltip_pop_out = {
													blockoverride "title_text" {
														margin = { 0 8 }
														datacontext = "[ObtainedAccoladeType.GetType]"
														text = "[AccoladeType.GetName]"
														default_format = "#T"
													}
													blockoverride "concept_link" {
														text = "[accolade_type|E]"
													}
													blockoverride "description_text" {
														text = "OBTAINED_ACCOLADE_TYPE_TT"
													}
												}
											}
										}

										button_round = {
											allow_outside = yes
											parentanchor = top|right
											size = { 30 30 }
											position = { 10 -10 }
											visible = "[And( GreaterThan_int32( Accolade.GetAvailableLevelUpPoints, '(int32)0' ), LessThan_int32( ObtainedAccoladeType.GetLevel, '(int32)3') )]"
											onclick = "[AccoladeView.LevelUpAccoladeType( ObtainedAccoladeType.Self )]"
											tooltipwidget = {
												object_tooltip_pop_out = {
													blockoverride "title_text" {
														margin = { 0 8 }
														datacontext = "[ObtainedAccoladeType.GetType]"
														text = "[AccoladeType.GetName]"
														default_format = "#T"
													}
													blockoverride "concept_link" {
														text = "[accolade_type|E]"
													}
													blockoverride "description_text" {
														text = "UPGRADE_ACCOLADE_TYPE_TT"
													}
												}
											}
											button_select_arrow = {
												parentanchor = center
												size = { 20 20 }
												texture = "gfx/interface/icons/flat_icons/arrow_up.dds"
												alwaystransparent = yes
												state = {
													name = a
													next = b
													alpha = 0.4
													trigger_on_create = yes
													duration = 1.6
													using = Animation_Curve_Default
												}
												state = {
													name = b
													next = a
													alpha = 1
													duration = 0.8
													using = Animation_Curve_Default
												}
											}
										}

										flowcontainer = {
											parentanchor = center
											position = { 0 39 }
											ignoreinvisible = yes
											alwaystransparent = yes

											background = {
												texture = "gfx/interface/component_tiles/tile_title_bg_01.dds"
												spriteType = Corneredtiled
												spriteborder = { 40 8 }
												texture_density = 2
												margin = { 15 1 }

												modify_texture = {
													name = "mask"
													texture = "gfx/interface/component_masks/mask_fade_horizontal_middle_thick.dds"
													spriteType = Corneredstretched
													spriteborder = { 0 0 }
													blend_mode = alphamultiply
												}
											}

											icon_flat_standard_gold = {
												visible = "[GreaterThan_int32( ObtainedAccoladeType.GetLevel, '(int32)0' )]"
												size = { 15 15 }
												texture = "gfx/interface/icons/flat_icons/star.dds"
											}

											icon_flat_standard_gold = {
												visible = "[GreaterThan_int32( ObtainedAccoladeType.GetLevel, '(int32)1' )]"
												size = { 15 15 }
												texture = "gfx/interface/icons/flat_icons/star.dds"
											}

											icon_flat_standard_gold = {
												visible = "[GreaterThan_int32( ObtainedAccoladeType.GetLevel, '(int32)2' )]"
												size = { 15 15 }
												texture = "gfx/interface/icons/flat_icons/star.dds"
											}

											icon_flat_standard_ash = {
												visible = "[Not( GreaterThan_int32( ObtainedAccoladeType.GetLevel, '(int32)1' ) )]"
												size = { 15 15 }
												texture = "gfx/interface/icons/flat_icons/star.dds"
												modify_texture = {
													color = { 0 0 0 1 }
													blend_mode = multiply
													alpha = 0.4
												}
											}

											icon_flat_standard_ash = {
												visible = "[Not( GreaterThan_int32( ObtainedAccoladeType.GetLevel, '(int32)2' ) )]"
												size = { 15 15 }
												texture = "gfx/interface/icons/flat_icons/star.dds"
												modify_texture = {
													color = { 0 0 0 1 }
													blend_mode = multiply
													alpha = 0.4
												}
											}
										}
									}
								}
							}
						}

						hbox = {
							layoutpolicy_horizontal = expanding

							expand = {}

							# Add new Type
							button_standard = {
								visible = "[And( LessThan_int32(GetDataModelSize(Accolade.GetObtainedAccoladeTypes), GetDefine( 'NAccolade', 'ACCOLADE_MAX_TYPES') ), Or( And( GreaterThan_int32(Accolade.GetAvailableLevelUpPoints, '(int32)0'), GreaterThan_int32( Accolade.GetCurrentRankNumber, '(int32)5' ) ), GreaterThan_int32( Subtract_int32( Accolade.GetAvailableLevelUpPoints,  Accolade.GetCurrentRankNumber ), '(int32)-6') ) ) ]"
								size = { 67 84 }
								datacontext = "[Accolade]"
								tooltip = "ACCOLADE_ADD_NEW_TYPE_TT"
								onclick = "[AccoladeView.OpenAttributeSelectorWindow]"

								button_icon = {
									parentanchor = center
									size = { 40 40 }
									texture = "gfx/interface/icons/flat_icons/plus.dds"
									alwaystransparent = yes
								}
							}
						}
					}

					expand = {}
				}

				vbox = {
					visible = "[AccoladeView.HasAnyRelevantTraits]"
					spacing = 5

					background = {
						using = Background_Area_Dark
						alpha = 0.6
						margin = { 5 -5 }
					}

					vbox = {
						layoutpolicy_horizontal = expanding
						margin_top = 10
						spacing = 10

						datamodel = "[AccoladeView.GetTraits]"

						item = {
							icon_trait = {
								datacontext = "[Accolade.GetAcclaimedKnight]"

								blockoverride "faith_context"
								{
									datacontext = "[Accolade.GetAcclaimedKnight.GetFaith]"
								}
								blockoverride "icon_size"
								{
									size = { 55 55 }
								}
							}
						}
					}

					expand = {}
				}
			}

			vbox = {
				layoutpolicy_horizontal = expanding
				margin = { 20 10 }

				background = {
					using = Background_Area_Dark
					alpha = 0.8
				}

				hbox = {
					layoutpolicy_horizontal = expanding

					text_single  = {
						text = "ACCOLADE_GLORY_AND_LEVEL"
						max_width = 200
					}

					expand = {}

					text_single  = {
						visible = "[Or( And( GreaterThan_int32( Accolade.GetCurrentRankNumber, '(int32)5' ), LessThan_int32(Accolade.GetAvailableLevelUpPoints, '(int32)0') ), LessThan_int32( Subtract_int32( Accolade.GetAvailableLevelUpPoints,  Accolade.GetCurrentRankNumber ), '(int32)-5') ) ]"
						text = "ACCOLADE_MAX_POINTS"
						max_width = 220
					}
					text_single  = {
						visible = "[Or( And( GreaterThan_int32(Accolade.GetAvailableLevelUpPoints, '(int32)0'), GreaterThan_int32( Accolade.GetCurrentRankNumber, '(int32)5' ) ), GreaterThan_int32( Subtract_int32( Accolade.GetAvailableLevelUpPoints,  Accolade.GetCurrentRankNumber ), '(int32)-6') ) ]"
						text = "ACCOLADE_UNSPENT_POINTS"
						max_width = 220
					}
				}

				hbox = {
					margin = { 0 20 }
					allow_outside = yes

					widget = {
						size = { 400 20 }
						allow_outside = yes

						datacontext = "[AccoladeView.GetProgressBar]"

						hbox_complex_bar_progress = {
							layoutpolicy_horizontal = expanding
						}

						hbox_complex_bar_progress_next = {
							layoutpolicy_horizontal = expanding
						}

						hbox_complex_bar_levels = {
							layoutpolicy_horizontal = expanding

							blockoverride "marker" {
								icon = {
									name = "rank_icon"
									parentanchor = center
									widgetanchor = center
									allow_outside = yes
									size = { 44 44 }

									texture = "[Accolade.GetComplexBarRankIcon( ComplexBar.GetIndexOfItem( ComplexBarItem.Self ) )]"
									tooltip = "[Accolade.GetComplexBarRankTooltip( ComplexBar.GetIndexOfItem( ComplexBarItem.Self ) )]"
								}
								text_single = {
									parentanchor = center
									position = { 0 -2 }
									raw_text = "[Add_int32( ComplexBar.GetIndexOfItem( ComplexBarItem.Self ), '(int32)1' )]"
									default_format = "#medium"
								}
							}
						}
					}
				}
			}
		}

		vbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			margin_top = 10
			spacing = 5

			background = {
				using = Background_Area_Dark
			}

			background = {
				texture = "[Accolade.GetOwner.GetCulture.GetGraphicalUnitType.GetAccoladesBigIllustration]"
				fittype = centercrop
				using = Mask_Rough_Edges
				alpha = 0.7

				modify_texture = {
					texture = "gfx/interface/component_masks/mask_holding_illustration.dds"
					blend_mode = alphamultiply
					alpha = 0.95
				}
			}

			text_single = {
				text = "ACCOLADE_SQUIRE_STATUS"
				default_format = "#medium;glow_color:{0,0,0,1}"
				margin_bottom = 5
				max_width = 450
				using = Font_Size_Medium
				align = center

				tooltip = "[AccoladeView.GetAccoladeSquireQualityBreakdown]"

				background = {
					margin = { 70 0 }

					texture = "gfx/interface/component_tiles/tile_title_bg_01.dds"
					spriteType = Corneredtiled
					spriteborder = { 40 8 }
					texture_density = 2

					modify_texture = {
						name = "mask"
						texture = "gfx/interface/component_masks/mask_fade_horizontal_middle_thick.dds"
						spriteType = Corneredstretched
						spriteborder = { 0 0 }
						blend_mode = alphamultiply
					}
				}
			}

			expand = {}
		}
		hbox = {
			layoutpolicy_horizontal = expanding

			margin = { 0 15 }
			spacing = 15

			expand = {}
			datacontext = "[AccoladeView.GetAccolade]"

			button_standard = {
				size = { 200 32 }
				text = "ACCOLADE_HISTORY"
				tooltip = "SHOW_ACCOLADE_HISTORY"
				onclick = "[AccoladeView.ToggleHistory]"
			}

			button_standard = {
				size = { 200 32 }
				text = "RETIRE_ACCOLADE"
				tooltip = "RETIRE_ACCOLADE_TT"
				onclick = "[Accolade.DestroyAccolade]"
			}

			expand = {}
		}
	}

	vbox = {
		datacontext = "[AccoladeView.GetAccolade]"
		visible = "[AccoladeView.IsShowingHistory]"

		margin = { 4 4 }
		spacing = 5

		header_pattern = {
			layoutpolicy_horizontal = expanding

			blockoverride "header_text"
			{
				text = "ACCOLADE_HISTORY"
			}

			blockoverride "button_close"
			{
				onclick = "[AccoladeView.ToggleHistory]"
				texture = "gfx/interface/icons/flat_icons/window_back.dds"
				tooltip = "BACK_TOOLTIP"
			}
		}

		scrollbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			blockoverride "scrollbox_content" {
				vbox = {
					name = "accolade_history_entries"
					datamodel = "[Accolade.GetHistory]"
					layoutpolicy_horizontal = expanding
					spacing = 10

					item = {
						hbox = {
							datacontext = "[AccoladeHistoryEntry.GetAcclaimedKnight]"
							layoutpolicy_horizontal = expanding

							vbox = {
								layoutpolicy_horizontal = expanding
								spacing = 10
								margin = { 0 0 }

								hbox = {
									layoutpolicy_horizontal = expanding
									layoutpolicy_vertical = expanding
									spacing = 10

									portrait_head = {}

									vbox = {
										layoutpolicy_horizontal = expanding
										layoutpolicy_vertical = expanding
										spacing = 10

										hbox = {
											layoutpolicy_horizontal = expanding
											spacing = 10

											background = {
												texture = "gfx/interface/component_tiles/tile_title_bg_01.dds"
												spriteType = Corneredtiled
												spriteborder = { 40 8 }
												texture_density = 2

												modify_texture = {
													name = "mask"
													texture = "gfx/interface/component_masks/mask_fade_horizontal_extended.dds"
													spriteType = Corneredstretched
													spriteborder = { 0 0 }
													blend_mode = alphamultiply
												}
											}

											widget = {
												size = { 30 50 }

												icon = {
													parentanchor = center
													texture = "gfx/interface/icons/icon_knight_acclaimed.dds"
													size = { 50 50 }
												}
											}

											text_single = {
												text = "[Character.GetNameNoTooltip]"
												align = nobaseline
												using = Font_Size_Medium
												max_width = 185
											}

											expand = {}

											text_single  = {
												text = "[prowess_i][Character.GetSkill( 'prowess' )]"
												align = nobaseline
												default_format = "#high"
												using = Font_Size_Big
											}
										}

										text_multi = {
											layoutpolicy_horizontal = expanding
											text = "ACCOLADE_HISTORY_ENTRY_DATE"
											autoresize = yes
											max_width = 280
										}

										expand = {}
									}
								}

								divider = {
									layoutpolicy_horizontal = expanding
								}
							}
						}
					}
				}
			}
		}
	}
}

types AccoladeWindowTypes
{
	type accolade_type_box = hbox {
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = expanding
		spacing = 8

		vbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			text_single = {
				layoutpolicy_horizontal = expanding

				block "name_text"
				{
					text = "[AccoladeType.GetName]"
				}

				align = nobaseline
			}

			text_single = {
				margin_left = 8
				layoutpolicy_horizontal = expanding

				block "subtitle_text"
				{
					text = ""
				}

				default_format = "#low"
				align = nobaseline
				max_width = 290
			}
		}

		block "icons" {}

		block "change_button" {}
	}

	type accolade_banner = icon {
		parentanchor = center
		size = { 98 103 } # not same aspect ratio as texture but not noticable
		alwaystransparent = yes
		texture = "gfx/interface/icons/knight_badge/frame/accolade_frame.dds"

		modify_texture = {
			texture = "gfx/interface/component_masks/mask_fade_horizontal_middle.dds"
			blend_mode = overlay
			alpha = 0.15
		}
	}

	type accolade_banner_dark = icon {
		parentanchor = center
		size = { 98 103 } # not same aspect ratio as texture but not noticable
		alwaystransparent = yes
		texture = "gfx/interface/icons/knight_badge/frame/accolade_frame.dds"
		alpha = 0.3
	}

	type accolade_banner_broken = icon {
		parentanchor = center
		size = { 98 103 } # not same aspect ratio as texture but not noticable
		alwaystransparent = yes
		texture = "gfx/interface/icons/knight_badge/frame/accolade_frame.dds"
		enabled = no
	}

	type accolade_rank_icon = icon {
		parentanchor = bottom|hcenter
		size = { 44 44 }

		icon = {
			position = { 1 13 }
			size = { 100% 100% }
			visible = "[Accolade.HasActiveEffects]"
			texture = "[Accolade.GetCurrentRankIcon]"
			tooltipwidget = accolade_tooltip
		}
	}
}

