######################################################
################# KNIGHTS VIEW ###################
######################################################

window = {
	datacontext = "[KnightsView.GetMilitaryView]"
	name = "knight_view"
	size = { 540 92% }
	parentanchor = top|right
	position = { -626 45 }
	movable = no
	layer = middle
	allow_outside = yes

	using = Window_Background_Subwindow

	state = {
		name = _show
		using = Animation_FadeIn_Quick

		position = { -626 45 }
	}

	state = {
		name = _hide
		using = Animation_FadeOut_Quick
		on_finish = "[GetVariableSystem.Clear('knight_permissions')]"

		position_x = -570
	}

	vbox = {
		margin = { 4 4 }
		spacing = 2

		header_pattern = {
			layoutpolicy_horizontal = expanding

			blockoverride "header_text"
			{
				datacontext = "[MilitaryView.GetCharacter]"
				text = "[SelectLocalization( And( HasDlcFeature( 'accolades' ), GreaterThan_int32( Character.GetNumAccoladeSlots, '(int32)0' ) ), 'KV_HEADER_ACCOLADES', 'KV_HEADER' )]"
			}

			blockoverride "button_close"
			{
				onclick = "[KnightsView.Close]"
			}
		}

		# ACCOLADES ----------------------------------------------------------------------------
		vbox = {
			datacontext = "[MilitaryView.GetCharacter]"
			visible = "[HasDlcFeature( 'accolades' )]"
			background = {
				using = Background_Area_ExtraDark
				alpha = 0.3
				margin = { 5 0 }
				margin_top = 10
			}

			text_label_center = {
				name = "accolades_limit"

				text = "ACCOLADES_LIMIT"
				default_format = "#low"

				tooltip = "ACCOLADES_LIMIT_TT"
			}

			hbox = {
				name = "accolades_box"
				visible = "[GreaterThan_int32( Character.GetNumAccoladeSlots, '(int32)0' )]"
				layoutpolicy_horizontal = expanding

				margin_bottom = 15
				spacing = 5

				background = {
					using = Background_Area_Dark
					margin_top = -26
					margin_bottom = -36

					modify_texture = {
						texture = "gfx/interface/component_masks/mask_fade_horizontal_middle_thick.dds"
						blend_mode = alphamultiply
					}
				}

				background = {
					using = Background_Frame
					margin_top = -33
					margin_bottom = -41

					modify_texture = {
						texture = "gfx/interface/component_masks/mask_fade_horizontal_middle.dds"
						blend_mode = alphamultiply
					}
				}

				expand = {}

				hbox = {
					name = "active_accolades"
					datamodel = "[Character.GetAccolades]"
					spacing = 5
					allow_outside = yes

					item = {
						widget = {
							size = { 98 103 }
							allow_outside = yes

							portrait_head_small = {
								parentanchor = center
								datacontext = "[Accolade.GetAcclaimedKnight]"

								tooltip = "MANAGE_ACCOLADE_NAME"
								using = tooltip_se

								blockoverride "portrait_button"
								{
									onclick = "[OpenGameViewData( 'accolade_view', Accolade.GetID )]"
									onclick = "[KnightsView.Close]"
								}

								blockoverride "portrait_button_template_onclick" {}
								blockoverride "opinion_box" {}
								selection_glow = {
									visible = "[GreaterThan_int32(Accolade.GetAvailableLevelUpPoints, '(int32)0')]"
									tooltip = "MANAGE_ACCOLADE_UPGRADE"
								}
							}

							accolade_banner = {
								parentanchor = center
								position = { 0 1 }
							}

							accolade_rank_icon = {
								position = { 0 2 }
								size = { 40 40 }
								allow_outside = yes

								text_single = {
									parentanchor = center
									position = { 1 11 }
									text = "[Accolade.GetCurrentRankNumber]"
								}
							}
						}
					}
				}

				hbox = {
					name = "other_accolade_slots"
					datamodel = "[GetNullCharacterDataModel( Subtract_int32( GetDefine('NGui', 'KNIGHTS_VIEW_NUM_ACCOLADES'), MilitaryView.GetCharacter.GetNumAccolades ) )]"
					spacing = 5

					item = {
						widget = {
							enabled = "[LessThan_int32( PdxGuiWidget.GetIndexInDataModel, MilitaryView.GetCharacter.GetNumFreeAccoladeSlots )]"

							size = { 98 103 }

							background = {
								using = Background_Area_Solid
								margin = { -5 -5 }
							}

							widget = {
								size = {100% 100%}
								name = "available_accolade_tutorial_uses_this"

								visible = "[And( MilitaryView.GetCharacter.HasFreeAccoladeSlots, KnightsView.HasCachedPotentialAcclaimedKnights )]"
							}

							widget = {
								parentanchor = center
								size = { 85 90 }
								tooltip = "[SelectLocalization( LessThan_int32( PdxGuiWidget.GetIndexInDataModel, MilitaryView.GetCharacter.GetNumFreeAccoladeSlots ), KnightsView.GetAccoladeSlotTooltip( MilitaryView.GetCharacter.Self ), 'LOCKED_ACCOLADE_SLOT' )]"
								using = tooltip_se

								widget = {
									size = { 100% 100% }

									background = {
										texture = "gfx/portraits/portrait_frame.dds"
										using = Color_Grey
										margin = { -4 -4 }
										alpha = 0.5
									}
								}

								button = {
									size = { 100% 100% }

									onclick = "[OpenGameViewData( 'create_accolade_view', MilitaryView.GetCharacter.GetID )]"
									onclick = "[KnightsView.Close]"

									state = {
										name = _mouse_hierarchy_enter
										on_start = "[PdxGuiWidget.FindChild('highlight_frame').TriggerAnimation('show')]"

									}

									state = {
										name = _mouse_hierarchy_leave
										on_start = "[PdxGuiWidget.FindChild('highlight_frame').TriggerAnimation('hide')]"

									}

									highlight_icon = {
										name = "portrait_unknown_head_glow"
										parentanchor = center
										position = { 3 -7 }
										gfxtype = framedbuttongfx
										effectname = "NoHighlight"
										texture = "gfx/portraits/unknown_portraits/button_unknown_head.dds"
										size = { 78 105 }
										framesize = { 384 480 }
										upframe = 1
										overframe = 2
									}


									button_plus = {
										parentanchor = center
										position = { 0 0 }
										alwaystransparent = yes

										visible = "[LessThan_int32( PdxGuiWidget.GetIndexInDataModel, MilitaryView.GetCharacter.GetNumFreeAccoladeSlots )]"
									}

									widget = {
										name = "highlight_frame"
										size = { 100% 100% }
										alwaystransparent = yes
										alpha = 0

										state = {
											name = "show"
											alpha = 1
										}

										state = {
											name = "hide"
											alpha = 0
										}

										background = {
											size = { 100% 100% }
											texture = "gfx/portraits/portrait_frame.dds"
											using = Color_Grey
											alpha = 0.7
											margin = { -4 -4 }
										}
									}
								}
							}

							accolade_banner = {
								visible = "[LessThan_int32( PdxGuiWidget.GetIndexInDataModel, MilitaryView.GetCharacter.GetNumFreeAccoladeSlots )]"
								position = { 0 1 }
							}

							accolade_banner_broken = {
								visible = "[GreaterThanOrEqualTo_int32( PdxGuiWidget.GetIndexInDataModel, MilitaryView.GetCharacter.GetNumFreeAccoladeSlots )]"
								position = { 0 1 }
							}
						}
					}
				}

				expand = {}
			}
			text_multi = {
				size = { 500 70 }
				margin = { 5 10 }
				text = LOCKED_ACCOLADE_SLOT_INFO
				default_format = "#tut"
				visible = "[LessThan_int32( Character.GetNumAccoladeSlots, '(int32)1' )]"
			}
		}

		# KNIGHTS ----------------------------------------------------------------------------
		vbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			spacing = 5

			hbox = {
				layoutpolicy_horizontal = expanding
				margin = { 10 5 }

				text_label_center = {
					name = "knights_cap"
					text = "MAX_KNIGHT_COUNT"
					tooltip = "MAX_KNIGHT_TOOLTIP"
					default_format = "#low"
				}

				text_label_center = {
					name = "knights_effectiveness"

					text = "KNIGHT_EFFECTIVENESS"
					tooltip = "KNIGHT_EFFECTIVENESS_TOOLTIP"
					default_format = "#low"
				}
			}

			vbox = {
				name = "decision_buttons"
				margin_top = 5
				margin_bottom = 10
				spacing = 5

				button_decision_entry = {
					name = "invite_knights_decision"
					datacontext = "[GetDecisionWithKey('invite_knights_decision')]"
					visible = "[Decision.IsShownForPlayer]"
					onclick = "[OpenGameViewData( 'decision_detail', Decision.Self )]"
				}

				button_decision_entry = {
					name = "invite_from_nomad_capital"
					datacontext = "[GetDecisionWithKey('recruit_from_nomadic_capital_decision')]"
					visible = "[Decision.IsShownForPlayer]"
					onclick = "[OpenGameViewData( 'decision_detail', Decision.Self )]"

					background = {
						using = Background_Area_Dark
						blend_mode = multiply

						modify_texture = {
							texture = "gfx/interface/component_masks/mask_fade_horizontal_thick.dds"
							blend_mode = alphamultiply
						}
					}

					blockoverride "icon_alpha" {
						alpha = 0.3
					}
				}
			}
			
			hbox = {
				layoutpolicy_horizontal = expanding
				margin = { 10 0 }
				spacing = 5
				
				button = {
					shortcut = "knight_permissions"
					onclick = "[GetVariableSystem.Toggle('knight_permissions')]"
					enabled = "[GetPlayer.IsValid]"
					tooltip = "KNIGHT_PERMISSIONS_TT"
					
					flowcontainer = {
						spacing = 5
						resizeparent = yes
						parentanchor = bottom
						ignoreinvisible = yes
						
						background = {
							using = Background_Area_Dark
							alpha = 0.6
							margin_left = 5
							margin_right = 40
							
							modify_texture = {
								texture = "gfx/interface/component_masks/mask_fade_horizontal_extended.dds"
								blend_mode = alphamultiply
							}
						}
						
						button_icon = {
							texture = "gfx/interface/icons/flat_icons/knight.dds"
							down = "[And(GetVariableSystem.Exists('knight_permissions'), GetPlayer.IsValid)]"
							alwaystransparent = yes
						}
						
						text_single = {
							visible = "[Not( KnightsView.GetKnightPermissions.IsDefault )]"
							raw_text = "@warning_icon!"
							margin_left = -4
							margin_top = 2
						}
						
						text_single = {
							default_format = "#clickable"
							text = "KNIGHT_PERMISSIONS_SHORT"
							min_height = 25
							max_width = 180
							margin_top = 5
							align = nobaseline
						}						
					}
				}
				
				expand = {}
				
				text_label_center = {
					text = "[MilitaryView.GetCharacter.Custom('GetValidKnightsHeader')]"
					max_width = 220
					min_height = 25
				}
				
				hbox = {
					margin_right = 5
					margin_bottom = 5 # text_label has it
					
					text_single = {
						min_width = 25 # so it doesn't shift around
						max_width = 35
						align = right
						text = "[GetDataModelSize(MilitaryView.GetKnights)]"
					}
				}				
			}

			scrollbox = {
				name = "knights"
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding

				blockoverride "scrollbox_content" {
					fixedgridbox = {
						name = "knights"
						datamodel = "[MilitaryView.GetKnights]"

						addcolumn = 500
						addrow = 136
						datamodel_reuse_widgets = yes

						item = {
							widget = {
								layoutpolicy_horizontal = expanding
								size = { 495 130 }

								using = Background_Guest

								blockoverride "Background_Guest_pattern_visible"
								{
									visible = "[Character.IsGuest]"
									alpha = 0.5

									margin_bottom = -9
									margin_right = 5
								}

								blockoverride "Background_Guest_frame_visible"
								{
									visible = "[Character.IsGuest]"
									alpha = 0.8

									margin_left = 3
									margin_bottom = -7
									margin_top = 1
									margin_right = 5
								}

								vbox = {
									spacing = 7

									hbox = {
										layoutpolicy_horizontal = expanding
										layoutpolicy_vertical = expanding
										margin_right = 5
										spacing = 10

										portrait_head = {
											alpha = "[Select_float( Character.IsKnight, '(float)1.0', '(float)0.6' )]"
										}

										vbox = {
											layoutpolicy_vertical = expanding
											layoutpolicy_horizontal = expanding

											hbox = {
												layoutpolicy_horizontal = expanding
												margin = { 0 5 }

												background = {
													using = Background_Area_Dark
													alpha = 0.7
													margin_left = 16
													margin_right = 10

													modify_texture = {
														texture = "gfx/interface/component_masks/mask_fade_horizontal_extended.dds"
														blend_mode = alphamultiply
													}
												}

												hbox = {
													layoutpolicy_horizontal = expanding
													layoutpolicy_vertical = expanding
													spacing = 10

													widget = {
														visible = "[Or(Character.IsAcclaimedKnight, Character.IsKnight)]"
														size = { 30 30 }

														icon = {
															visible = "[And(Character.IsKnight, Not(Character.IsAcclaimedKnight) )]"
															parentanchor = center
															texture = "gfx/interface/icons/icon_knight_small.dds"
															size = { 40 40 }
														}

														icon = {
															visible = "[Character.IsAcclaimedKnight]"
															parentanchor = center
															texture = "gfx/interface/icons/icon_knight_acclaimed.dds"
															size = { 50 50 }
														}
													}

													vbox = {
														layoutpolicy_horizontal = expanding
														layoutpolicy_vertical = expanding

														text_single = {
															layoutpolicy_horizontal = expanding
															#AGOT Modified
															# text = "[Character.GetNameNoTooltip]"
															raw_text = "[AGOTGetNameNoTooltip(Character)]"
															using = Font_Size_Medium
															autoresize = no
														}

														text_single = {
															layoutpolicy_horizontal = expanding
															text = "[Character.GetRelationToString( GetPlayer )]"
															tooltip = "EXTENDED_RELATIONS_TOOLTIP"
															default_format = "#low"
															autoresize = no
															align = nobaseline
														}

														expand = {}
													}
												}

												vbox = {
													margin_right = 5

													text_single = {
														text = "[prowess_i][Character.GetSkill( 'prowess' )]"
														align = nobaseline
														default_format = "#high"
														using = Font_Size_Big
													}
												}
											}

											expand = {}

											hbox = {
												visible = "[Not(Character.IsGuest)]"
												layoutpolicy_horizontal = expanding
												spacing = 5

												button_standard = {
													layoutpolicy_horizontal = expanding
													size = { 90 33 }
													onclick = "[MilitaryView.SetKnightForced( Character.Self )]"
													down = "[Character.IsKnightForced]"
													alwaystransparent = "[Character.IsKnightForced]"

													text = "KNIGHTS_VIEW_FORCE"

													tooltip = "KNIGHTS_VIEW_TITLE_FORCE_TT"
													using = tooltip_se
												}

												button_standard = {
													layoutpolicy_horizontal = expanding
													size = { 90 33 }
													onclick = "[MilitaryView.SetKnightDefault( Character.Self )]"
													down = "[Character.IsKnightDefault]"
													alwaystransparent = "[Character.IsKnightDefault]"

													text = "KNIGHTS_VIEW_ALLOW"

													tooltip = "KNIGHTS_VIEW_TITLE_BY_PROWESS_TT"
													using = tooltip_se
												}

												button_standard = {
													layoutpolicy_horizontal = expanding
													size = { 90 33 }
													onclick = "[MilitaryView.SetKnightDisallowed( Character.Self )]"
													down = "[Character.IsKnightDisallowed]"
													alwaystransparent = "[Character.IsKnightDisallowed]"
													enabled = "[Not( Character.IsAcclaimedKnight )]"


													text = "KNIGHTS_VIEW_FORBID"
													tooltip = "[SelectLocalization( Character.IsAcclaimedKnight, 'CANNOT_FORBID_ACCLAIMED_KNIGHT', 'KNIGHTS_VIEW_TITLE_FORBID_TT' )]"
													using = tooltip_se
												}

												expand = {}
											}

											hbox = {
												visible = "[Character.IsGuest]"
												layoutpolicy_horizontal = expanding
												spacing = 10

												button_standard = {
													visible = "[Character.IsPlayerInteractionShown('recruit_guest_interaction')]"
													enabled = "[Character.IsPlayerInteractionValid('recruit_guest_interaction')]"
													onclick = "[Character.OpenPlayerInteraction('recruit_guest_interaction')]"
													text = "[Character.GetPlayerInteractionName('recruit_guest_interaction')]"
													tooltip = "[Character.GetPlayerInteractionTooltip('recruit_guest_interaction')]"
													using = tooltip_se
												}

												expand = {}
											}

											expand = {}
										}


									}

									divider = {
										layoutpolicy_horizontal = expanding
										texture = "gfx/interface/colors/gold_darker.dds"
									}
								}
							}
						}
					}
				}
			}
		}

		expand = {}
	}
	
	@label = 130
	
	window = {
		name = "knight_permissions"
		size = { 420 740 }
		using = Window_Background_Subwindow
		parentanchor = right|bottom
		position = { -540 0 }
		
		visible = "[And(GetVariableSystem.Exists('knight_permissions'), GetPlayer.IsValid)]"
	
		state = {
			name = _show
			using = Animation_FadeIn_Quick
	
			position = { -540 0 }
		}
	
		state = {
			name = _hide
			using = Animation_FadeOut_Quick
	
			position_x = -550
		}
		
		vbox = {
			layoutpolicy_horizontal = expanding
			margin = { 4 4 }
			
			header_pattern = {
				layoutpolicy_horizontal = expanding
				
				blockoverride "header_text"
				{
					text = "KNIGHT_PERMISSIONS_TITLE"
					margin = { 30 0 }
				}
				
				blockoverride "button_close"
				{
					onclick = "[GetVariableSystem.Clear('knight_permissions')]"
				}
			}
			
			scrollbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				blockoverride "scrollbox_background" {}
				blockoverride "scrollbox_background_fade" {}
				blockoverride "scrollbox_margins" {
					margin = { 15 0 }
					margin_bottom = 5
				}
				
				blockoverride "scrollbox_content" {
					spacing = 10
					
					text_multi = {
						layoutpolicy_horizontal = expanding
						margin = { 0 10 }
						max_height = -1
						autoresize = yes
						max_width = 380
						text = "YOUR_KNIGHT_PERMISSIONS"
						default_format = "#weak"
					}
					
					widget_permission_header = {
						blockoverride "text" {
							text = "MINIMUM_PROWESS"
							max_width = 250
						}
						blockoverride "extra" {
							hbox = {
								spacing = 5
								
								button_round = {
									size = { 28 28 }
									button_ignore = none
									onclick = "[KnightsView.GetKnightPermissions.AdjustMinProwess( '(int32)-1' )]"
									onrightclick = "[KnightsView.GetKnightPermissions.AdjustMinProwess( '(int32)-10' )]"
									tooltip = "DECREASE_MIN_PROWESS_KP"
									using = tooltip_es
									tooltip_offset = { 0 30 }
									enabled = "[NotZero(KnightsView.GetKnightPermissions.GetMinProwess)]"

									button_minus_small = {
										name = "decrease_skill"
										parentanchor = center
										alwaystransparent = yes
									}
								}

								text_single = {
									text = "[KnightsView.GetKnightPermissions.GetMinProwess]"
									using = Font_Size_Medium
									default_format = "#high"
									align = nobaseline|center
									min_width = 25
								}

								button_round = {
									size = { 28 28 }
									button_ignore = none
									onclick = "[KnightsView.GetKnightPermissions.AdjustMinProwess( '(int32)1' )]"
									onrightclick = "[KnightsView.GetKnightPermissions.AdjustMinProwess( '(int32)10' )]"
									tooltip = "INCREASE_MIN_PROWESS_KP"
									using = tooltip_es
									tooltip_offset = { 0 30 }

									button_plus_small = {
										name = "increase_skill"
										parentanchor = center
										alwaystransparent = yes
									}
								}
							}
						}
					}
									
					text_multi = {
						layoutpolicy_horizontal = expanding
						text = "KP_CULTURE_MINIMUM_PROWESS"
						autoresize = yes
						max_width = 380
						visible = "[GetScriptedGui('kp_culture_minimum_prowess').IsShown( GuiScope.SetRoot( GetPlayer.GetCulture.MakeScope ).End )]"
					}
					
					text_multi = {
						layoutpolicy_horizontal = expanding
						text = "KP_CULTURE_HIGH_PROWESS"
						autoresize = yes
						max_width = 380
						visible = "[GetScriptedGui('kp_culture_high_prowess').IsShown( GuiScope.SetRoot( GetPlayer.GetCulture.MakeScope ).End )]"
					}
					
					widget_permission_header = {
						blockoverride "text" {
							text = "DYNASTY_HOUSE"
							max_width = 130
						}
						blockoverride "extra" {
							dropdown_menu_standard = {
								blockoverride "dropdown_properties"
								{
									datamodel = "[KnightsView.GetHouseFilterOptions]"
									onselectionchanged = "[KnightsView.GetKnightPermissions.SetHouseFilterIndex]"
									selectedindex = "[KnightsView.GetKnightPermissions.GetHouseFilterIndex]"
								}

								blockoverride "dropdown_active_item_properties"
								{
									text = "[KnightPermissionHouseFilterOption.GetName]"
									tooltip = "[KnightPermissionHouseFilterOption.GetDescription]"
									using = tooltip_se
								}

								blockoverride "dropdown_item_properties"
								{
									text = "[KnightPermissionHouseFilterOption.GetName]"
									tooltip = "[KnightPermissionHouseFilterOption.GetDescription]"
									using = tooltip_se
								}
							}
						}
					}
					
					widget_permission_header = {
						blockoverride "text" {
							text = "game_concept_vassals"
							max_width = 130
						}
						blockoverride "extra" {
							dropdown_menu_standard = {
								blockoverride "dropdown_properties"
								{
									datamodel = "[KnightsView.GetVassalFilterOptions]"
									onselectionchanged = "[KnightsView.GetKnightPermissions.SetVassalFilterIndex]"
									selectedindex = "[KnightsView.GetKnightPermissions.GetVassalFilterIndex]"
								}

								blockoverride "dropdown_active_item_properties"
								{
									text = "[KnightPermissionVassalFilterOption.GetName]"
									tooltip = "[KnightPermissionVassalFilterOption.GetDescription]"
									using = tooltip_se
								}

								blockoverride "dropdown_item_properties"
								{
									text = "[KnightPermissionVassalFilterOption.GetName]"
									tooltip = "[KnightPermissionVassalFilterOption.GetDescription]"
									using = tooltip_se
								}
							}
						}
					}
					
					widget_permission_header = {
						blockoverride "text" {
							text = "FAMILY_RELATIONS_KP"
						}
					}
					
					vbox = {
						layoutpolicy_horizontal = expanding
						spacing = 5
						margin_bottom = -5
						
						vbox = {
							layoutpolicy_horizontal = expanding
							spacing = 5
							
							hbox = {
								layoutpolicy_horizontal = expanding
								spacing = 15
								
								button_checkbox_label = {
									layoutpolicy_horizontal = expanding
									onclick = "[KnightsView.GetKnightPermissions.ToggleAllowPlayerHeir]"
									blockoverride "checkbox" {
										checked = "[KnightsView.GetKnightPermissions.GetAllowPlayerHeir]"
									}
									blockoverride "text" {
										text = "game_concept_player_heir"
										max_width = @label
										min_width = @label
									}
								}
								
								button_checkbox_label = {
									layoutpolicy_horizontal = expanding
									onclick = "[KnightsView.GetKnightPermissions.ToggleAllowSpouses]"
									blockoverride "checkbox" {
										checked = "[KnightsView.GetKnightPermissions.GetAllowSpouses]"
									}
									blockoverride "text" {
										text = "SPOUSES"
										max_width = @label
										min_width = @label
									}
								}
							}
							
							hbox = {
								layoutpolicy_horizontal = expanding
								spacing = 15
								
								button_checkbox_label = {
									layoutpolicy_horizontal = expanding
									onclick = "[KnightsView.GetKnightPermissions.ToggleAllowOtherChildren]"
									blockoverride "checkbox" {
										checked = "[KnightsView.GetKnightPermissions.GetAllowOtherChildren]"
									}
									blockoverride "text" {
										text = "OTHER_CHILDERN_KP"
										max_width = @label
										min_width = @label
									}
								}
								
								button_checkbox_label = {
									layoutpolicy_horizontal = expanding
									onclick = "[KnightsView.GetKnightPermissions.ToggleAllowConcubines]"
									blockoverride "checkbox" {
										checked = "[KnightsView.GetKnightPermissions.GetAllowConcubines]"
									}
									blockoverride "text" {
										text = "game_concept_concubines"
										max_width = @label
										min_width = @label
									}
								}
							}
							
							hbox = {
								layoutpolicy_horizontal = expanding
								spacing = 15
								
								button_checkbox_label = {
									layoutpolicy_horizontal = expanding
									onclick = "[KnightsView.GetKnightPermissions.ToggleAllowSpousesOfChildren]"
									blockoverride "checkbox" {
										checked = "[KnightsView.GetKnightPermissions.GetAllowSpousesOfChildren]"
									}
									blockoverride "text" {
										text = "SPOUSES_OF_CHILDERN_KP"
										max_width = 300
									}
								}
								
								#TODO CTD on toggling the filter on!
								button_checkbox_label = {
									visible = no
									layoutpolicy_horizontal = expanding
									onclick = "[KnightsView.GetKnightPermissions.ToggleAllowLovers]"
									blockoverride "checkbox" {
										checked = "[KnightsView.GetKnightPermissions.GetAllowLovers]"
									}
									blockoverride "text" {
										text = "LOVERS_LABEL"
										max_width = @label
										min_width = @label
									}
								}
								
								expand = {}
							}
						}
						
						# culture
						hbox = {
							layoutpolicy_horizontal = expanding
						
							hbox = {
								name = "martial"
								datacontext = "[GetPlayer.GetCulture]"
								datacontext = "[Culture.GetMartial]"
								
								# Only show Martial if culture affects martial customs,
								# which is only the case if we are able to modify
								# the culture pillars.
								visible = "[HasDlcFeature( 'diverge_culture' )]"
								
								tooltipwidget = {
									using = culture_pillar_tooltip
								}
								spacing = 5
								
								icon_doctrine = {
									size = { 40 40 }
									texture = "[CulturePillar.GetIcon]"
								}
								
								vbox = {
									layoutpolicy_horizontal = expanding
									
									hbox = {
										layoutpolicy_horizontal = expanding
										
										spacing = 5										
										
										text_single = {
											text = "[Culture.GetNameNoTooltip]"
											align = nobaseline
											max_width = 150
										}
										
										text_single = {
											text = "CULTURE_VIEW_MARTIAL_CUSTOM_TEXT"
											align = nobaseline
											max_width = 150
										}
										
										expand = {}
									}
								}
							}
						
							expand = {}
						}
						
						# faith
						hbox = {
							layoutpolicy_horizontal = expanding
							
							datacontext = "[GetPlayer.GetFaith]"
							visible = "[Not(HasDlcFeature( 'diverge_culture' ))]"
							
							hbox_doctrine_faith = {
								datacontext = "[GetFaithDoctrine('doctrine_gender_male_dominated')]"
							}
							
							hbox_doctrine_faith = {
								datacontext = "[GetFaithDoctrine('doctrine_gender_equal')]"
							}
							
							hbox_doctrine_faith = {
								datacontext = "[GetFaithDoctrine('doctrine_gender_female_dominated')]"
							}
						
							expand = {}
						}
						
						text_multi = {
							layoutpolicy_horizontal = expanding
							text = "KP_CULTURE_ADMIN_FAMILY_KNIGHTS"
							autoresize = yes
							max_width = 380
							visible = "[GetScriptedGui('kp_culture_admin_family_knights').IsShown( GuiScope.SetRoot( GetPlayer.GetCulture.MakeScope ).End )]"
						}
					}
					
					widget_permission_header = {
						blockoverride "text" {
							text = "game_concept_court"
						}
					}
					
					vbox = {
						layoutpolicy_horizontal = expanding
						spacing = 5
						
						hbox = {
							layoutpolicy_horizontal = expanding
							spacing = 15
							
							button_checkbox_label = {
								layoutpolicy_horizontal = expanding
								onclick = "[KnightsView.GetKnightPermissions.ToggleAllowCouncillors]"
								blockoverride "checkbox" {
								checked = "[KnightsView.GetKnightPermissions.GetAllowCouncillors]"
								}
								blockoverride "text" {
									raw_text = "game_concept_councillors"
									max_width = @label
									min_width = @label
								}
							}
							
							button_checkbox_label = {
								layoutpolicy_horizontal = expanding
								onclick = "[KnightsView.GetKnightPermissions.ToggleAllowInspiredCourtiers]"
								blockoverride "checkbox" {
								checked = "[KnightsView.GetKnightPermissions.GetAllowInspiredCourtiers]"
								}
								blockoverride "text" {
									text = "game_concept_inspired"
									max_width = @label
									min_width = @label
								}
							}
						}
						
						hbox = {
							layoutpolicy_horizontal = expanding
						
							button_checkbox_label = {
								layoutpolicy_horizontal = expanding
								onclick = "[KnightsView.GetKnightPermissions.ToggleAllowNonCombatCourtPositions]"
								blockoverride "checkbox" {
								checked = "[KnightsView.GetKnightPermissions.GetAllowNonCombatCourtPositions]"
								}
								blockoverride "text" {
									text = "COURT_POSITIONS_KP"
									tooltip = "COURT_POSITIONS_TT"
									max_width = 300
									min_width = 300
								}
							}
						
							expand = {}
						}
					}
					
					widget_permission_header = {
						blockoverride "text" {
							text = "WITH_TRAITS_KP"
						}
					}
					
					hbox = {
						layoutpolicy_horizontal = expanding
						spacing = 15
						
						button_checkbox_label = {
							layoutpolicy_horizontal = expanding
							onclick = "[KnightsView.GetKnightPermissions.ToggleAllowWithTraitWounded]"
							blockoverride "checkbox" {
							checked = "[KnightsView.GetKnightPermissions.GetAllowWithTraitWounded]"
							}
							blockoverride "text" {
								raw_text = "trait_wounded_1"
								max_width = @label
								min_width = @label
							}
						}
						
						button_checkbox_label = {
							layoutpolicy_horizontal = expanding
							onclick = "[KnightsView.GetKnightPermissions.ToggleAllowPregnant]"
							blockoverride "checkbox" {
							checked = "[KnightsView.GetKnightPermissions.GetAllowPregnant]"
							}
							blockoverride "text" {
								raw_text = "trait_pregnant"
								max_width = @label
								min_width = @label
							}
						}
					}
					
					vbox = {
						layoutpolicy_horizontal = expanding
						
						using = Knight_Permissions_Mod
					}					
				}
			}
			
			expand = {}
			
			vbox = {
				layoutpolicy_horizontal = expanding
				margin = { 10 0 }
				margin_bottom = 10
				spacing = 10
				
				hbox = {
					layoutpolicy_horizontal = expanding
					
					margin = { 15 0 }
					margin_bottom = 5
					
					text_single = {
						raw_text = "KNIGHT_RESTRICTIONS"
						default_format = "#e"
						tooltip = "KNIGHT_RESTRICTIONS_TT"
						max_width = 350
					}
					
					expand = {}
				}
				
				button_standard = {
					layoutpolicy_horizontal = expanding
					text = "CHARACTER_RESET_FILTERS"
					onclick = "[KnightsView.GetKnightPermissions.ResetToDefault]"
					enabled = "[Not( KnightsView.GetKnightPermissions.IsDefault )]"
				}
			}
		}
	}
}

types Knights {
	type widget_permission_header = widget {
		size = { 0 30 }
		layoutpolicy_horizontal = expanding
		
		background = {
			using = Background_Area_Dark
			alpha = 0.7
			margin_left = 16
			margin_right = 10
			
			modify_texture = {
				texture = "gfx/interface/component_masks/mask_fade_horizontal_extended.dds"
				blend_mode = alphamultiply
			}
		}
		
		hbox = {
			layoutpolicy_horizontal = expanding
			# spacing = 15
			
			hbox = {
				layoutpolicy_horizontal = expanding
				spacing = 10
				
				text_single = {
					max_width = 300
					block "text" {
						text = ""
					}
					align = nobaseline
				}
				expand = {}
			}
			
			expand = {}
			
			block "extra" {}
		}
	}
	
	type hbox_doctrine_faith = hbox {
		visible = "[And(FaithDoctrine.IsVisible, Faith.HasDoctrine( FaithDoctrine.Self ))]"
		layoutpolicy_vertical = expanding
		using = tooltip_se
		spacing = 5
		
		tooltip = "HBOX_DOCTRINE_FAITH_TT"

		icon_doctrine = {
			name = "doctrine_group_icon"
			size = { 40 40 }
			texture = "[FaithDoctrine.GetIcon]"
		}

		text_single = {
			name = "doctrine_name"
			align = nobaseline
			text = "[FaithDoctrine.GetNameNoTooltip( Faith.Self )]"
			max_width = 300									
		}

		expand = {}
	}
}

# for modders: replace this template instead of ovewriting the whole window
template Knight_Permissions_Mod {
	visible = no
}
