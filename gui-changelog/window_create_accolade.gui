######################################################
################# CREATE ACCOLADE VIEW ###################
######################################################

window = {
	name = "create_accolade_view"
	size = { 540 865 }
	parentanchor = top|right
	position = { -626 170 }
	movable = no
	layer = middle
	datacontext = "[CreateAccoladeView.AccessMilitaryView]"

	using = Window_Background_Subwindow

	state = {
		name = _show
		using = Animation_FadeIn_Quick

		position = { -626 170 }
	}

	state = {
		name = _hide
		using = Animation_FadeOut_Quick

		position_x = -570
	}

	vbox = {
		name = "create_accolade_tutorial_uses_this"
		widgetid = "create_accolade_tutorial_uses_this"
		margin = { 5 5 }

		header_pattern = {
			layoutpolicy_horizontal = expanding

			blockoverride "header_text"
			{
				text = "CREATE_ACCOLADE"
			}

			blockoverride "button_back"
			{
				onclick = "[CreateAccoladeView.Close]"
				onclick = "[OpenGameView( 'knights' )]"
				texture = "gfx/interface/icons/flat_icons/window_back.dds"
				tooltip = "BACK_TOOLTIP"
			}

			blockoverride "button_close"
			{
				onclick = "[CreateAccoladeView.Close]"
			}
		}

		hbox = {
			layoutpolicy_horizontal = expanding
			margin = { 15 0 }

			widget = {
				size = { 145 160 }

				accolade_banner_dark = {
					size = { 100% 100% }
				}

				portrait_shoulders = {
					datacontext = "[CreateAccoladeView.GetSelectedKnight]"
					parentanchor = center
				}
			}

			vbox = {
				visible = "[CreateAccoladeView.GetSelectedKnight.IsValid]"
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding

				margin = { 15 5 }

				background = {
					using = Background_Area

					margin = { 0 -5 }
				}

				hbox = {
					spacing = 5
					layoutpolicy_horizontal = expanding

					margin = { 0 10 }

					background = {
						using = Background_Area_Dark
						alpha = 0.6
						margin = { 15 0 }
					}

					text_single = {
						visible = "[Not( CreateAccoladeView.IsRenaming )]"
						text = "[CreateAccoladeView.GetAccoladeName]"
						max_width = 285
						using = Font_Size_Medium
						align = nobaseline
					}

					button_edit_text = {
						size = { 25 25 }
						visible = "[Not( CreateAccoladeView.IsRenaming )]"
						onclick = "[CreateAccoladeView.ToggleRenaming]"
						tooltip = "RENAME_ACCOLADE"
					}

					editbox_standard = {
						layoutpolicy_horizontal = expanding
						visible = "[CreateAccoladeView.IsRenaming]"

						blockoverride "editbox_properties"
						{
							name = "accolade_name"
							text = "[CreateAccoladeView.GetTempName]"
							ontextedited = "[CreateAccoladeView.EditName]"
							onreturnpressed = "[CreateAccoladeView.SubmitName]"
						}
					}

					expand = {}
				}

				hbox = {
					name = "candidate_attributes_tutorial_uses_this"
					widgetid = "candidate_attributes_tutorial_uses_this"
					layoutpolicy_horizontal = expanding
					margin_top = 5

					vbox = {
						layoutpolicy_horizontal = expanding
						spacing = 10

						accolade_type_box = {
							datacontext = "[CreateAccoladeView.GetSelectedInitialType]"

							blockoverride "subtitle_text"
							{
								text = "ACCOLADE_TYPE"
							}

							blockoverride "change_button"
							{
								icon = {
									visible = "[AccoladeType.GetMaaUnlock.IsValid]"
									datacontext = "[AccoladeType.GetMaaUnlock]"
									texture = "[MenAtArmsType.GetIcon]"
									tooltipwidget = {
										widget_maa_type_container_tooltip = {
											blockoverride "maa_texture"
											{
												texture = "[MenAtArmsType.GetHorizontalImageForCulture( GetPlayer.GetCulture )]"
											}
										}
									}
									size = { 30 30 }
								}
							}
						}
					}
				}

				expand = {}

				hbox = {
					visible = "[CreateAccoladeView.GetSelectedKnight.IsGuest]"
					layoutpolicy_horizontal = expanding

					button_standard = {
						visible = "[CreateAccoladeView.GetSelectedKnight.IsPlayerInteractionShown('recruit_guest_interaction')]"
						enabled = "[CreateAccoladeView.GetSelectedKnight.IsPlayerInteractionValid('recruit_guest_interaction')]"
						onclick = "[CreateAccoladeView.GetSelectedKnight.OpenPlayerInteraction('recruit_guest_interaction')]"
						text = "[CreateAccoladeView.GetSelectedKnight.GetPlayerInteractionName('recruit_guest_interaction')]"
						tooltip = "[CreateAccoladeView.GetSelectedKnight.GetPlayerInteractionTooltip('recruit_guest_interaction')]"
						using = tooltip_se
					}
				}
				hbox = {
					visible = "[Not( CreateAccoladeView.GetSelectedKnight.IsGuest )]"
					layoutpolicy_horizontal = expanding
					spacing = 5

					button_standard = {
						size = { 90 33 }
						onclick = "[MilitaryView.SetKnightForced( CreateAccoladeView.GetSelectedKnight.Self )]"
						down = "[CreateAccoladeView.GetSelectedKnight.IsKnightForced]"
						alwaystransparent = "[CreateAccoladeView.GetSelectedKnight.IsKnightForced]"

						text = "KNIGHTS_VIEW_FORCE"

						tooltip = "CREATE_ACCOLADE_FORCE_TT"
						using = tooltip_se
					}

					button_standard = {
						size = { 90 33 }
						onclick = "[MilitaryView.SetKnightDefault( CreateAccoladeView.GetSelectedKnight.Self )]"
						down = "[CreateAccoladeView.GetSelectedKnight.IsKnightDefault]"
						alwaystransparent = "[CreateAccoladeView.GetSelectedKnight.IsKnightDefault]"

						text = "KNIGHTS_VIEW_ALLOW"

						tooltip = "CREATE_ACCOLADE_BY_PROWESS_TT"
						using = tooltip_se
					}

					button_standard = {
						size = { 90 33 }
						onclick = "[MilitaryView.SetKnightDisallowed( CreateAccoladeView.GetSelectedKnight.Self )]"
						down = "[CreateAccoladeView.GetSelectedKnight.IsKnightDisallowed]"
						alwaystransparent = "[CreateAccoladeView.GetSelectedKnight.IsKnightDisallowed]"
						enabled = "[Not( CreateAccoladeView.GetSelectedKnight.IsAcclaimedKnight )]"


						text = "KNIGHTS_VIEW_FORBID"
						tooltip = "[SelectLocalization( CreateAccoladeView.GetSelectedKnight.IsAcclaimedKnight, 'CANNOT_FORBID_ACCLAIMED_KNIGHT', 'CREATE_ACCOLADE_FORBID_TT' )]"
						using = tooltip_se
					}

					expand = {}
				}

				expand = {}
			}

			vbox = {
				visible = "[Not(CreateAccoladeView.GetSelectedKnight.IsValid)]"
				layoutpolicy_horizontal = expanding
				margin = { 10 0 }

				text_multi = {
					align = center
					text = "CREATE_ACCOLADE_SELECT_KNIGHT"
					default_format = "#help"
					autoresize = yes
					max_width = 300
				}
			}
		}

		vbox = {
			layoutpolicy_horizontal = expanding
			margin = { 20 4 }
			visible = "[CreateAccoladeView.GetSelectedKnight.IsValid]"

			hbox = {
				spacing = 10
				margin = { 0 15 }

				button_standard = {
					size = { 200 40 }

					#onclick = "[CreateAccoladeView.Close]"
					onclick = "[OpenGameViewData( 'create_accolade_view', MilitaryView.GetCharacter.GetID )]"
					shortcut = "go_back"

					text = "CANCEL"
				}

				button_primary = {
					size = { 200 40 }
					enabled = "[CreateAccoladeView.CanCreateAccolade]"
					onclick = "[CreateAccoladeView.CreateAccolade]"

					tooltip = "[CreateAccoladeView.GetCreateAccoladeTooltip]"
					text = "CREATE_ACCOLADE"
				}
			}
		}

		hbox = {
			margin_bottom = 5

			text_label_center = {
				visible = "[CreateAccoladeView.GetSelectedInitialType.IsValid]"
				text = "CREATE_ACCOLADE_TYPES"
				default_format = "#medium"
			}
			text_label_center = {
				visible = "[Not( CreateAccoladeView.GetSelectedInitialType.IsValid )]"
				text = "KNIGHTS_SUBHEADER"
				default_format = "#medium"
			}
		}

		scrollbox = {
			name = "accolade_candidate_list_tutorial_uses_this"

			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			visible = "[Not( CreateAccoladeView.GetSelectedInitialType.IsValid )]"

			blockoverride "scrollbox_content" {
				vbox = {
					name = "acclaimed_knights"
					datamodel = "[MilitaryView.GetKnights]"
					datacontext = "[CreateAccoladeView.AccessKnightsView]"
					layoutpolicy_horizontal = expanding
					spacing = 5

					item = {
						button_standard = {
							layoutpolicy_horizontal = expanding
							size = { 0 126 }

							# has at least 2 potential accolade types
							visible = "[And( And( Or( Not( Character.HasLandedTitles ), Character.GetPrimaryTitle.IsBarony ), KnightsView.HasPotentialAccolade( Character.Self ) ), GreaterThanOrEqualTo_int32(Character.GetProwess, '(int32)8'))]"
							onclick = "[CreateAccoladeView.SetSelectedKnight( Character.Self )]"
							tooltip = "CREATE_ACCOLADE_ASSIGN_TT"
							using = tooltip_nw

							blockoverride "Background_Guest_pattern_visible"
							{
								visible = "[Character.IsGuest]"
								margin_bottom = -5
								margin_right = 5
							}

							blockoverride "Background_Guest_frame_visible"
							{
								visible = "[Character.IsGuest]"
								margin_left = 3
								margin_bottom = -5
								margin_top = 1
								margin_right = 5
							}

							vbox = {
								margin_left = 4
								margin_right = 15

								hbox = {
									layoutpolicy_horizontal = expanding
									layoutpolicy_vertical = expanding
									margin_right = 5
									spacing = 10

									portrait_head = {
										alpha = "[Select_float( Character.IsKnight, '(float)1.0', '(float)0.6' )]"
									}

									vbox = {
										layoutpolicy_vertical = expanding
										layoutpolicy_horizontal = expanding
										spacing = 15

										hbox = {
											layoutpolicy_horizontal = expanding
											margin = { 0 5 }

											background = {
												using = Background_Area_Dark
												alpha = 0.7
												margin_left = 16
												margin_right = 10
												margin_top = -2

												modify_texture = {
													texture = "gfx/interface/component_masks/mask_fade_horizontal_extended.dds"
													blend_mode = alphamultiply
												}
											}

											hbox = {
												layoutpolicy_horizontal = expanding
												layoutpolicy_vertical = expanding
												spacing = 10

												widget = {
													visible = "[Character.IsKnight]"
													size = { 30 30 }

													icon = {
														parentanchor = center
														texture = "gfx/interface/icons/icon_knight_small.dds"
														size = { 40 40 }
													}
												}

												vbox = {
													layoutpolicy_horizontal = expanding
													layoutpolicy_vertical = expanding

													text_single = {
														layoutpolicy_horizontal = expanding
														#AGOT Modified
														# text = "[Character.GetNameNoTooltip]"
														raw_text = "[AGOTGetNameNoTooltip(Character)]"
														using = Font_Size_Medium
														autoresize = no
														alwaystransparent = yes
													}

													text_single = {
														layoutpolicy_horizontal = expanding
														text = "[Character.GetRelationToString( GetPlayer )]"
														default_format = "#low"
														autoresize = no
														align = nobaseline
														alwaystransparent = yes
													}

													expand = {}
												}
											}

											text_single  = {
												text = "[prowess_i][Character.GetSkill( 'prowess' )]"
												align = nobaseline
												default_format = "#high"
												alwaystransparent = yes
												using = Font_Size_Big
											}
										}

										hbox = {
											visible = "[Not(Character.IsGuest)]"
											layoutpolicy_horizontal = expanding
											spacing = 5

											button_standard = {
												size = { 90 33 }
												onclick = "[MilitaryView.SetKnightForced( Character.Self )]"
												down = "[Character.IsKnightForced]"
												alwaystransparent = "[Character.IsKnightForced]"

												text = "KNIGHTS_VIEW_FORCE"

												tooltip = "KNIGHTS_VIEW_TITLE_FORCE_TT"
												using = tooltip_se
											}

											button_standard = {
												size = { 90 33 }
												onclick = "[MilitaryView.SetKnightDefault( Character.Self )]"
												down = "[Character.IsKnightDefault]"
												alwaystransparent = "[Character.IsKnightDefault]"

												text = "KNIGHTS_VIEW_ALLOW"

												tooltip = "KNIGHTS_VIEW_TITLE_BY_PROWESS_TT"
												using = tooltip_se
											}

											button_standard = {
												size = { 90 33 }
												onclick = "[MilitaryView.SetKnightDisallowed( Character.Self )]"
												down = "[Character.IsKnightDisallowed]"
												alwaystransparent = "[Character.IsKnightDisallowed]"
												enabled = "[Not( Character.IsAcclaimedKnight )]"

												text = "KNIGHTS_VIEW_FORBID"
												tooltip = "[SelectLocalization( Character.IsAcclaimedKnight, 'CANNOT_FORBID_ACCLAIMED_KNIGHT', 'KNIGHTS_VIEW_TITLE_FORBID_TT' )]"
												using = tooltip_se
											}

											expand = {}

											icon = {
												visible = "[And( HasDlcFeature( 'accolades' ), And( Or( Not( Character.HasLandedTitles ), Character.GetPrimaryTitle.IsBarony ), KnightsView.HasPotentialAccolade( Character.Self ) ) )]"

												texture = "gfx/interface/icons/icon_knight_acclaimed.dds"
												size = { 30 30 }

												tooltipwidget = {
													using = accolade_types_tooltip
												}

												icon = {
													visible = "[Not( KnightsView.CanBeAcclaimedKnight( Character.Self ) )]"
													size = { 25 25 }
													position = { 10 10 }
													texture = "gfx/interface/icons/symbols/icon_cross.dds"
												}
											}
										}

										hbox = {
											visible = "[Character.IsGuest]"
											layoutpolicy_horizontal = expanding

											button_standard = {
												visible = "[Character.IsPlayerInteractionShown('recruit_guest_interaction')]"
												enabled = "[Character.IsPlayerInteractionValid('recruit_guest_interaction')]"
												onclick = "[Character.OpenPlayerInteraction('recruit_guest_interaction')]"
												text = "[Character.GetPlayerInteractionName('recruit_guest_interaction')]"
												tooltip = "[Character.GetPlayerInteractionTooltip('recruit_guest_interaction')]"
												using = tooltip_se
											}

											expand = {}

											icon = {
												datacontext = "[CreateAccoladeView.AccessKnightsView]"

												visible = "[And( HasDlcFeature( 'accolades' ), And( Or( Not( Character.HasLandedTitles ), Character.GetPrimaryTitle.IsBarony ), KnightsView.HasPotentialAccolade( Character.Self ) ) )]"

												texture = "gfx/interface/icons/icon_knight_acclaimed.dds"
												size = { 30 30 }

												tooltipwidget = {
													using = accolade_types_tooltip
												}

												icon = {
													visible = "[Not( KnightsView.CanBeAcclaimedKnight( Character.Self ) )]"
													size = { 25 25 }
													position = { 10 10 }
													texture = "gfx/interface/icons/symbols/icon_cross.dds"
												}
											}
										}

										expand = {}
									}

								}

								divider = {
									layoutpolicy_horizontal = expanding
								}
							}
						}
					}
				}
			}
		}

		scrollbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			visible = "[CreateAccoladeView.GetSelectedInitialType.IsValid]"

			blockoverride "scrollbox_content"
			{
				fixedgridbox = {
					name = "types_grid"
					datamodel = "[CreateAccoladeView.GetPotentialTypes]"
					layoutpolicy_horizontal = expanding
					flipdirection = yes
					datamodel_wrap = 3
					addcolumn = 180
					addrow = 164

					item = {
						widget = {
							size = { 140 150 }

							button_standard = {
								size = { 96 120 }
								parentanchor = top|hcenter
								onclick = "[CreateAccoladeView.SetSelectedInitialType( AccoladeType.Self )]"
								tooltipwidget = {
									object_tooltip_pop_out = {
										blockoverride "title_text" {
											margin = { 0 8 }
											text = "[AccoladeType.GetName]"
											default_format = "#T"
										}
										blockoverride "concept_link" {
											text = "[accolade_type|E]"
										}
										blockoverride "description_text" {
											text = "CREATE_ACCOLADE_SET_INITIAL_TYPE_TT"
										}
									}
								}

								highlight_icon = {
									name = "accolade_type_icon"
									parentanchor = center
									size = { 92	116 }
									texture = "[AccoladeType.GetIcon]"
									using = Mask_Rough_Edges
								}

								selection_glow = {
									visible = "[ObjectsEqual( AccoladeType.Self, CreateAccoladeView.GetSelectedInitialType )]"
								}
							}

							text_label_center = {
								name = "accolade_type_name"
								parentanchor = bottom|hcenter
								layoutpolicy_horizontal = expanding
								text = "[AccoladeType.GetNameNoTooltip]"
								align = center
								default_format = "#high"
								max_width = 150
							}
						}
					}
				}
			}
		}
	}
}

types CreateAccoladeWindowTypes
{
	type empty_accolade_type_box = hbox {
		layoutpolicy_horizontal = expanding
		spacing = 10

		text_single = {
			layoutpolicy_horizontal = expanding
			text = "CREATE_ACCOLADE_EMPTY_TYPE"
			align = nobaseline
		}

		debug_square = {
			size = { 30 30 }
		}
	}
}

